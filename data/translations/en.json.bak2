  "page_informatique": {
    "g_s_a_en_tete_des_ateliers_dune_journee_selon": "G &amp; S has in mind one-day workshops following an original \"hands-on\" approach with qualified partners, each time on a specific topic such as:",
    "en_sappuyant_sur_des_ateliers_proposes_dans_l": "Drawing on workshops offered in the past, such as the behaviour of men and women in Boards or the use of personal computers, today the focus would be on the use of social media; G &amp; S can organise specific workshops.",
    "codages": "<i class=\"fas fa-code me-2\" style=\"color: #1e73be;\"></i>Coding",
    "cybersecurite_avec_un_hacker_reconverti": "<i class=\"fas fa-shield-alt me-2\" style=\"color: #1e73be;\"></i>Cybersecurity with a Reformed Hacker",
    "cloud_visite_guidee_gros_data_center": "<i class=\"fas fa-cloud me-2\" style=\"color: #1e73be;\"></i>\"Cloud\" Guided Tour of a Large Data Centre",
    "internet_des_objets": "<i class=\"fas fa-network-wired me-2\" style=\"color: #1e73be;\"></i>Internet of Things",
    "call_center_et_intelligence_artificielle": "<i class=\"fas fa-robot me-2\" style=\"color: #1e73be;\"></i>Call Center and Artificial Intelligence",
    "gestion_des_documents_pour_conseils": "<i class=\"fas fa-folder-open me-2\" style=\"color: #1e73be;\"></i>Document Management for Boards",
    "big_data_et_relation_client": "<i class=\"fas fa-database me-2\" style=\"color: #1e73be;\"></i>Big Data and Customer Relations",
    "big_data_interfaces_avec_si_classiques": "<i class=\"fas fa-exchange-alt me-2\" style=\"color: #1e73be;\"></i>Big Data Interfaces with Traditional IT Systems",
    "reglement_europeen_sur_les_donnees_personnell": "<i class=\"fas fa-user-shield me-2\" style=\"color: #1e73be;\"></i>European Regulation on Personal Data",
    "la_cryptographie_et_les_mots_de_passe": "<i class=\"fas fa-lock me-2\" style=\"color: #1e73be;\"></i>Cryptography and Passwords",
    "realite_virtuelle": "<i class=\"fas fa-vr-cardboard me-2\" style=\"color: #1e73be;\"></i>Virtual Reality",
    "blockchain": "<i class=\"fas fa-link me-2\" style=\"color: #1e73be;\"></i>Blockchain",
    "mooc": "<i class=\"fas fa-graduation-cap me-2\" style=\"color: #1e73be;\"></i>MOOC",
    "salle_de_gestion_de_crise": "<i class=\"fas fa-exclamation-triangle me-2\" style=\"color: #1e73be;\"></i>Crisis Management Room",
