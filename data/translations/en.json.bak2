  "page_assises_parite": {
    "forum_de_la_mixite_21_decembre_2012": "<i class=\"fas fa-calendar text-primary me-2\"></i>Gender Diversity Forum - 21 December 2012",
    "webinaire_8_mars_2023": "<i class=\"fas fa-video text-primary me-2\"></i>Webinar - 8 March 2023",
    "presentation_de_letude": "<i class=\"fas fa-chart-line text-primary me-2\"></i>Presentation of the study",
    "au_forum_de_la_mixite_du_21_decembre_2012_guy": "At the Gender Diversity Forum on 21 December 2012, Guy Le Péchon was one of the speakers in the <strong>Leyders Associates</strong> workshop on the theme:",
    "il_a_evoque_les_profils_des_administratrices_": "He mentioned the profiles of directors within nombreuses listed companies on Euronext and suggéré surtout penser à convaincre les Chairmen d'élargir de façon professional les cooptations des members of their Conseils.",
    "reprenant_mis_a_jour_des_elements_de_son_inte": "Reprenant mis à jour des éléments de son intervention enregistrée - Gender Parity Conference 2012 and 2023 - le 8 mars 2023 dans un Webinaire organisé par le <strong>Centre des Professions financières</strong>, fin juin 2023, Guy Le Péchon a été interviewé par <strong>Lucille Desjonquères</strong> au cours de la séance d'inauguration à <strong>Bercy des Assises de la Parité</strong>.",
    "il_a_pu_donner_un_apercu_de_la_situation_de_l": "Il a pu donner un aperçu de la situation de la féminisation des Instances de Gouvernance (Conseils d'Administration or de Surveillance, COMEX and CODIR) des sociétés du CAC 40 à fin juin 2023.",
    "copie_de_lune_des_planches_majeures_projetees": "<strong>Copy of one of the major slides presented</strong>",
    "g_s_enverra_copie_de_la_presentation_de_letud": "G &amp; S enverra copie de la présentation de l'étude and du rapport détaillé à fin juin 2023 aux personnes le demandant indiquant leurs coordonnées à <a href=\"mailto:contact@g-et-s.com\" style=\"color: #1e73be; text-decoration: underline;\">contact@g-et-s.com</a>",
    "se_positionner_pour_etre_administrable_femini": "\"Positioning yourself to be board-ready. Feminising your board.\"",
    "obtenir_le_rapport_complet": "<i class=\"fas fa-envelope text-info me-2\"></i>Obtain the full report",
    "assises_de_la_parite_2012_et_2023": "Gender Parity Conference 2012 and 2023"
  },
  "page_bibliographie": {
    "articles_interessants_publies_dans_la_presse_": "Interesting articles published in the press on \"Corporate Governance\"",
    "actions_diverses_de_g_squelques_unes_des_inte": "<p data-i18n=\"page_bibliographie.actions_diverses_de_g_s\"><span style=\"color: #ff0000;\">VARIOUS ACTIONS BY G&amp;S</span></p>\n<p data-i18n=\"page_bibliographie.quelques_unes_des_interventions_passees_de_g_\">Some of the past interventions by G &amp; S</p>",
    "actions_diverses_de_g_s": "<span style=\"color: #ff0000;\">VARIOUS ACTIONS BY G&amp;S</span>",
    "quelques_unes_des_interventions_passees_de_g_": "Quelques-unes des interventions passées de G &amp; S",
    "grace_a_une_serie_detudes_de_cas_se_lisant_fa": "Thanks to a series of case studies as easy to read as short detective novels, the author, drawing on his long practical experience as a director, presents the delicate and exciting side of the director's role. For each case, he comments and derives best governance practices.",
    "lactualite_nannihile_pas_les_ecrits_passes_im": "<span style=\"color: #ff0000;\"><b>Current events do not invalidate important past writings</b></span>",
    "un_extrait_du_rapport_bouton_concernantles_cr": "<span style=\"color: #000099;\"><b>An excerpt from the Bouton Report concerning<br/>the criteria for qualifying<br/>a director as \"independent\"<br/>is recalled here:</b></span>",
    "1_ni_mandataire_social_ni_salarie_actuel_ou_a": "<span style=\"font-size: small;\">\n                                                                        1- Neither corporate officer nor current (or past five years) employee.<br/>\n                                                                        2- Not a cross-director.<br/>\n                                                                        3- Not a significant client, supplier or banker (for business or financing purposes) or representing a significant share of the company's activity.<br/>\n                                                                        4- No close family ties with a corporate officer.<br/>\n                                                                        5- Neither partner nor current (or past five years) collaborator of the Statutory Auditors.<br/>\n                                                                        6- Not a director of the company for more than twelve years.<br/>\n                                                                        7- Shareholders:<br/>\n                                                                        – Below 10%: independent if not participating in control.<br/>\n                                                                        – Above 10%: review by the board, depending on the ownership structure and the existence of potential conflicts of interest.\n                                                                    </span>",
    "bibliographie_corporate_governance": "Corporate Governance Bibliography",
    "on_directorshipshareholder_advocates_are_keen": "<div>\n<table class=\"table\">\n<tbody>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.on_directorshipshareholder_advocates_are_keen_2\">\n<a href=\"http://ondirectorship.com/ondirectorship/j3xb9xcqpivwnw6dktyde495k7ktr0\">\n<span style=\"text-decoration: underline;\"><strong><span style=\"color: #000080; text-transform: uppercase;\">On Directorship</span></strong></span><br/>\n<span style=\"color: blue;\">Shareholder advocates are keen to point out the risk of company directors becoming captured by \"groupthink\".</span><br/>\n<span style=\"color: black;\">Peter Tunjic, Lawyer/Writer/Creator, Melbourne, Australia</span>\n</a><br/>\n<span style=\"color: #808080;\">Original article explaining the reasons, the presence and the dangers of \"groupthink\" within boards of directors</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.harvard_business_review_france_11_12_2014_la_\">\n<a href=\"http://www.hbrfrance.fr/chroniques-experts/2014/12/5477-la-feminisation-une-source-de-renouveau-pour-les-conseils-dadministration/\">\n<span style=\"text-decoration: underline;\"><strong><span style=\"color: #000080;\">Harvard Business Review France (11/12/2014)</span></strong></span><br/>\n<span style=\"color: blue;\">Feminisation, a source of renewal for boards of directors.</span><br/>\n<span style=\"color: black;\">Viviane de Beaufort (Professor at ESSEC) (Women Be European Board Ready Training)</span>\n</a><br/>\n<span style=\"color: #808080;\">Detailed arguments on the benefits of the presence of female directors on Boards</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.liberation_29_05_2014_presenteisme_alibi_masc\">\n<span style=\"text-decoration: underline;\"><strong><span style=\"color: #000080;\"><a href=\"http://www.ft.com/intl/cms/s/0/3bdb9b68-f0cb-11e0-aec8-00144feab49a.html#axzz1bURIcX45\" style=\"color: #000080;\"><span style=\"text-transform: uppercase;\">LIBERATION (29/05/2014)</span></a></span></strong></span><br/>\n<a href=\"http://www.liberation.fr/societe/2014/05/26/presenteisme-alibi-masculin-pour-eviter-les-taches-menageres_1027387\">\n<span style=\"color: blue;\">\"Presenteeism: a male alibi to avoid household chores?\"</span>\n</a><br/>\n<span style=\"color: black;\">François Fatoux, Member of the equality laboratory</span><br/>\n<span style=\"color: #808080;\">A remarkable and in-depth analysis of the five forms of presenteeism at work, the fifth form being \"totally taboo, which overwhelmingly affects men who are relieved, without wanting to admit it, to have to stay 'stuck' at work because going home early means preparing dinner, monitoring children's homework, feeding them, doing housework. It is still more pleasant to come home when everything is done.\"<br/>\n                                                G &amp; S sees this as one of the causes of the glass ceiling. Indeed, these accumulated late working hours, over a year for example, can result in good professional results. However, these good results, rather than the presence itself, will positively influence assessments and consequently the career progression of those who practise them.</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.la_tribune_5_9_12_bientot_des_quotas_de_femme\">\n<span style=\"text-decoration: underline;\"><span style=\"color: #000080;\"><strong><a href=\"http://www.ft.com/intl/cms/s/0/3bdb9b68-f0cb-11e0-aec8-00144feab49a.html#axzz1bURIcX45\" style=\"color: #000080;\"><span style=\"text-transform: uppercase;\">LA TRIBUNE (5/9/12)</span></a></strong></span></span><br/>\n<span style=\"color: blue;\"><a href=\"http://www.latribune.fr/actualites/economie/union-europeenne/20120904trib000717652/bientot-des-quotas-de-femmes-administratrices-dans-toute-l-ue.html?goback=.gde_3816734_member_158951768\">\"Soon quotas for female directors throughout the EU\"</a></span><br/>\n<span style=\"color: black;\">Marina Torre</span><br/>\n<span style=\"color: #808080;\">Measures which, according to a document obtained by the Financial Times, the services of Viviane Reding, EU Commissioner for Justice, are studying.</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.lentreprisefemmes_administratrices_je_vous_ai\">\n<a href=\"http://www.ft.com/intl/cms/s/0/3bdb9b68-f0cb-11e0-aec8-00144feab49a.html#axzz1bURIcX45\">\n<span style=\"text-decoration: underline; color: #000080;\"><strong>L'ENTREPRISE</strong></span>\n</a><br/>\n<span style=\"color: blue;\">\"Women directors: I love you\"</span>\n<span style=\"color: #808080;\">CAC 40 companies are drawing from the pool of women business owners of SMEs to improve gender diversity on their board. Why not you?</span><br/>\n<span style=\"color: blue;\">L'Entreprise November 2010 No. 294</span><br/>\n<span style=\"color: black;\">Corinne Corniou</span><br/>\n<span style=\"color: #808080;\">An overview of the advances in CAC 40 boards and their directors</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.financial_times_electroniceveryone_benefits_o\">\n<span style=\"text-decoration: underline;\"><strong><span style=\"color: #000080;\"><a href=\"http://www.hbrfrance.fr/chroniques-experts/2014/12/5477-la-feminisation-une-source-de-renouveau-pour-les-conseils-dadministration/\" style=\"color: #000080;\"><span style=\"text-transform: uppercase;\">FINANCIAL TIMES ELECTRONIC</span></a></span></strong></span><br/>\n<span style=\"color: blue;\">\"Everyone benefits of a beast in the boardroom\"<br/>1 October 2010</span><br/>\n<span style=\"color: black;\">Lucy Kellaway</span><br/>\n<span style=\"color: #808080;\">A very humorous analysis of the value of having an \"iconoclastic villain\" as a board member. By amusing analogy with quotas for other minorities including women, the journalist asks \"Should there be quotas for villains?\"</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.challengesje_suis_top_ou_comment_briser_le_pl\">\n<span style=\"text-decoration: underline;\"><span style=\"color: #000080;\"><strong><a href=\"http://www.jesuistop.fr/\" style=\"color: #000080;\"><span style=\"text-transform: uppercase;\">CHALLENGES</span></a></strong></span></span><br/>\n<span style=\"color: blue;\">\"Je suis top\", or how to break the glass ceiling\"<br/>1 December 2010</span><br/>\n<span style=\"color: black;\">Anne-Marie Rocco</span><br/>\n<span style=\"color: #808080;\">Positive analysis of the play \"Je suis au top\" by Blandine Métayer performed in December 2010 at the Théâtre de 10 heures. The play follows the adventures of a woman trying to reach executive positions by breaking the glass ceiling.</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.lexpress8_septembre_2010valerie_liongouvernan\">\n<span style=\"color: #000080;\"><strong><span style=\"text-decoration: underline;\"><a href=\"./../wp-content/uploads/2020/01/vlionexpresssept.pdf\" style=\"color: #000080;\"><span style=\"text-transform: uppercase;\">L'EXPRESS</span></a></span></strong></span><br/>\n<span style=\"color: blue;\">8 September 2010</span><br/>\n<span style=\"color: black;\">Valérie Lion</span><br/>\n<span style=\"color: #808080;\">Governance, Eternal Masculine<br/>The heavyweights of the CAC 40 have feminised their boards. But behind the scenes, immobility reigns, as revealed by an exclusive study….</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.challengesdes_quotas_pour_etablir_legalite11_\">\n<span style=\"text-decoration: underline; color: #000080;\"><strong><a href=\"http://www.challenges.fr/magazine/international/0199.28686/\" style=\"color: #000080;\"><span style=\"text-transform: uppercase;\">CHALLENGES</span></a></strong></span><br/>\n<span style=\"color: blue;\">Quotas to establish equality<br/>11 February 2010</span><br/>\n<span style=\"color: black;\">Richard Descoings</span><br/>\n<span style=\"color: #808080;\">This editorial article defends the idea that the law on quotas for female directors should be temporary. G &amp; S shares the same opinion.</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.lexpressou_sont_les_femmes_conseils_dadminist\">\n<span style=\"text-decoration: underline;\"><strong><span style=\"color: #000080;\"><a href=\"http://www.lexpress.fr/actualite/economie/ou-sont-les-femmes_841709.html\" style=\"color: #000080;\"><span style=\"text-transform: uppercase;\">L'EXPRESS</span></a></span></strong></span><br/>\n<span style=\"color: blue;\">Where are the women? Boards of Directors<br/>13 January 2010</span><br/>\n<span style=\"color: black;\">Valérie Lion</span><br/>\n<span style=\"color: #808080;\">Many articles appeared before and after the debate in the National Assembly on 19 January 2010 on the bill on gender parity in boards of directors and supervisory boards of companies. This one, <a href=\"http://www.lexpress.fr/actualite/economie/ou-sont-les-femmes_841709.html\">available online</a>, is interesting as it provides a structured summary with examples and explanations of the situation regarding CAC 40 companies.</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.sur_119_societes_cotees_sur_alternext_trois_s\">\n<span style=\"text-decoration: underline; color: #000080;\"><strong><span style=\"text-transform: uppercase;\">Of 119 listed companies on Alternext, three are led by women!</span></strong></span><br/>\n<span style=\"color: blue;\">Challenges No. 193, 17 December 2009</span><br/>\n<span style=\"color: black;\">Marc Fiorentino</span><br/>\n<span style=\"color: #808080;\">After discussing his search for female executives in Alternext companies and noting their small number, he recommends buying shares in the three companies led by women.</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.le_gouvernement_veut_feminiser_lencadrement_d\">\n<a href=\"http://www.hbrfrance.fr/chroniques-experts/2014/12/5477-la-feminisation-une-source-de-renouveau-pour-les-conseils-dadministration/\">\n<span style=\"text-decoration: underline; color: #000080;\"><strong>The government wants to feminise corporate management</strong></span>\n</a><br/>\n<span style=\"color: blue;\">Le Monde, 6 November 2009</span><br/>\n<span style=\"color: #808080;\">A very humorous analysis of the value of having an \"iconoclastic villain\" as a board member. By amusing analogy with quotas for other minorities including women, the journalist asks \"Should there be quotas for villains?\"</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.jean_francois_cope_sengage_pour_legalite_homm\">\n<span style=\"color: #000080;\"><a href=\"http://www.hbrfrance.fr/chroniques-experts/2014/12/5477-la-feminisation-une-source-de-renouveau-pour-les-conseils-dadministration/\" style=\"color: #000080;\">\n<span style=\"text-decoration: underline;\"><strong>Jean-François Copé commits to gender equality at work</strong></span>\n</a></span><br/>\n<span style=\"color: blue;\">Lefigaro.fr, 25 October 2009</span><br/>\n<span style=\"color: #808080;\">In an interview with the Journal du Dimanche, he expresses his wish that \"in the coming days, a bill be introduced providing that 40%, and eventually 50%, of seats on the boards of directors of large companies be reserved for women.\"</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.quotas_de_femmes_la_cle_de_la_paritelefigaro_\">\n<span style=\"color: #000080;\"><a href=\"http://madame.lefigaro.fr/societe/en-kiosque/2257-la-cle-de-la-parite/2\" style=\"color: #000080;\">\n<span style=\"text-decoration: underline;\"><strong>Quotas for women directors, the key to parity</strong></span>\n</a></span><br/>\n<span style=\"color: blue;\">Lefigaro.fr, 29 September 2009</span><br/>\n<span style=\"color: black;\">Clara Dufour</span><br/>\n<span style=\"color: #808080;\">Results of a poll on the introduction of gender quotas in Boards of Directors and comments by personalities active in this field.</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.une_image_approfondie_sur_internet_cela_senca\">\n<a href=\"http://madame.lefigaro.fr/societe/en-kiosque/2257-la-cle-de-la-parite/2\">\n<span style=\"text-decoration: underline;\"><span style=\"color: #000080;\"><strong>Managing your online image in depth</strong></span></span>\n</a><br/>\n<span style=\"color: blue;\">Challenges No. 22, October 2009</span><br/>\n<span style=\"color: black;\">Gilles Fontaine</span><br/>\n<span style=\"color: #808080;\">Recommendations useful for Chairmen and directors of companies who want to prevent their image being damaged via the Web.</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" style=\"text-align: center;\">\n<img alt=\"en couverture\" decoding=\"async\" src=\"./../wp-content/uploads/2020/01/chalengfem-300x201.jpg\" style=\"max-width: 100%; height: auto;\"/>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.dossier_approfondi_sur_les_femmes_administrat\">\n<span style=\"text-decoration: underline;\"><strong><span style=\"color: #000080; text-transform: uppercase;\">In-depth dossier on female directors, 50 women qualified to sit on Boards of Directors and foreseeable trends</span></strong></span><br/>\n<span style=\"color: blue;\">Challenges No. 15, October 2009</span><br/>\n<span style=\"color: black;\">Anne-Marie Rocco</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.les_hedge_funds_sont_le_trou_noir_de_la_finan\">\n<span style=\"text-decoration: underline;\"><span style=\"color: #000080;\"><strong><span style=\"text-transform: uppercase;\">Hedge funds are the black hole of global finance</span></strong></span></span><br/>\n<span style=\"color: blue;\">Interview with Daniel Le Bègue, Chairman of the IFA<br/>Le Monde, economics section, 23 September 2008</span><br/>\n<span style=\"color: #808080;\">He recommends that all major economic and political actors issue \"an appeal to the thirty largest global banks to turn away from the least reputable tax havens.\"</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.lobservatoire_de_la_gouvernance_altedia_la_tr\">\n<span style=\"text-decoration: underline; color: #000080;\"><strong><span style=\"text-transform: uppercase;\">The Altedia-La Tribune Governance Observatory</span></strong></span><br/>\n<span style=\"color: blue;\">La Tribune – 16 October 2007 – Survey</span><br/>\n<span style=\"color: #808080;\">The board of directors put to the test of practice<br/>Surveyed for the 5th consecutive year, French listed companies confirm their progress in governance. The strengthening of the role of committees reinforces the power of the board. But its functioning is far from optimal.</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.soft_regulation_not_rulesby_bruce_kogutnumero\">\n<a href=\"http://madame.lefigaro.fr/societe/en-kiosque/2257-la-cle-de-la-parite/2\">\n<span style=\"text-decoration: underline; color: #000080;\"><strong>\"Soft Regulation, not rules\"</strong></span>\n</a><br/>\n<span style=\"color: blue;\">by Bruce Kogut<br/>October 2006 issue of World Business</span><br/>\n<span style=\"color: black;\">Gilles Fontaine</span><br/>\n<span style=\"color: #808080;\">Strict laws and prison cannot substitute for adequate Boards of Directors and shareholders in steering managers.</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.dans_le_domaine_de_la_gouvernance_souvent_on_\" style=\"text-align: center;\">\n<span style=\"color: blue;\">In the field of governance, it is often noted that ideas and recommendations have not yet been put into practice.<br/>If a historical list of articles identified by G &amp; S interests you, you can download it <a href=\"./../wp-content/uploads/2020/01/bibliopassee.doc\" style=\"color: lightblue;\">by clicking here</a></span>\n</td>\n</tr>\n</tbody>\n</table>\n</div>",
    "on_directorshipshareholder_advocates_are_keen_2": "<a href=\"http://ondirectorship.com/ondirectorship/j3xb9xcqpivwnw6dktyde495k7ktr0\">\n<span style=\"text-decoration: underline;\"><strong><span style=\"color: #000080; text-transform: uppercase;\">On Directorship</span></strong></span><br/>\n<span style=\"color: blue;\">Shareholder advocates are keen to point out the risk of company directors becoming captured by \"groupthink\".</span><br/>\n<span style=\"color: black;\">Peter Tunjic, Lawyer/Writer/Creator, Melbourne, Australia</span>\n</a><br/>\n<span style=\"color: #808080;\">Article original expliquant les raisons, la présence and les dangers de la \"pensée de groupe\" au sein des conseils</span>",
    "harvard_business_review_france_11_12_2014_la_": "<a href=\"http://www.hbrfrance.fr/chroniques-experts/2014/12/5477-la-feminisation-une-source-de-renouveau-pour-les-conseils-dadministration/\">\n<span style=\"text-decoration: underline;\"><strong><span style=\"color: #000080;\">Harvard Business Review France (11/12/2014)</span></strong></span><br/>\n<span style=\"color: blue;\">Feminisation, a source of renewal for boards of directors.</span><br/>\n<span style=\"color: black;\">Viviane de Beaufort (Professor at ESSEC) (Women Be European Board Ready Training)</span>\n</a><br/>\n<span style=\"color: #808080;\">Detailed arguments on the benefits of the presence of female directors on Boards</span>",
    "liberation_29_05_2014_presenteisme_alibi_masc": "<span style=\"text-decoration: underline;\"><strong><span style=\"color: #000080;\"><a href=\"http://www.ft.com/intl/cms/s/0/3bdb9b68-f0cb-11e0-aec8-00144feab49a.html#axzz1bURIcX45\" style=\"color: #000080;\"><span style=\"text-transform: uppercase;\">LIBERATION (29/05/2014)</span></a></span></strong></span><br/>\n<a href=\"http://www.liberation.fr/societe/2014/05/26/presenteisme-alibi-masculin-pour-eviter-les-taches-menageres_1027387\">\n<span style=\"color: blue;\">\"Presenteeism: a male alibi to avoid household chores?\"</span>\n</a><br/>\n<span style=\"color: black;\">François Fatoux, Member of the equality laboratory</span><br/>\n<span style=\"color: #808080;\">A remarkable and in-depth analysis of the five forms of presenteeism at work, the fifth form being \"totally taboo, which overwhelmingly affects men who are relieved, without wanting to admit it, to have to stay 'stuck' at work because going home early means preparing dinner, monitoring children's homework, feeding them, doing housework. It is still more pleasant to come home when everything is done.\"<br/>\n                                                G &amp; S sees this as one of the causes of the glass ceiling. Indeed, these accumulated late working hours, over a year for example, can result in good professional results. However, these good results, rather than the presence itself, will positively influence assessments and consequently the career progression of those who practise them.</span>",
    "la_tribune_5_9_12_bientot_des_quotas_de_femme": "<span style=\"text-decoration: underline;\"><span style=\"color: #000080;\"><strong><a href=\"http://www.ft.com/intl/cms/s/0/3bdb9b68-f0cb-11e0-aec8-00144feab49a.html#axzz1bURIcX45\" style=\"color: #000080;\"><span style=\"text-transform: uppercase;\">LA TRIBUNE (5/9/12)</span></a></strong></span></span><br/>\n<span style=\"color: blue;\"><a href=\"http://www.latribune.fr/actualites/economie/union-europeenne/20120904trib000717652/bientot-des-quotas-de-femmes-administratrices-dans-toute-l-ue.html?goback=.gde_3816734_member_158951768\">\"Soon quotas for female directors throughout the EU\"</a></span><br/>\n<span style=\"color: black;\">Marina Torre</span><br/>\n<span style=\"color: #808080;\">Measures which, according to a document obtained by the Financial Times, the services of Viviane Reding, EU Commissioner for Justice, are studying.</span>",
    "lentreprisefemmes_administratrices_je_vous_ai": "<a href=\"http://www.ft.com/intl/cms/s/0/3bdb9b68-f0cb-11e0-aec8-00144feab49a.html#axzz1bURIcX45\">\n<span style=\"text-decoration: underline; color: #000080;\"><strong>L'ENTREPRISE</strong></span>\n</a><br/>\n<span style=\"color: blue;\">\"Women directors: I love you\"</span>\n<span style=\"color: #808080;\">CAC 40 companies are drawing from the pool of women business owners of SMEs to improve gender diversity on their board. Why not you?</span><br/>\n<span style=\"color: blue;\">L'Entreprise November 2010 No. 294</span><br/>\n<span style=\"color: black;\">Corinne Corniou</span><br/>\n<span style=\"color: #808080;\">An overview of the advances in CAC 40 boards and their directors</span>",
    "financial_times_electroniceveryone_benefits_o": "<span style=\"text-decoration: underline;\"><strong><span style=\"color: #000080;\"><a href=\"http://www.hbrfrance.fr/chroniques-experts/2014/12/5477-la-feminisation-une-source-de-renouveau-pour-les-conseils-dadministration/\" style=\"color: #000080;\"><span style=\"text-transform: uppercase;\">FINANCIAL TIMES ELECTRONIC</span></a></span></strong></span><br/>\n<span style=\"color: blue;\">\"Everyone benefits of a beast in the boardroom\"<br/>1 October 2010</span><br/>\n<span style=\"color: black;\">Lucy Kellaway</span><br/>\n<span style=\"color: #808080;\">A very humorous analysis of the value of having an \"iconoclastic villain\" as a board member. By amusing analogy with quotas for other minorities including women, the journalist asks \"Should there be quotas for villains?\"</span>",
    "challengesje_suis_top_ou_comment_briser_le_pl": "<span style=\"text-decoration: underline;\"><span style=\"color: #000080;\"><strong><a href=\"http://www.jesuistop.fr/\" style=\"color: #000080;\"><span style=\"text-transform: uppercase;\">CHALLENGES</span></a></strong></span></span><br/>\n<span style=\"color: blue;\">\"Je suis top\", or comment briser le glass ceiling\"<br/>1 December 2010</span><br/>\n<span style=\"color: black;\">Anne-Marie Rocco</span><br/>\n<span style=\"color: #808080;\">Analyse positive of the pièce \"Je suis au top\" de Blandine Métayer jouée en December 2010 au théâtre of ten heures. La pièce relate les pérégrinations of a femme pour atteindre of positions de dirigeantes en brisant le glass ceiling.</span>",
    "lexpress8_septembre_2010valerie_liongouvernan": "<span style=\"color: #000080;\"><strong><span style=\"text-decoration: underline;\"><a href=\"./../wp-content/uploads/2020/01/vlionexpresssept.pdf\" style=\"color: #000080;\"><span style=\"text-transform: uppercase;\">L'EXPRESS</span></a></span></strong></span><br/>\n<span style=\"color: blue;\">8 September 2010</span><br/>\n<span style=\"color: black;\">Valérie Lion</span><br/>\n<span style=\"color: #808080;\">Governance, Eternal Masculine<br/>The heavyweights of the CAC 40 have feminised their boards. But behind the scenes, immobility reigns, as revealed by an exclusive study….</span>",
    "challengesdes_quotas_pour_etablir_legalite11_": "<span style=\"text-decoration: underline; color: #000080;\"><strong><a href=\"http://www.challenges.fr/magazine/international/0199.28686/\" style=\"color: #000080;\"><span style=\"text-transform: uppercase;\">CHALLENGES</span></a></strong></span><br/>\n<span style=\"color: blue;\">Quotas to establish equality<br/>11 February 2010</span><br/>\n<span style=\"color: black;\">Richard Descoings</span><br/>\n<span style=\"color: #808080;\">This editorial article defends the idea that the Law on quotas for female directors should be temporary. G &amp; S shares the same opinion.</span>",
    "lexpressou_sont_les_femmes_conseils_dadminist": "<span style=\"text-decoration: underline;\"><strong><span style=\"color: #000080;\"><a href=\"http://www.lexpress.fr/actualite/economie/ou-sont-les-femmes_841709.html\" style=\"color: #000080;\"><span style=\"text-transform: uppercase;\">L'EXPRESS</span></a></span></strong></span><br/>\n<span style=\"color: blue;\">Où sont les femmes ? Boards of Directors<br/>13 January 2010</span><br/>\n<span style=\"color: black;\">Valérie Lion</span><br/>\n<span style=\"color: #808080;\">De nombreux articles sont parus avant and après la discussion à l'National Assembly le 19 January 2010 of the bill on the gender parity within the boards of directors and supervisory boards of companies. Celui-ci, <a href=\"http://www.lexpress.fr/actualite/economie/ou-sont-les-femmes_841709.html\">available online</a>, est interesting car he gives une synthèse structurée with exemples and explications de the situation regarding les CAC 40 companies.</span>",
    "sur_119_societes_cotees_sur_alternext_trois_s": "<span style=\"text-decoration: underline; color: #000080;\"><strong><span style=\"text-transform: uppercase;\">Of 119 listed companies on Alternext, three are led by women!</span></strong></span><br/>\n<span style=\"color: blue;\">Challenges No. 193, 17 December 2009</span><br/>\n<span style=\"color: black;\">Marc Fiorentino</span><br/>\n<span style=\"color: #808080;\">After discussing his search for female executives in Alternext companies and noting their small number, he recommends buying shares in the three companies led by women.</span>",
    "le_gouvernement_veut_feminiser_lencadrement_d": "<a href=\"http://www.hbrfrance.fr/chroniques-experts/2014/12/5477-la-feminisation-une-source-de-renouveau-pour-les-conseils-dadministration/\">\n<span style=\"text-decoration: underline; color: #000080;\"><strong>The government wants to feminise corporate management</strong></span>\n</a><br/>\n<span style=\"color: blue;\">Le Monde, 6 November 2009</span><br/>\n<span style=\"color: #808080;\">A very humorous analysis of the value of having an \"iconoclastic villain\" as a board member. By amusing analogy with quotas for other minorities including women, the journalist asks \"Should there be quotas for villains?\"</span>",
    "jean_francois_cope_sengage_pour_legalite_homm": "<span style=\"color: #000080;\"><a href=\"http://www.hbrfrance.fr/chroniques-experts/2014/12/5477-la-feminisation-une-source-de-renouveau-pour-les-conseils-dadministration/\" style=\"color: #000080;\">\n<span style=\"text-decoration: underline;\"><strong>Jean-François Copé commits to gender equality at work</strong></span>\n</a></span><br/>\n<span style=\"color: blue;\">Lefigaro.fr, 25 October 2009</span><br/>\n<span style=\"color: #808080;\">In an interview with the Journal du Dimanche, he wishes that \"in the coming days, a bill be introduced providing that 40%, and eventually 50%, of seats on the boards of large companies be reserved for women.\"</span>",
    "quotas_de_femmes_la_cle_de_la_paritelefigaro_": "<span style=\"color: #000080;\"><a href=\"http://madame.lefigaro.fr/societe/en-kiosque/2257-la-cle-de-la-parite/2\" style=\"color: #000080;\">\n<span style=\"text-decoration: underline;\"><strong>Quotas for women directors, la clé of the parité</strong></span>\n</a></span><br/>\n<span style=\"color: blue;\">Lefigaro.fr of 29/9/2009</span><br/>\n<span style=\"color: black;\">Clara Dufour</span><br/>\n<span style=\"color: #808080;\">Résultats of a sondage sur l'instauration de quotas hommes/femmes in Board of Directorss and commentaires by personnalités œuvrant in this doMayne</span>",
    "une_image_approfondie_sur_internet_cela_senca": "<a href=\"http://madame.lefigaro.fr/societe/en-kiosque/2257-la-cle-de-la-parite/2\">\n<span style=\"text-decoration: underline;\"><span style=\"color: #000080;\"><strong>Une image in-depth sur Internet cela s'encadre</strong></span></span>\n</a><br/>\n<span style=\"color: blue;\">Challenges No. 22 October 2009</span><br/>\n<span style=\"color: black;\">Gilles Fontaine</span><br/>\n<span style=\"color: #808080;\">Des recommandations pouvant intéresser les Chairmen and directors de companies who want éviter that theur image is détériorée via le WEB</span>",
    "dossier_approfondi_sur_les_femmes_administrat": "<span style=\"text-decoration: underline;\"><strong><span style=\"color: #000080; text-transform: uppercase;\">Dossier in-depth on the women directors, 50 femmes aptes à siéger in Boards of Directors and évolution prévisible</span></strong></span><br/>\n<span style=\"color: blue;\">Challenges No. 15 October 2009</span><br/>\n<span style=\"color: black;\">Anne-Marie Rocco</span>",
    "les_hedge_funds_sont_le_trou_noir_de_la_finan": "<span style=\"text-decoration: underline;\"><span style=\"color: #000080;\"><strong><span style=\"text-transform: uppercase;\">Hedge funds are the black hole of global finance</span></strong></span></span><br/>\n<span style=\"color: blue;\">Interview with Daniel Le Bègue, Chairman of the IFA<br/>Le Monde, economics section, 23 September 2008</span><br/>\n<span style=\"color: #808080;\">He recommends that all major economic and political actors issue \"an appeal to the thirty largest global banks to turn away from the least reputable tax havens.\"</span>",
    "lobservatoire_de_la_gouvernance_altedia_la_tr": "<span style=\"text-decoration: underline; color: #000080;\"><strong><span style=\"text-transform: uppercase;\">The Altedia-La Tribune Governance Observatory</span></strong></span><br/>\n<span style=\"color: blue;\">La Tribune – 16 October 2007 – Survey</span><br/>\n<span style=\"color: #808080;\">The board of directors put to the test of practice<br/>Surveyed for the 5th consecutive year, French listed companies confirm their progress in governance. The strengthening of the role of committees reinforces the power of the board. But its functioning is far from optimal.</span>",
    "soft_regulation_not_rulesby_bruce_kogutnumero": "<a href=\"http://madame.lefigaro.fr/societe/en-kiosque/2257-la-cle-de-la-parite/2\">\n<span style=\"text-decoration: underline; color: #000080;\"><strong>\"Soft Regulation, not rules\"</strong></span>\n</a><br/>\n<span style=\"color: blue;\">by Bruce Kogut<br/>October 2006 issue of World Business</span><br/>\n<span style=\"color: black;\">Gilles Fontaine</span><br/>\n<span style=\"color: #808080;\">Strict laws and prison cannot substitute for adequate Boards of Directors and shareholders in steering managers.</span>",
    "dans_le_domaine_de_la_gouvernance_souvent_on_": "<span style=\"color: blue;\">In the field of governance, it is often noted that ideas and recommendations have not yet been put into practice.<br/>If a historical list of articles identified by G &amp; S interests you, you can download it <a href=\"./../wp-content/uploads/2020/01/bibliopassee.doc\" style=\"color: lightblue;\">by clicking here</a></span>",
    "au_cours_de_la_reunion_du_27_novembre_2016de1": "<div>\n<table class=\"table\">\n<tbody>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.au_cours_de_la_reunion_du_27_novembre_2016de1_2\" style=\"text-align: left;\">\n<a href=\"http://www.100womeninhedgefunds.org/pages/event.php?e=1225&amp;inc=A&amp;yr=0&amp;loc=12&amp;kw=&amp;p=1\">\n<span style=\"color: red;\">During the meeting on 27 November 2016</span> of<br/>\n<span style=\"color: blue;\">100 Women in Hedge Funds on the topic</span><br/>\n<span style=\"color: black;\">Women on Boards in Paris and Abroad – Where are We?</span>\n</a><br/>\n<span style=\"color: #808080;\">Guy Le Péchon spoke as part of the panel discussion. He previewed the main results of G &amp; S studies on the 1,000 female directors of Boards of 400 companies listed on Euronext Paris tracked for 7 years by G &amp; S, <a href=\"./../wp-content/uploads/2020/01/wihf%20flyer.pdf\">see leaflet</a></span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.au_cours_de_la_matinale_du_23_juin_2014tenue_\" style=\"text-align: left;\">\n<span style=\"color: red;\">During the morning event on 23 June 2014</span> held by the IFA<br/>\n<span style=\"color: blue;\">\"First lessons from the 2014 Annual General Meetings\"</span><br/>\n<span style=\"color: #808080;\">chaired by Caroline De La Marinière of Capital Com, she cited the initial estimates from G &amp; S concerning CAC 40 companies after reading the annual reports and 2014 AGM convening notices: the average ratio now slightly exceeds 30%. <a href=\"./../wp-content/uploads/2020/01/cb%20%25%202013%202014.pdf\">See Charts</a></span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.auforum_de_la_mixitedu_21_decembre_2012guy_le\" style=\"text-align: left;\">\n<span style=\"color: red;\">At the <a href=\"http://www.forumdelamixite.com/\" style=\"color: red;\">Gender Diversity Forum</a> on 21 December 2012</span><br/>\n<span style=\"color: blue;\">Guy Le Péchon was one of the speakers in the Leyders Associates workshop</span><br/>\n<span style=\"color: #808080;\">\"Positioning yourself to be board-ready. Feminising your board.\"<br/>\n                                                He mentioned the profiles of directors in numerous listed companies on Euronext and above all suggested convincing Chairmen to broaden co-optations of board members professionally.</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.le_29_mars_2012objectifcasha_organise_un_peti\" style=\"text-align: left;\">\n<span style=\"color: red;\">On 29 March 2012</span><br/>\n<span style=\"color: blue;\"><a href=\"http://www.objectifcash.com/\">ObjectifCash</a> organised a Breakfast event \"Chairwomen, Chairmen, Shareholders, stop waiting to co-opt qualified directors!\"</span><br/>\n<span style=\"color: #808080;\">Guy Le Péchon was the moderator. Find the \"Finyear\" article from one of the participants in <a href=\"https://g-et-s.com/la-presse-parle-de-gouvernance-structures/\">the press kit</a></span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.le_16_decembre_2011participation_de_g_s_a_lat\" style=\"text-align: left;\">\n<span style=\"color: red;\">On 16 December 2011</span><br/>\n<span style=\"color: #808080;\">Participation of G &amp; S in the \"Board\" workshop at the Gender Diversity Forum, to read the workshop report click <a href=\"https://www.g-et-s.com/french/docdech/formix.pdf\">here</a></span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.le_7_decembre_2011madame_la_deputee_marie_jos\" style=\"text-align: left;\">\n<span style=\"color: red;\">On 7 December 2011</span><br/>\n<span style=\"color: blue;\">MP Marie-José Zimmermann organised a morning meeting in the Salon Lamartine of the National Assembly on the theme:</span><br/>\n<span style=\"color: black;\">« Chairmen and Chairwomen, where do we stand in the application of the Law of 27 January 2011 on the balanced representation of women and men on the boards of listed companies? »</span><br/>\n<span style=\"color: #808080;\">Guy Le Péchon presented the G &amp; S study on the situation as of 30 June 2011 regarding directors on Boards of Directors and Supervisory Boards of 500 French listed companies on Euronext Paris.<br/>\n                                                The summary page highlighting the key elements presented can be downloaded by clicking <a href=\"./../wp-content/uploads/2020/01/synth712.pdf\">here</a>.<br/>\n                                                Mr Jean-François Coppé, Ms Anne-Marie Rocco of the Challenges review and Ms Maryam SALEHI, Deputy Managing Director and Director of NRJ, then spoke in succession. An exchange with the audience followed. One of the conclusions of this morning event was that the Law was already today prompting reflection on the composition of Boards of Directors and Supervisory Boards, and would ultimately lead to better \"Corporate Governance\" of companies.<br/>\n                                                For any information send an email to <a href=\"mailto:info@g-et-s.com\">info@g-et-s.com</a></span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.le_10_octobre_2011a_lessec_viviane_de_beaufor\" style=\"text-align: left;\">\n<span style=\"color: red;\">On 10 October 2011</span><br/>\n<span style=\"color: blue;\">At ESSEC (Viviane De Beaufort) Launch meeting of the second session of the \"Women Be European Board Ready\" training.</span><br/>\n<span style=\"color: #808080;\">The theme of this meeting was the recruitment of directors in France and England. Guy Le Péchon, representing the Institute of Directors, summarised the situation in England. To receive the slides from his presentation, simply send an email with your contact details to <a href=\"mailto:info@g-et-s.com\">info@g-et-s.com</a></span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.le_9_juin_2011une_conference_etait_organisee_\" style=\"text-align: left;\">\n<span style=\"color: red;\">On 9 June 2011</span><br/>\n<span style=\"color: blue;\">a conference was organised by the <a href=\"http://www.fbn-france.fr/\">Business Family Network</a> association on the subject of the Law of 27 January 2011,</span><br/>\n<span style=\"color: #808080;\">Ms Caroline Ressot, Secretary General of the Gender Parity Observatory and Guy Le Péchon of G &amp; S were able to present the previous situation, the Law and the developments taking shape.</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.le_29_avril_2011une_conference_etait_organise\" style=\"text-align: left;\">\n<span style=\"color: red;\">On 29 April 2011</span><br/>\n<span style=\"color: blue;\">a conference was organised by NYSE Euronext on \"What kind of director for tomorrow?\"</span><br/>\n<span style=\"color: #808080;\">The dialogue initiated with Ms Maryse Aulagnon, Chairman and CEO, Groupe Affine, and director of Air France-KLM, Mr Alain Martel, Secretary General of the IFA, Ms Viviane Neiter, Director of Dolphin Intégration, of Prodware and non-voting member of Ginger Grontmij France, and Mr Guy Le Péchon, Managing Partner, G&amp;S, enabled the presentation to listed companies of the available means to meet the requirements of the gender parity law in boards.</span>\n</td>\n</tr>\n</tbody>\n</table>\n</div>\n<div class=\"mt-3\">\n<table class=\"table\">\n<tbody>\n<tr>\n<td data-i18n=\"page_bibliographie.notes_et_articles_publies_par_g_s\" style=\"color: #0000ff; font-weight: 900; text-align: center;\">Notes and articles published by G&amp; S</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.relations_presse_de_gouvernance_structures_fl\">\n<span style=\"color: red;\">Press relations of Gouvernance &amp; Structures (<a href=\"http://g-et-s.agence-presse.net/feed/\">RSS Feed</a>)</span><br/>\n<a href=\"https://g-et-s.com/exposes-articles-et-notes-publies-par-g-s/\">Click here</a>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.blogs_lies_a_la_gouvernancearcafi_notesfinanc\">\n<span style=\"color: red;\">Governance-related blogs</span><br/>\n<a href=\"http://www.arcafi-notes.blogspot.com/\">Arcafi-notes</a> <span style=\"color: #808080;\">Finance-Business-Economics</span>\n</td>\n</tr>\n</tbody>\n</table>\n</div>\n<div class=\"mt-3\">\n<table class=\"table\">\n<tbody>\n<tr>\n<td data-i18n=\"page_bibliographie.rapports\" style=\"color: #0000ff; font-weight: 900; text-align: center;\">Reports</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.lacces_des_femmes_aux_responsabilites_dans_le\">\n<a href=\"http://ondirectorship.com/ondirectorship/j3xb9xcqpivwnw6dktyde495k7ktr0\">\n<span style=\"color: blue;\">Women's access to positions of responsibility in companies</span>\n</a><br/>\n<span style=\"color: black;\">by Ms Marie-Jo Zimmermann, MP, Activity report</span><br/>\n<span style=\"color: #808080;\">for 2009, submitted pursuant to Article 6 septies of Ordinance No. 58-1100 of 17 November 1958 relating to the functioning of parliamentary assemblies on behalf of the delegation for women's rights and equal opportunities between women and men.</span><br/>\n<span style=\"color: #000000; font-weight: bold;\">A historical selection of reports identified by G &amp; S as interesting for corporate governance can be downloaded by <a href=\"./../wp-content/uploads/2020/01/rapports.doc\">clicking here</a></span><br/>\n<span style=\"color: #000000;\">For others, the websites of the <a href=\"http://www.ifa-asso.com/bonnes-pratiques/md/documents-utiles.php\">IFA</a>, <a href=\"http://www.apia.asso.fr/373_p_10216/publications.html\">APIA</a>, <a href=\"http://www.adae.asso.fr/accueil.php\">ADAE</a> can be consulted.</span>\n</td>\n</tr>\n</tbody>\n</table>\n</div>\n<div class=\"mt-3\">\n<table class=\"table\">\n<tbody>\n<tr>\n<td data-i18n=\"page_bibliographie.livres\" style=\"color: #0000ff; font-weight: 900; text-align: center;\">Books</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.administrateur_de_societe_pourquoi_pas_moi_me\">\n                                                Company Director: Why not me?<br/>\n                                                Method and advice for searching for and obtaining a directorship mandate<br/>\n<a href=\"http://www.editions-eyrolles.com/Livre/9782212564198/administrateur-de-societes-pourquoi-pas-moi\">(Yves Dumont, Eyrolles, 2016)</a>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.administrateur_e_au_femininguide_pour_devenir\">\n<b><span style=\"color: #0000ff;\">Women on Boards</span></b><br/>\n                                                Guide to becoming a female director<br/>\n                                                Collective work published by <a href=\"http://www.europeanpwn.net/paris\">European Professional Women Network</a> (Paris)<br/>\n                                                March 2011<br/>\n<span style=\"color: #ff0000;\">This guide can also be very useful for men wishing to become directors.</span>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.profession_administrateurscenes_de_vie_et_bon\">\n<b><span style=\"color: #0000ff;\">Profession: Director</span></b><br/>\n<span style=\"color: #0000cc;\">Scenes from corporate life and best practices in companies (Guy Ferré, Editions du Palio)</span>\n<p data-i18n=\"page_bibliographie.grace_a_une_serie_detudes_de_cas_se_lisant_fa\">Thanks to a series of case studies as easy to read as short detective novels, the author, drawing on his long practical experience as a director, presents the delicate and exciting side of the director's role. For each case, he comments and derives best governance practices.</p>\n</td>\n</tr>\n<tr>\n<td class=\"article-cell\" data-i18n=\"page_bibliographie.une_liste_dautres_livres_reperes_par_g_scomme\" style=\"font-weight: bold;\">\n<span style=\"color: #000000;\">A list of other books identified by G &amp; S<br/>\n                                                as interesting for corporate governance can be downloaded by <a href=\"./../wp-content/uploads/2020/01/livres.pdf\">clicking here</a></span>\n</td>\n</tr>\n</tbody>\n</table>\n</div>\n<div class=\"mt-3\">\n<table align=\"center\" bgcolor=\"#CCCCCC\" border=\"1\" cellpadding=\"0\" cellspacing=\"3\" width=\"97%\">\n<tbody>\n<tr>\n<td bgcolor=\"#CCCCCC\" data-i18n=\"page_bibliographie.lactualite_nannihile_pas_les_ecrits_passes_im_2\">\n<div align=\"center\">\n<table border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"99%\">\n<tbody>\n<tr>\n<td bgcolor=\"#CCCCCC\" data-i18n=\"page_bibliographie.lactualite_nannihile_pas_les_ecrits_passes_im_3\">\n<p align=\"center\" data-i18n=\"page_bibliographie.lactualite_nannihile_pas_les_ecrits_passes_im\"><span style=\"color: #ff0000;\"><b>Current events do not invalidate important past writings</b></span></p>\n<p align=\"center\" data-i18n=\"page_bibliographie.un_extrait_du_rapport_bouton_concernantles_cr\"><span style=\"color: #000099;\"><b>An extract from the Bouton Report concerning<br/>the criteria for qualifying<br/>a director as \"independent\"<br/>is recalled here:</b></span></p>\n<p align=\"left\" data-i18n=\"page_bibliographie.1_ni_mandataire_social_ni_salarie_actuel_ou_a\"><span style=\"font-size: small;\">\n                                                                        1- Neither corporate officer nor current (or past five years) employee.<br/>\n                                                                        2- Not a cross-director.<br/>\n                                                                        3- Not a significant client, supplier or banker (for business or financing purposes) or representing a significant share of the company's activity.<br/>\n                                                                        4- No close family ties with a corporate officer.<br/>\n                                                                        5- Neither partner nor current (or past five years) collaborator of the Statutory Auditors.<br/>\n                                                                        6- Not a director of the company for more than twelve years.<br/>\n                                                                        7- Shareholders:<br/>\n                                                                        – Below 10%: independent if not participating in control.<br/>\n                                                                        – Above 10%: review by the board, depending on the ownership structure and the existence of potential conflicts of interest.\n                                                                    </span></p>\n</td>\n</tr>\n</tbody>\n</table>\n</div>\n</td>\n</tr>\n</tbody>\n</table>\n</div>",
    "au_cours_de_la_reunion_du_27_novembre_2016de1_2": "<a href=\"http://www.100womeninhedgefunds.org/pages/event.php?e=1225&amp;inc=A&amp;yr=0&amp;loc=12&amp;kw=&amp;p=1\">\n<span style=\"color: red;\">During the meeting on 27 November 2016</span> of<br/>\n<span style=\"color: blue;\">100 Women in Hedge Funds on the theme</span><br/>\n<span style=\"color: black;\">Women on Boards in Paris and Abroad – Where are We?</span>\n</a><br/>\n<span style=\"color: #808080;\">Guy Le Péchon spoke as part of the panel discussion. He previewed the main results of G &amp; S studies on the 1,000 female directors of Boards of 400 companies listed on Euronext Paris tracked for 7 years by G &amp; S, <a href=\"./../wp-content/uploads/2020/01/wihf%20flyer.pdf\">see leaflet</a></span>",
    "au_cours_de_la_matinale_du_23_juin_2014tenue_": "<span style=\"color: red;\">During the matinale of 23 June 2014</span> tenue par the IFA<br/>\n<span style=\"color: blue;\">\"Premières leçons des General Meetings 2014\"</span><br/>\n<span style=\"color: #808080;\">animée par Caroline De La Marinière de Capital Com, the latter has cited the initial estimates de G &amp; S concernant les CAC 40 companies après lecture des annual reports and des convocations aux AGs 2014: the average ratio dépasse désorMays légèrement 30%. <a href=\"./../wp-content/uploads/2020/01/cb%20%25%202013%202014.pdf\">See Charts</a></span>",
    "auforum_de_la_mixitedu_21_decembre_2012guy_le": "<span style=\"color: red;\">Au <a href=\"http://www.forumdelamixite.com/\" style=\"color: red;\">Forum of the Gender diversity</a> of 21 December 2012</span><br/>\n<span style=\"color: blue;\">Guy Le Péchon was one of the speakers within the workshop Leyders Associates</span><br/>\n<span style=\"color: #808080;\">\"Se positionner pour être administrable. Improving board gender diversity.\"<br/>\n                                                He mentioned the profiles of directors within nombreuses listed companies on Euronext and suggéré surtout penser à convaincre les Chairmen d'élargir de façon professional les cooptations des member of their Conseils.</span>",
    "le_29_mars_2012objectifcasha_organise_un_peti": "<span style=\"color: red;\">On 29 March 2012</span><br/>\n<span style=\"color: blue;\"><a href=\"http://www.objectifcash.com/\">ObjectifCash</a> organised a Breakfast event \"Chairwomen, Chairmen, Shareholders, stop waiting to co-opt qualified directors!\"</span><br/>\n<span style=\"color: #808080;\">Guy Le Péchon was the moderator. Find the \"Finyear\" article from one of the participants in <a href=\"https://g-et-s.com/la-presse-parle-de-gouvernance-structures/\">the press kit</a></span>",
    "le_16_decembre_2011participation_de_g_s_a_lat": "<span style=\"color: red;\">16 December 2011</span><br/>\n<span style=\"color: #808080;\">Participation of G &amp; S in the \"Board\" workshop at the Gender Diversity Forum, to read the workshop report click <a href=\"https://www.g-et-s.com/french/docdech/formix.pdf\">here</a></span>",
    "le_7_decembre_2011madame_la_deputee_marie_jos": "<span style=\"color: red;\">On 7 December 2011</span><br/>\n<span style=\"color: blue;\">MP Marie-José Zimmermann organised a morning meeting in the Salon Lamartine of the National Assembly on the theme:</span><br/>\n<span style=\"color: black;\">« Chairmen and Chairwomen, where do we stand in the application of the Law of 27 January 2011 on the balanced representation of women and men on the boards of listed companies? »</span><br/>\n<span style=\"color: #808080;\">Guy Le Péchon presented the G &amp; S study on the situation as of 30 June 2011 regarding directors on Boards of Directors and Supervisory Boards of 500 French listed companies on Euronext Paris.<br/>\n                                                The summary page highlighting the key elements presented can be downloaded by clicking <a href=\"./../wp-content/uploads/2020/01/synth712.pdf\">here</a>.<br/>\n                                                Mr Jean-François Coppé, Ms Anne-Marie Rocco of the Challenges review and Ms Maryam SALEHI, Deputy Managing Director and Director of NRJ, then spoke in succession. An exchange with the audience followed. One of the conclusions of this morning event was that the Law was already today prompting reflection on the composition of Boards of Directors and Supervisory Boards, and would ultimately lead to better \"Corporate Governance\" of companies.<br/>\n                                                For any information send an email to <a href=\"mailto:info@g-et-s.com\">info@g-et-s.com</a></span>",
    "le_10_octobre_2011a_lessec_viviane_de_beaufor": "<span style=\"color: red;\">On 10 October 2011</span><br/>\n<span style=\"color: blue;\">A l'Essec (Viviane De Beaufort) Réunion of thencement of the seconof his/hersion by training \"Women Be European Board ready\".</span><br/>\n<span style=\"color: #808080;\">Le thème of this réunion has been the recruitment des directors in France and in England. Guy Le Péchon, au titre of the Institute of Directors, a résumé the situation in England. Pour recevoir the slides of his presentation, simply send an eMayl with your contact details to <a href=\"mailto:info@g-et-s.com\">info@g-et-s.com</a></span>",
    "le_9_juin_2011une_conference_etait_organisee_": "<span style=\"color: red;\">On 9 June 2011</span><br/>\n<span style=\"color: blue;\">une conference était organisée par the association <a href=\"http://www.fbn-france.fr/\">Business Family Network</a> on the topic of the Law of 27 January 2011,</span><br/>\n<span style=\"color: #808080;\">Madame Caroline Ressot, Secretary General of the Gender Parity Observatory and Guy Le Péchon G &amp; S were able to présenter the situation passée, la Loi and the developments who dessinent.</span>",
    "le_29_avril_2011une_conference_etait_organise": "<span style=\"color: red;\">On 29 April 2011</span><br/>\n<span style=\"color: blue;\">a conference was organised by NYSE Euronext on \"What kind of director for tomorrow?\"</span><br/>\n<span style=\"color: #808080;\">The dialogue initiated with Ms Maryse Aulagnon, Chairman and CEO, Groupe Affine, and director of Air France-KLM, Mr Alain Martel, Secretary General of the IFA, Ms Viviane Neiter, Director of Dolphin Intégration, of Prodware and non-voting member of Ginger Grontmij France, and Mr Guy Le Péchon, Managing Partner, G&amp;S, enabled the presentation to listed companies of the available means to meet the requirements of the gender parity law in boards.</span>",
    "notes_et_articles_publies_par_g_s": "Notes and articles publiés par G&amp; S",
    "relations_presse_de_gouvernance_structures_fl": "<span style=\"color: red;\">Relations presse de Gouvernance &amp; Structures (<a href=\"http://g-et-s.agence-presse.net/feed/\">FluxRSS</a>)</span><br/>\n<a href=\"https://g-et-s.com/exposes-articles-et-notes-publies-par-g-s/\">Click here</a>",
    "blogs_lies_a_la_gouvernancearcafi_notesfinanc": "<span style=\"color: red;\">Governance-related blogs</span><br/>\n<a href=\"http://www.arcafi-notes.blogspot.com/\">Arcafi-notes</a> <span style=\"color: #808080;\">Finance-Business-Economics</span>",
    "rapports": "Reports",
    "lacces_des_femmes_aux_responsabilites_dans_le": "<a href=\"http://ondirectorship.com/ondirectorship/j3xb9xcqpivwnw6dktyde495k7ktr0\">\n<span style=\"color: blue;\">Women's access to positions of responsibility in companies</span>\n</a><br/>\n<span style=\"color: black;\">by Ms Marie-Jo Zimmermann, MP, Activity report</span><br/>\n<span style=\"color: #808080;\">for 2009, submitted pursuant to Article 6 septies of Ordinance No. 58-1100 of 17 November 1958 relating to the functioning of parliamentary assemblies on behalf of the delegation for women's rights and equal opportunities between women and men.</span><br/>\n<span style=\"color: #000000; font-weight: bold;\">A historical selection of reports identified by G &amp; S as interesting for corporate governance can be downloaded by <a href=\"./../wp-content/uploads/2020/01/rapports.doc\">clicking here</a></span><br/>\n<span style=\"color: #000000;\">For others, the websites of the <a href=\"http://www.ifa-asso.com/bonnes-pratiques/md/documents-utiles.php\">IFA</a>, <a href=\"http://www.apia.asso.fr/373_p_10216/publications.html\">APIA</a>, <a href=\"http://www.adae.asso.fr/accueil.php\">ADAE</a> can be consulted.</span>",
    "livres": "Books",
    "administrateur_de_societe_pourquoi_pas_moi_me": "Company Director: Pourquoi pas moi ?<br/>\n                                                Méthode and conseils pour rechercher and obtenir a mandatee d'administrateur<br/>\n<a href=\"http://www.editions-eyrolles.com/Livre/9782212564198/administrateur-de-societes-pourquoi-pas-moi\">(Yves Dumont, Eyrolles, 2016)</a>",
    "administrateur_e_au_femininguide_pour_devenir": "<b><span style=\"color: #0000ff;\">Women on Boards</span></b><br/>\n                                                Guide pour devenir administrative<br/>\n                                                Collective Work published par <a href=\"http://www.europeanpwn.net/paris\">European Professional Women Network</a> (Paris)<br/>\n                                                March 2011<br/>\n<span style=\"color: #ff0000;\">Ce guide peut also être très utile for the hommes voulant devenir director</span>",
    "profession_administrateurscenes_de_vie_et_bon": "<b><span style=\"color: #0000ff;\">Profession: Director</span></b><br/>\n<span style=\"color: #0000cc;\">Scenes from corporate life and best practices in companies (Guy Ferré, Editions du Palio)</span>\n<p data-i18n=\"page_bibliographie.grace_a_une_serie_detudes_de_cas_se_lisant_fa\">Thanks to a series of case studies as easy to read as short detective novels, the author, drawing on his long practical experience as a director, presents the delicate and exciting side of the director's role. For each case, he comments and derives best governance practices.</p>",
    "une_liste_dautres_livres_reperes_par_g_scomme": "<span style=\"color: #000000;\">A list of other books identified by G &amp; S<br/>                                                 as interesting for corporate governance can be downloaded here.</span>",
    "lactualite_nannihile_pas_les_ecrits_passes_im_2": "<div align=\"center\">\n<table border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"99%\">\n<tbody>\n<tr>\n<td bgcolor=\"#CCCCCC\" data-i18n=\"page_bibliographie.lactualite_nannihile_pas_les_ecrits_passes_im_3\">\n<p align=\"center\" data-i18n=\"page_bibliographie.lactualite_nannihile_pas_les_ecrits_passes_im\"><span style=\"color: #ff0000;\"><b>Current events do not invalidate important past writings</b></span></p>\n<p align=\"center\" data-i18n=\"page_bibliographie.un_extrait_du_rapport_bouton_concernantles_cr\"><span style=\"color: #000099;\"><b>An extract from the Bouton Report concerning<br/>the criteria for qualifying<br/>a director as \"independent\"<br/>is recalled here:</b></span></p>\n<p align=\"left\" data-i18n=\"page_bibliographie.1_ni_mandataire_social_ni_salarie_actuel_ou_a\"><span style=\"font-size: small;\">\n                                                                        1- Neither corporate officer nor current (or past five years) employee.<br/>\n                                                                        2- Not a cross-director.<br/>\n                                                                        3- Not a significant client, supplier or banker (for business or financing purposes) or representing a significant share of the company's activity.<br/>\n                                                                        4- No close family ties with a corporate officer.<br/>\n                                                                        5- Neither partner nor current (or past five years) collaborator of the Statutory Auditors.<br/>\n                                                                        6- Not a director of the company for more than twelve years.<br/>\n                                                                        7- Shareholders:<br/>\n                                                                        – Below 10%: independent if not participating in control.<br/>\n                                                                        – Above 10%: review by the board, depending on the ownership structure and the existence of potential conflicts of interest.\n                                                                    </span></p>\n</td>\n</tr>\n</tbody>\n</table>\n</div>",
    "lactualite_nannihile_pas_les_ecrits_passes_im_3": "<p align=\"center\" data-i18n=\"page_bibliographie.lactualite_nannihile_pas_les_ecrits_passes_im\"><span style=\"color: #ff0000;\"><b>Current events do not invalidate important past writings</b></span></p>\n<p align=\"center\" data-i18n=\"page_bibliographie.un_extrait_du_rapport_bouton_concernantles_cr\"><span style=\"color: #000099;\"><b>An extract from the Bouton Report concerning<br/>the criteria for qualifying<br/>a director as \"independent\"<br/>is recalled here:</b></span></p>\n<p align=\"left\" data-i18n=\"page_bibliographie.1_ni_mandataire_social_ni_salarie_actuel_ou_a\"><span style=\"font-size: small;\">\n                                                                        1- Neither corporate officer nor current (or past five years) employee.<br/>\n                                                                        2- Not a cross-director.<br/>\n                                                                        3- Not a significant client, supplier or banker (for business or financing purposes) or representing a significant share of the company's activity.<br/>\n                                                                        4- No close family ties with a corporate officer.<br/>\n                                                                        5- Neither partner nor current (or past five years) collaborator of the Statutory Auditors.<br/>\n                                                                        6- Not a director of the company for more than twelve years.<br/>\n                                                                        7- Shareholders:<br/>\n                                                                        – Below 10%: independent if not participating in control.<br/>\n                                                                        – Above 10%: review by the board, depending on the ownership structure and the existence of potential conflicts of interest.\n                                                                    </span></p>",
    "salon_du_livre_des_polytechniciens": "Polytechnicians’ Book Fair"
  },
  "page_boards_et_comex": {
    "cette_page_est_en_cours_de_construction_le_co": "This page is under construction. Content will be available soon.",
    "boards_et_comex": "Boards and Comex"
  },
  "page_candidats_mandataires_sociaux": {
    "candidat_e_s_mandatairesadministratrices_admi": "CANDIDATE(S) OFFICERS<br/> FEMALE AND MALE DIRECTORS",
    "accueil_candidats_mandatairesadministratrices": "<span style=\"color: #00ccff;\"><a href=\"../index.html\" style=\"color: #00ccff;\">Home</a> &gt;&gt; <a href=\"../index.htmlelementor-380/\" style=\"color: #00ccff;\">CANDIDATS MANDATAIRES</a> ADMINISTRATRICES ADMINISTRATEURS</span>",
    "aujourdhui_des_conseils_dadministration_peuve": "Today, Boards of Directors may need to recruit women and men qualified to co-opt as directors.",
    "gouvernance_structures_connait_deja_un_certai": "Gouvernance &amp; Structures already knows a number of candidates. Their anonymous mini CVs are listed below.",
    "pour_connaitre_leur_nom_et_leurs_coordonnees_": "To find out their names and contact details and to reach them, write to <a href=\"mailto:contact@g-et-s.com\">contact@g-et-s.com</a> specifying the reference indicated.",
    "le_candidat_x_ensta_actuellement_expert_indep": "<strong>The candidate, X-Ensta, currently independent expert in mergers &amp; acquisitions, has 35 years of experience in balance sheet operations, including twenty years in energy and raw materials.</strong>",
    "apres_un_debut_de_carriere_dans_le_nucleaire_": "After starting his career in the nuclear sector, he was in charge of distressed businesses at the Ministry of Industry and at the Treasury. He was then responsible for 6 years for a significant multinational oil holding, then for 4 years was Deputy CEO of a major portfolio management structure, before joining one of the world leaders in nuclear energy to carry out restructuring of investments and activities, balance sheet operations, and strategic reflections.",
    "il_a_ete_administrateur_dun_grand_groupe_mini": "He has served as director of a major mining group and of a holding company, and until recently Chairman of the Supervisory Board of a company in which the BPI holds a stake.",
    "il_est_depuis_plusieurs_annees_expert_industr": "He has for several years been an industry-energy expert at a mergers and acquisitions firm.",
    "ref_920": "Ref: 920",
    "administrateur_independant_membre_du_comite_d": "<strong> Independent director, member of the Audit Committee, expert in risk management, digital transformation and cybersecurity</strong>",
    "aujourdhui_senior_manager_dans_un_cabinet_de_": "Today, Senior Manager at a consulting firm dealing with risk management, fraud and corruption. Looking back, in a regulated context (Solvency 2), he served as Director and Chairman of the Audit Committee of a Prévoyance company whose sale he led. In an industrial CAC40 company, he led a shared service center, was internal auditor and project manager for a merger and acquisition operation. Within a major American company, and previously, in a major French telecom group, he served as internal auditor.",
    "a_loccasion_de_ses_nombreuses_missions_il_a_a": "Through his numerous assignments, he has acquired:",
    "une_profonde_expertise_en_systeme_dinformatio": "– Deep expertise in information systems and digital transformation,",
    "une_experience_internationale_tres_etendue_un": "– Extensive international experience: around thirty countries, across 5 continents, with a predominance for Africa where he also worked 2 years as a cooperation volunteer (Kenya) for the Ministry of Foreign Affairs.",
    "une_connaissance_de_secteurs_dactivite_tres_v": "– Knowledge of a wide variety of business sectors, in particular: industry, construction, telecommunications, environment, energy, defence, research, insurance, asset management.",
    "diplome_de_lessec_et_de_telecom_paris_anglais": "Graduate of ESSEC and Télécom Paris, fluent English, Member of the IFA Audit Committee. Ref 732",
    "non_executive_director_in_european_companies_": "<b><span style=\"font-size: small;\"> </span></b><strong>Non Executive Director in European companies and family offices with a focus and presence in Asia.</strong>",
    "this_male_candidate_has_a_successful_track_re": "This male candidate has a successful track record of over twenty-two years advising Fortune 500 companies on strategy, mergers and acquisitions (M&amp;A), corporate finance and business development in ASEAN and India. Knowledge and experience of profit and loss (P&amp;L) and Balance Sheet responsibilities, starting and growing a highly profitable investment banking business and in completing a complex restructuring for a large family owned business. Boards Director experience in listed and unlisted companies as a Non Executive and Executive Director. 52 year old Indian national, INSEAD MBA, Physics background and International outlook having lived in India, Singapore, France, and the U.K.. Presently based in Singapore. Languages: English, Hindi, Gujarati, French basic",
    "ref_881": "<span style=\"font-size: small;\">Ref: 881</span>",
    "industries_a_destination_du_btp_securite_fran": "<b><span style=\"font-size: small;\"> Industries serving the construction/security sector (France, Netherlands, Egypt)</span></b>",
    "le_candidat_ingenieur_et_science_po_a_dans_le": "<span style=\"font-size: small;\">The candidate, engineer and Science-Po, has in the above-mentioned countries and sectors experience as Chairman and director</span>",
    "ref_871": "<span style=\"font-size: small;\">Ref: 871</span>",
    "candidat_a_un_poste_dadministrateur_independa": "<strong> Candidate for an independent director position. Long and broad experience as General Manager of an industrial family SME. European and Asian subsidiaries. Director of companies in the service sector</strong>",
    "ingenieur_43_ans_de_carriere_industrielle_don": "Engineer, 43 years of industrial career, including 13 in production, then 30 as General Manager and Chairman of an industrial family SME (turnover €40M), mechanical and metallurgy sector.",
    "creation_et_presidence_de_filiales_en_europe_": "Creation and Chairmanship of subsidiaries in Europe, China and India. Development of international alliances and networks. Strong commercial and managerial experience in Europe, the Middle East and Asia.",
    "23_ans_president_de_conseil_de_surveillance_e": "23 years Chairman of Supervisory Board as independent director of two service sector companies: publishing &amp; multimedia (€2M), catering &amp; seminars (€5M).",
    "experience_en_evaluation_acquisition_et_integ": "Experience in company valuation, acquisition and integration, and issues of governance, succession, and ownership transfers.",
    "connaissance_de_lenseignement_superieur_10_an": "Knowledge of Higher Education: 10 years as Chairman of an Advisory Board. English and German.",
    "ref_544": "<span style=\"font-size: small;\">Ref: 544</span>",
    "administrateur_independant_grande_experience_": "<strong>Independent director, extensive audit experience</strong>",
    "le_candidat_ingenieur_commercial_dhec_liege_a": "The candidate, HEC Liège commercial engineer, worked for 25 years as Statutory Auditor and Chartered Accountant in Belgium and in the Grand Duchy of Luxembourg.",
    "certifie_comme_administrateur_de_societes_ifa": "Certified as Company Director (IFA/SC.PO) and in risk management strategy CEFAR/AMRAE. Member of the French and Luxembourg Institutes of Directors.",
    "fort_de_son_experience_internationale_au_sein": "Drawing on his international experience within Anglo-Saxon audit firms for commercial, industrial and financial companies (of intermediate size), he became an entrepreneur by creating and developing his own chartered accountancy, company domiciliation and audit firms (affiliated with an international network, Kreston).",
    "son_parcours_professionnel_lui_a_fait_connait": "His professional career has exposed him to very diverse sectors including construction and wealth management, structures of various sizes, with challenges and business models at various stages of development. He has participated in numerous restructuring assignments both in France and in Luxembourg.",
    "de_par_sa_nationalite_italienne_et_son_parcou": "By virtue of his Italian nationality and his European career, he has an in-depth knowledge of French, Italian and English cultures and has mastered the associated languages.",
    "aujourdhui_il_est_administrateur_de_societes_": "Today, he is a director of Luxembourg companies and an internal auditor within regulated Luxembourg financial structures.",
    "ref_532": "<span style=\"font-size: small;\">Ref: 532</span>",
    "candidat_a_un_poste_dadministrateur_independa_2": "<b>Candidate for an independent director position,</b> long experience as a CEO of SMEs/Mid-caps including internationally and the Far East",
    "25_ans_de_direction_generale_de_pme_eti_indus": "– 25 years of Senior Management of industrial SME/ETI of 10/50/120 million € in revenue, multi-site and multi-country – Industrial sectors: composite materials, aerospace coatings, printing, plastic packaging, wood processing, equipment parts for industry and the oil and gas sector. – Types of shareholdings: listed French and foreign groups, family groups, companies under LBO. – Experience in development, management, restructuring, insolvency proceedings, LBO takeovers and external growth. <span style=\"font-size: smaller;\">– Worked in Europe, India, Iran, China, South Africa. Knowledge of major export markets where industrial subsidiaries were established.</span> – Member IFA, APIA – UTC Engineer, Master of Sciences from Cranfield Institute of Technology, MBA from HEC Group – Fluent English",
    "ref_678": "<span style=\"font-size: small;\">Ref: 678</span>",
    "candidat_a_un_poste_dadministrateur_independa_3": "<b>Candidate for an independent director position (Audit or Remuneration Committee). Extensive experience in Finance and Operational Management across several sectors.</b>",
    "dote_dune_triple_formation_mba_americain_inge": "With a triple background (American MBA, Engineer, Economics), the candidate for an independent director position, after serving as junior consultant in two renowned firms, pursued his career in French subsidiaries of two major international groups, one American then the other German. For the latter, he also worked within the parent company in Germany. He has rich experience of more than 20 years in extensive Finance Departments (finance, accounting, taxation, legal and IT) in international environments. In this capacity, he has participated, both in France and abroad, in numerous merger and acquisition operations and has served on more than ten supervisory or administrative boards of subsidiaries of the mentioned groups. The originality of his career lies in the fact that he has also been an operational CEO, notably in several successful turnaround operations of companies belonging to different sectors. The economic sectors where he could apply his experience notably include chemicals, pharmaceuticals, agri-food, flavours and fragrances as well as real estate. Trilingual French/English/German",
    "ref_503": "<span style=\"font-size: small;\">Ref: 503</span>",
    "industrie_pharmaceutique": "<span style=\"font-size: small;\"><b> Pharmaceutical Industry</b></span>",
    "le_candidat_docteur_en_pharmacie_aihp_a_une_e": "<span style=\"font-size: small;\">The candidate, Doctor of Pharmacy, AIHP, has experience in hospital research and R&amp;D Management positions in pharmaceutical companies including one of large scale with subsidiaries in the USA.</span>",
    "createur_dune_start_up_de_conseil_en_strategi": "<span style=\"font-size: small;\">Founder of a start-up for pharmaceutical R&amp;D strategy consulting and co-founder of another in the design of new antiviral drugs.</span>",
    "ref_561": "<span style=\"font-size: small;\">Ref: 561</span>",
    "le_candidat_de_formation_x_et_supaero_ensae_c": "<span style=\"color: #000000; font-size: small;\">The candidate, trained at the École Polytechnique and Sup'Aéro (ENSAé), with additional Strategic Management training (IFG-ICG), has held senior positions within the Defence Procurement Directorate of the Ministry of Defence. With extensive experience in defence electronics, he is one of the few senior officials mastering the French and European defence sector in the field of high technologies. Holder of the company director certificate (IFA)</span>.",
    "ref_462": "<span style=\"font-size: small;\">Ref: 462</span>",
    "equipements_et_appareillages_industriels_ener": "<b><span style=\"font-size: small;\"> </span></b><span style=\"font-size: small;\"><b>Equipements and appareillages industriels (Energie, Transport, Haute Technologie)</b></span>",
    "le_candidat_ingenieur_mba_bilingue_francais_a": "<span style=\"font-size: small;\">The candidate, Engineer + MBA, bilingual French/English, has highly advanced experience: – of Asia/Pacific with 7 years of residence in Japan and the chairmanship of companies both in Japan and in China, Korea, Taiwan, Thailand, India, Australia. – Of Europe and the Commonwealth with 6 years of residence in London where director positions in these regions were added to those already held in Asia.</span>",
    "ref_261": "<span style=\"font-size: small;\">Ref: 261</span>",
    "aviation_aeronautique_spatial_defense_securit": "<span style=\"font-size: small;\"><b> </b></span><span style=\"font-size: small;\">.</span><b><span style=\"font-size: small;\">Aviation, Aeronautics, Space, Defence &amp; Security.</span></b>",
    "le_candidat_de_formation_economique_commerce_": "<span style=\"font-size: small;\">The candidate, trained in Economics &amp; International Trade (London and Paris) complemented by Management (INSEAD) and Defence (IHEDN), has extensive international experience through the World Bank (Americas and Asia) then the French, European and American Aerospace/Space/Defence/Security industry for which he has held very senior operational and \"Corporate\" positions.</span><span style=\"font-size: small;\"> He splits his residence between Washington and Paris and is particularly active in the indicated sectors across Europe, the Americas and the Middle East.</span>",
    "ref_513": "<span style=\"font-size: small;\">Ref: 513 </span>",
    "administrateur_de_filiales_anglaises_de_socie": "<b><span style=\"font-size: small;\"> Director of English subsidiaries of French companies and vice versa</span></b>",
    "le_candidat_a_30_ans_dexperience_dans_quelque": "<span style=\"color: #000000; font-size: small;\">The candidate has 30 years of experience in some of the largest companies in the United Kingdom, Germany, the United States and the Netherlands. A financier by training, accustomed to headquarters issues as well as operational ones, his expertise covers companies as varied as marine, chemicals, sustainable development and real estate. Of English origin, but long established in France, in Paris and in the Rhine region, he would be happy to build bridges between French subsidiaries and their British/German parent companies or vice versa.</span>",
    "ref_203": "<span style=\"color: #000000; font-size: small;\">Ref: 203</span>",
    "le_candidat_de_formation_x_et_insead_a_une_la": "<span style=\"font-size: small;\"><b>The candidate, trained at the École Polytechnique and INSEAD, has extensive experience in infrastructure, planning, construction, environment, sustainable development, engineering, public services, concessions and public-private partnerships.</b> In these sectors, he has held operational management positions including on major international construction sites (Algeria, China). He has served as director within highly diverse Boards of Directors and Supervisory Boards, and was CEO of a subsidiary of one of the leaders in engineering and consulting. He has recently created his own consulting firm in order to make his experience available to companies in these sectors, notably through independent director mandates.</span>",
    "ref_508": "<span style=\"color: #000000; font-size: small;\">Ref: 508</span>",
    "edition_de_logiciel": "<b><span style=\"font-size: small;\"> Software Publishing</span></b>",
    "le_candidat_expert_comptable_a_une_large_expe": "<span style=\"font-size: small;\">The candidate, Chartered Accountant, has extensive experience in financial management, general secretariat and as director of </span><span style=\"font-size: small;\">IT service companies and software publishers</span>",
    "ref_909": "<span style=\"font-size: small;\">Ref: 909</span>",
    "genie_medical_france_et_usa": "<b> <span style=\"font-family: Times New Roman, Times, serif; font-size: small;\">Génie Médical France and USA</span></b>",
    "apres_avoir_ete_aux_usa_manager_de_projets_ma": "<span style=\"font-size: small;\">After serving in the USA as marketing project manager for a subsidiary of a major US pharmaceutical company, then for 4 years as International Marketing Director of a US company in Medical Engineering, he founded in France a start-up for medical assessments. He was CEO and led a successful development. The company operated in Europe and the USA, listed on Euronext. Extensive experience in high-level contacts and technology transfers (USA and Europe) with scientific and financial circles. Education: Master in Management from ISG</span>",
    "ref_104": "<span style=\"font-size: small;\">Ref: 104</span>",
    "pharmacie_humaine_otc_et_sante_animale": "<b><span style=\"font-family: Times New Roman, Times, serif; font-size: small;\">Pharmacie humaine (OTC) and Santé animale</span></b>",
    "le_candidat_veterinaire_avec_une_formation_de": "<span style=\"font-size: small;\">The candidate, a veterinarian with management training acquired at ESSEC, is an experienced executive in large groups, particularly American ones, both as operational (MD or Business Unit) and functional (Marketing) within subsidiaries marketing products for animal or human health (OTC). Experience as director of the Veterinary Medicine Industry Association. Knowledge of Russian.</span>",
    "ref_115": "<span style=\"font-size: small;\">Ref: 115</span>",
    "equipements_pour_l_energie_le_petrole_et_le_g": "<span style=\"font-size: small;\"><b>Equipment for energy, oil and gas</b></span>",
    "le_candidat_ingenieur_et_mba_hec_isa_a_une_ex": "<span style=\"font-size: small;\">The candidate, engineer and MBA HEC-ISA, has experience as director in several companies in the above-mentioned sector.</span>",
    "experience_tres_etendue_produits_alimentaires": "<b><span style=\"font-size: small;\">Very extensive experience (Fast-moving consumer food products) France and International for more than 15 years</span></b>",
    "le_candidat_a_des_postes_dadministrateur_est_": "<span style=\"font-size: small;\"> The candidate for director positions is a graduate of a Business School. He served as CEO, Director and Operational Head of subsidiaries in several European countries and in the USA. He has carried out complex restructuring operations. In the context of his responsibilities, he has raised funds from major venture capital investors and led assignments in mergers &amp; acquisitions consulting (multinationals and start-ups).</span>",
    "ref_845": "<span style=\"font-size: small;\">Ref: 845</span>",
    "experience_internationale_tres_etendue_high_t": "<b> </b><span style=\"font-size: small;\"><b><span style=\"font-size: small;\">Very extensive international experience (High Tech and IT)</span></b> </span>",
    "le_candidat_a_passe_plus_de_30_ans_dans_des_e": "<span style=\"font-size: small;\">The candidate has spent over 30 years in international environments including over 10 years of living in the USA. </span><span style=\"font-size: small;\">He has been CEO, Director or operational head of subsidiaries of large IT companies (generalist, service providers, enterprise software) and Vice Chairman of a start-up (biometrics). Responsibilities taken in the field of art trading and real estate have enriched his vision of business. Today, as an international consultant, he proposes, by becoming an independent director, to make his competence available to companies. </span><span style=\"font-size: small;\">Education: Arts et Métiers Engineer and INSEAD</span>",
    "presse_et_medias_developpement_international": "<b><span style=\"font-size: small;\"> Presse and Médias Développement International</span></b>",
    "le_candidat_aujourdhui_consultant_internation": "<span style=\"font-size: small;\">The candidate, today an international consultant, started as Director of the French Chamber of Commerce in a Nordic country, before representing French textile and clothing industries in international bodies. Then, within a major French press/media group, he was Subsidiary Director in Portugal, International Director notably in charge of joint venture arrangements, Managing Director of a subsidiary in France, Deputy Director with director positions. Potential corporate officer of press/media companies with international development (speaks several languages: Swedish, Portuguese, English and German). Education: Law, Oriental Languages (Russian).</span>",
    "ref_101": "<span style=\"font-size: small;\">Ref: 101 </span>",
    "questions_energetiques_et_gestion_des_risques": "<b><span style=\"font-size: small;\"> Energy issues and associated risk management</span></b>",
    "le_candidat_a_une_longue_experience_des_affai": "<span style=\"font-size: small;\">The candidate has long experience in energy matters (specialised civil engineering and heavy equipment/turbomachines...) and associated risk management. Over recent years, he has assimilated the particular status, inherent uncertainties, and working methods of senior executives and directors of companies and their increasing involvement in energy management and risk.</span>",
    "ref_402": "<span style=\"font-size: small;\">Ref: 402</span>",
    "candidate_administratrice_independante_grande": "<span style=\"font-family: georgia, palatino, serif;\"><b>Female candidate for independent director: Extensive international experience</b></span>",
    "la_candidate_ecole_des_mines_et_biotechnologi": "<span style=\"font-family: georgia, palatino, serif;\">The candidate (École des Mines and Biotechnology at MIT) has held 3 successive mandates on the Supervisory Board of an international family ETI: organic and external growth, challenges linked to rapid growth (manufacturing, supply chain, HR). More than 40 years outside France: USA + various European countries, in Germany since 2000. Strategy consulting at Bain, operational director at Pasteur-Mérieux. For two years, mentoring start-ups with the MassChallenge accelerator.</span>",
    "candidate_administratrice_independante_hotell": "<span style=\"font-size: small;\"><b>Candidate independent director: Hospitality, Catering, Tourism; France and Europe</b> Multidisciplinary experience acquired within an international hotel group listed on the CAC 40. Over 30 years, including 12 years in public catering, the candidate has successively held executive positions in varied fields: management control, products, operations, marketing, internal audit, production, publishing and communication of international sales offices, and finally regarding the effectiveness of marketing &amp; distribution costs.</span>",
    "aujourdhui_elle_est_consultante_independante_": "<span style=\"font-size: small;\">Today, she is an independent consultant in these fields. Very good knowledge of international matters. Education: Master's in Economics (Paris 2), DEA Monetary Theories and Policies (Paris 2), Executive Doctorate in Business Administration (Paris Dauphine, 2009). Member of the IFA and Secretary General of the European Association of Neuroeconomics.</span>",
    "ref_303": "<span style=\"font-size: small;\">Ref: 303</span>",
    "candidate_au_poste_dadministratrice_independa": "<span style=\"font-size: small;\"><b> </b></span><span style=\"font-weight: bold;\">Candidate for independent director position.</span>",
    "docteur_en_economie_la_candidate_beneficie_du": "Doctor of Economics, the candidate has more than 30 years of professional experience. Her professional competences cover the banking/finance sector, organisational and strategy consulting, new technologies and digital transformation.",
    "membre_des_comites_de_direction_elle_a_assure": "Member of executive committees, she has successfully managed operational responsibilities (profit centres, development) within one of the world's largest banks, a leading consulting firm (big four) and a listed information systems specialist company (CAC 40). Given the projects she has carried out and her various functions, she is thoroughly familiar with the Europe zone (UK, Benelux, Hungary, Spain, Italy), the United States, India and Morocco.",
    "membre_du_cercle_des_administrateurs_de_lasso": "Member of the Circle of Directors, of the ATOS Alumni association, she also leads voluntary activities for V.E.C.V (Votre École Chez Vous), an association recognised as being of public utility and under contract with the national education authority.",
    "ref_324": "Ref: 324",
    "candidate_a_un_poste_dadministratrice_indepen": "<span style=\"font-size: small;\"><b> Candidate for an independent director position, with good knowledge of construction, business services, healthcare, investment funds and communications.</b></span>",
    "apres_avoir_mene_des_travaux_daudit_chez_erns": "<span style=\"font-size: small;\">After conducting audit work at Ernst &amp; Young, the candidate, over the following 13 years, successively gained experience in managing a business unit, directing an industrial branch, and managing a company. She brings extensive knowledge of governance, compliance, and financial oversight.</span>",
    "ensuite_apres_avoir_ete_secretaire_general_du": "<span style=\"font-size: small;\">Then, after serving as Secretary General of a major Law Firm, she created her own consulting firm, putting her management and financial skills at the service of the strategy, governance and organisation of her clients.</span>",
    "la_candidate_membre_de_lifa_est_diplomee_de_l": "<span style=\"font-size: small;\">The candidate, a member of the IFA, holds a degree from IEP Paris, Eco-fi, a DESS in banking-insurance and a management master's from Dauphine.</span>",
    "ref_825": "<span style=\"font-size: small;\">Ref: 825 </span>",
    "woman_european_company_board_ready": "<strong>Woman European Company Board ready </strong>",
    "mba_insead_certificate_and_diploma_in_company": "MBA INSEAD, Certificate and Diploma in Company Direction from Institute of Directors (IOD London)",
    "en_france_creatrice_de_son_propre_cabinet_de_": "<strong>In France</strong>, founder of her own IT/Digital market research and studies firm, developed to 150 people across Europe then sold to a major consulting group; then CEO of an IT research firm. <strong>Then in Europe</strong>, responsible for the development of a major HR consulting firm and then another in IT. <strong>Then, a long career in the USA</strong> as Executive Director in various positions for the development of a major international management consulting firm.",
    "de_retour_en_europe_membre_du_comite_executif": "<strong>Back in Europe</strong>, member of the European Executive Committee of a renowned consulting firm specialising in leadership and executive search",
    "cette_large_experience_internationale_vecue_d": "This extensive international experience gained in 6 countries has enabled her to know many B-to-B sectors, including digital and consumer goods. Her \"Business\" network (INSEAD, IOD, American Chamber of Commerce Zurich) can be put at the service of a Board. To note: Member for 5 years of the Board of CAWC, Connections for Abused Women and their Children in Chicago, Chairwoman of the Communications Commission",
    "ref_304": "Ref: 304",
    "candidate_a_un_poste_dadministratrice_indepen_2": "<b><span style=\"font-size: small;\"> </span></b><strong>Candidate for an independent director position.</strong> She brings 30 years of experience in an international environment of public/private structures and in diverse fields such as research, production, strategy, risk management (human, capital and societal), project and team management, and start-up mentoring. Her key areas of expertise are the pharmaceutical and chemical industries in close and continuous collaboration with a network of local and international SMEs. Drawing on all these experiences and areas of expertise, she is able to intervene in many related or complementary industries (equipment manufacturers, cosmetics, agrochemicals...). Her interest in economic development in a sustainable and equitable way is her guiding thread because she believes in collective intelligence, co-construction and collaboration as the foundation of a company's success and more broadly of our society. The candidate has a PhD in Chemistry Engineering and is a certified Director from EM Lyon.",
    "ref_299": "Ref 299",
    "la_candidate_a_un_poste_dadministratrice_inde": "<b><span style=\"font-size: small;\"> The candidate for an independent director position</span></b> <span style=\"font-size: small;\">is today a consultant and teacher in finance at the École Nationale des Ponts et Chaussées. She holds a DECS in Accounting and an Executive MBA in Management from New York University, Stern Business School. Bilingual French-English with 26 years of experience as CFO and Administrative Officer in international companies (including in the USA) in various sectors, notably consumer products and luxury. Very operational and close to the business, she has expertise in strategy, organisation, management and information systems. Representative of a corporate foundation and Member of the EPWN Board, she has experienced from the inside the workings of a Board of Directors. Member of the IFA, Women Corporate Directors and EPWN</span>",
    "ref_302": "<span style=\"font-size: small;\">Ref: 302</span>",
    "la_candidate_a_un_poste_dadministratrice_inde_2": "<b><span style=\"font-size: small;\"> Female candidate for independent director position. Very broad international experience in business development, Biotechnologies</span></b>",
    "la_candidate_ecole_des_mines_et_biotechnology": "<span style=\"font-size: small;\">The candidate (École des Mines and Biotechnology at MIT), has lived in Germany since 2000, with many years outside France: USA + various European countries. Strategy consulting at Bain, operational director at Pasteur-Mérieux, notably for a spin-off / sale of a business unit. For 8 years, successfully working as an independent consultant for the international launch/development of start-ups (biotechnology and health).</span>",
    "ref_603": "<span style=\"font-size: small;\">Ref: 603</span>",
    "candidate_a_un_poste_de_directrice_de_linnova": "<strong>Candidate for Innovation Director position, Knowledge of Boards of Directors</strong>",
    "la_candidate_est_de_formation_initiale_ingeni": "The candidate's initial training is as a PhD engineer in industrial engineering (INPG), then she obtained an \"Executive MBA\" and a doctorate in business administration (IAE, PSB). She has 15 years of experience in an international paper group managing cross-functionally the operational and strategic development of innovation (multiple international placements including Germany, the USA, Spain). For 9 years, she has developed her management consulting activity in innovation and in parallel supervises academic research on innovation culture: notably the management of collective creativity. She also has good knowledge of Boards of Directors, as she is certified as director by ADAE, of which she has become a member of the Comex and educational coordinator for the director training programme. She furthermore leads a collection of books on new value trends and Board performance.",
    "langues_etrangeres_anglais_allemand_notions_e": "Foreign languages: English, German – Basic: Spanish, Italian",
    "ref_756": "Ref:756",
    "avec_une_longue_experience_de_direction_gener": "<span style=\"font-size: small;\">With extensive experience in Senior Management, with telecom operators and suppliers, the candidate has supervised international and multidisciplinary teams (finance, marketing, commercial, product development). Member of the Executive Committee of a worldwide association of operators for more than 10 years, she has acquired a global knowledge of the industry and its players as well as experience in governance.</span>",
    "la_candidate_a_une_formation_deconomiste_aux_": "<span style=\"font-size: small;\">The candidate has an economics background (in the United States and in Switzerland) and an INSEAD MBA. She is a Member of the INSEAD Circle of Directors and Women Corporate Directors, and holds dual French and American nationality.</span>",
    "ref_108": "<span style=\"font-size: small;\">Ref: 108</span>",
    "candidate_a_un_poste_dadministratrice_indepen_3": "<span style=\"text-align: left; font-weight: bold;\"><strong>Candidate for an independent director position.</strong> Varied international experience within major American and European groups (Space, Medical and Defence), but also for SMEs and start-ups.</span>",
    "apres_un_doctorat_en_mathematiques_appliquees": "After a doctorate in applied mathematics, for about twenty years, she managed major projects (over €10 million) for export (USA, South Africa, Spain, Italy, Indonesia, Thailand, etc.) and multicultural teams in high technology information and communication. Then, in the field of artificial intelligence, she worked to define a new development strategy for a start-up from the École Normale Supérieure.",
    "ayant_obtenu_des_certificats_pour_evaluation_": "Having obtained certificates for financial evaluation and the creation of technological start-ups (HEC and Polytechnique), she joined the industrial innovation agency then the major public investment bank to provide strategic analysis of major selected projects (up to €110 million) by these organisations. Today, as an independent, she provides strategy consulting assignments. Member of the Circle of Directors.",
    "ref_109": "<span style=\"font-size: small;\">Ref: 109</span>",
    "la_candidate_de_formation_ingenieur_insead_a_": "<b><span style=\"font-size: small;\"> The candidate, trained as Engineer + INSEAD, has extensive experience in senior management positions and as a director in the industrial sector, complemented by genuine expertise in the risk management of major international projects.</span></b>",
    "apres_10_ans_a_des_postes_de_responsabilite_t": "<span style=\"font-size: small;\">After 10 years in positions of technical responsibility (design, production, testing, management of major projects), the candidate has held various Management functions involving amounts that could exceed €500M and including an international dimension: Strategy, Administration and Finance, Operations, Management Control, Supply Chain. This multidisciplinary experience (mechanical, electronic, IT, communications) has naturally led her to positions as industrial Business Unit Director, Director within General Management and as Director. The candidate has often in parallel exercised cross-functional responsibilities in multidisciplinary risk management of operational units and projects. This experience now allows her to be considered an expert in this field. She teaches management control courses (in English: \"Management control\") at various schools including ESSEC. The candidate is a member of the IFA and the INSEAD/Wharton/… Circle of Directors.</span>",
    "ref_754": "<span style=\"font-size: small;\">Ref: 754</span>",
    "consultante_franco_suisse_experte_en_gouverna": "<b><span style=\"font-size: small;\"> </span></b><strong>Consultant, French-Swiss, expert in family business governance</strong>",
    "apres_avoir_ete_avocate_au_barreau_de_paris_s": "After serving as a lawyer at the Paris Bar, specialised in business law, for seven years, she led the family wine business based in Gascony. Her work was particularly focused on international commercial development and opening new markets. Building on this experience, for 4 years, she served as Secretary General of the Family Business Network France, where she developed a multidisciplinary educational programme of workshops and lectures for entrepreneurial families.",
    "aujourdhui_consultante_independante_elle_les_": "Today, as an independent consultant, she advises them, in the context of accelerated international change, on how best to organise their governance and plan succession, particularly within the family.",
    "elle_a_suivi_un_cursus_de_droit_des_affaires_": "She studied business law and philosophy of law, and holds the certificate of aptitude for the legal profession and a master's in coaching. She lives between France and Italy.",
    "langues_francais_anglais_italien": "Languages: French – English – Italian",
    "ref_832": "<span style=\"font-size: small;\">Ref: 832</span>",
    "administratrice_independante_de_nationalite_f": "<strong>Independent director of French nationality currently living in Madrid. Extensive operational experience in the telecommunications business, then in an International NGO and today as an entrepreneur.</strong>",
    "apres_un_dea_deconomie_a_paris_la_sorbonne_et": "After a DEA in economics from Paris La Sorbonne and an MBA from the University of San Francisco in the United States, the candidate worked for 7 years within a major French telecommunications operator. She was the first woman to join the International division, as an expatriate, responsible for launching commercial activities in Spain. She remained there to launch the activities of another group in the same sector and take responsibility for their subsidiary in Spain and Portugal. She then for four years was manager for the Iberian peninsula for subsidiaries of American telecommunications companies listed on Nasdaq (hardware and software).",
    "ensuite_durant_6_annees_elle_a_ete_responsabl": "Then, for 6 years, she was responsible for the Latin countries of a major international NGO aimed at promoting the presence of women in business in positions of responsibility and boards of directors. She has developed expertise in diversity management.",
    "aujourdhui_elle_a_cree_sa_propre_entreprise_d": "Today, she has created her own consulting company to develop, within companies such as a major cosmetics group, team spirit, leadership and facilitate organisational change, notably using coaching, music and rhythms. Mentor within the international association Professional Women Network (PWN) as well as member of the Spanish Women CEO Association. Languages: French, English, Spanish.",
    "ref_723": "Ref 723",
    "administratrice_independante_experimentee_jur": "<strong>Experienced independent female director, Spanish lawyer with extensive European business experience including via Internet</strong>",
    "apres_une_formation_de_juriste_en_espagne_et_": "After legal training in Spain and Germany, the candidate worked for 5 years in Brussels, Madrid and Barcelona in several business law firms, one Spanish and two American: handling very varied disputes upstream of court proceedings, including vis-à-vis the European Commission: customs duties, abuse of dominant position, commercial agreements, mergers and acquisitions... Then, for 6 years, she was part of the Cabinet of Mr Marcelino Oreja, member of the European Commission, responsible for directing the follow-up of Enterprises, responsible for concerted actions between the Commission and member states on policies to improve the environment and develop companies. Then in Madrid, she was the creator and manager of a major e-commerce platform project designed to facilitate international trade transactions, aiming to enable commercial exchanges with significant cost reductions in exports and imports. The project received financial support from the European Union, chambers of commerce and various associations from 8 European countries. An operational prototype was created. The project received several awards and distinctions.",
    "en_parallele_elle_a_ete_directrice_juridique_": "In parallel, she was Legal Director and adviser to the Chairman of a very large Spanish group in the field of food products and construction of hotel complexes. She notably participated in the creation of an internet portal to broaden the consumer base. Today, she has created her own consulting firm for both companies and public bodies. She can provide them with the benefit of her extensive European experience, as well as in establishing relations with China and Latin American countries.",
    "en_espagne_elle_a_ete_administratrice_de_la_c": "In Spain, she has served as director of the Spanish employers' confederation, Vice Chairwoman of Women CEO and, in a major city in the eastern USA, director of a major international school as well as an NGO aimed at improving living conditions for disadvantaged people. In 2013, she participated in the course <strong><em>\"</em></strong><em>Making corporate boards more effective</em>\" at Harvard Business School.",
    "ref_762": "Ref 762",
    "la_candidate_a_un_poste_dadministratrice_inde_3": "<span style=\"font-weight: bold;\">The candidate for an independent director position, of French and American nationality, is based in the USA and in France. An Anglo-Saxon career of 30 years at the crossroads of real estate and finance</span> at Bank of America, General Motors, EY, ... or in the service of institutional clients such as the World Bank or BlackRock. She has had in turn the roles of analyst, issuer, evaluator, lender, and investor.",
    "elle_a_mene_plusieurs_operations_de_fusion_ac": "She has led several merger and acquisition or company sale operations, and sat on several boards of directors of subsidiaries of a major group.",
    "aujourdhui_consultante_independante_connaissa": "Today, as an independent consultant, with good knowledge of the United States, Canada, Western European countries and Russia, she works internationally to help institutional actors to properly formulate and execute their real estate strategies. She sits on the board of several professional real estate associations.",
    "certifications_immobilieres_courantes_avec_ob": "<strong style=\"font-weight: normal;\">Current real estate certifications, with continuing education requirements: </strong> In the USA: MAI (Member of the Appraisal Institute), CRE (Counselors of Real Estate)",
    "formation_sciences_po_paris_institut_durbanis": "<strong>Education</strong>: Sciences-Po Paris, Paris Institute of Urban Planning, New York University, Certified Director (IFA)",
    "ref_320": "Ref: 320",
    "diplomee_de_liae_de_nice_de_paris_i_pantheon_": "<span style=\"font-weight: bold;\">Graduate of IAE Nice, Paris I Panthéon Sorbonne and HEC, with an international, commercial and marketing orientation, the candidate of Franco-Bulgarian nationality has spent a third of her professional life abroad, in Bulgaria, Morocco, Italy, USA, France</span>, etc.",
    "elle_a_20_ans_dexperience_de_directions_opera": "She has 20 years of experience in operational and strategic management, in the sectors of pharmaceutical distribution, capital goods and services, in Italian, French and Japanese companies in Europe. She can claim several delicate turnarounds and has experienced two particular situations: listing on the NYSE and hostile takeover by a major Japanese group.",
    "elle_a_egalement_acquis_une_bonne_connaissanc": "She has also acquired good knowledge of how Boards work, on the one hand as a member of Executive Committees (presentations before directors), and on the other hand for having in several circumstances played the role of Board Secretary (preparation of files for the Board, knowledge of stakeholders, governance reports).",
    "elle_est_actuellement_conseil_independant_en_": "She is currently an independent advisor in strategy, supporting company or innovative activity creators from large groups, specialised in brand development &amp; enhancement, member of the strategic committee of a start-up and volunteer career advisor (HEC mentoring). Member of the French Institute of Directors, the French American Foundation, the Professional Women's Network and the HEC governance group.",
    "ref_617": "Ref: 617",
    "la_candidate_de_formation_ingenieur_insead_a__2": "<b><span style=\"font-size: small;\"> The candidate, trained as Engineer + INSEAD, has extensive experience in senior management positions and as a director in the industrial sector, complemented by genuine expertise in the risk management of major international projects.</span></b>",
    "apres_10_ans_a_des_postes_de_responsabilite_t_2": "<span style=\"font-size: small;\">After 10 years in positions of technical responsibility (design, production, testing, management of major projects), the candidate has held various Management functions involving amounts that could exceed €500M and including an international dimension: Strategy, Administration and Finance, Operations, Management Control, Supply Chain. This multidisciplinary experience (mechanical, electronic, IT, communications) has naturally led her to positions as industrial Business Unit Director, Director within General Management and as Director. The candidate has often in parallel exercised cross-functional responsibilities in multidisciplinary risk management of operational units and projects. This experience now allows her to be considered an expert in this field. She teaches courses on company control in English \"Management control\" at various schools including ESSEC.</span>",
    "la_candidate_est_membre_de_lifa_et_du_cercle_": "The candidate is a member of the IFA and the INSEAD/Wharton/… Circle of Directors.",
    "ref_754_2": "<span style=\"font-size: small;\">Ref: 754</span>",
    "administratrice_independante_grande_societe_e": "<b><span style=\"font-size: small;\"> Independent female director, Large European Company</span></b>",
    "la_candidate_domiciliee_depuis_25_ans_a_paris": "<span style=\"font-size: small;\">The candidate based in Paris for the last 25 years holds dual French and Spanish nationality. Her experience in managing highly strategic operations for major listed companies in the United Kingdom, France and Belgium has been accumulated over 30 years. First, and in depth, in the telecommunications sector, but also more recently in healthcare (hospitals) and the food industry (fishing). She can claim several delicate turnarounds as a Board member overseeing smooth operational execution, as a member of the Executive Committee, and as a consultant. Independent director of a Norwegian company, she has experienced two very enriching situations: stock exchange listing in London and hostile takeover by a major German group.</span>",
    "dans_un_contexte_franco_espagnol_tendu_elle_a": "In a tense Franco-Spanish context, she served as CEO, then Chairwoman of the Board of Directors of the Spanish joint venture of two groups (IBEX35 / CAC40). Her international experience is European and more particularly for Southern countries whose languages she speaks fluently, but extends to South America.",
    "formation_computing_sciences_engineer_cours_p": "Education: Computing Sciences Engineer, + Executive courses at INSEAD. Member of the International Board of the Global Telecommunications Women Network and in Spain of \"Plataforma de Expertas\". Member of \"Achieving Outstanding Performance\" (AoP) and TMT Group's INSEAD",
    "ref_753": "<span style=\"font-size: small;\">Ref: 753 </span>",
    "actuellement_directeur_grands_comptes_dans_un": "<b><span style=\"font-size: small;\">Currently Key Account Director in a listed international telecommunications company, the candidate is seeking, with her employer's agreement, a director position in a Board of Directors.</span></b>",
    "pendant_plus_de_15_ans_la_candidate_a_travail": "<span style=\"font-size: small;\">For more than 15 years, the candidate worked in Consulting and Engineering (IT, electronics, process,...), within a listed international group, for the Development and Management of Major Accounts, notably in Industry (automotive, medical, defence,...) and Telecoms.</span>",
    "la_candidate_a_une_expertise_de_business_deve": "The candidate has expertise as a Business Developer as well as strong marketing and HR openness. Within subsidiaries (60 to 800 people with some having revenues of more than €500M), she served as Director (France and Spain), CEO and Chairwoman (SAS). She has furthermore exercised cross-functional responsibilities and contributed to organisational transformation, both during periods of growth and during periods of crisis.",
    "membre_de_leuropean_professionals_women_netwo": "<span style=\"font-size: small;\">Member of the European Professional's Women Network, the Governance and Equilibre Circle, certified by ESSEC for the specific training to become a director \"Women Be European Board Ready\"</span>",
    "ref_604": "<span style=\"font-size: small;\">Ref: 604</span>",
    "la_candidate_pharmacie_mba_actuellement_conse": "<b><span style=\"font-size: small;\"> </span></b><b><span style=\"font-size: small;\">The candidate, Pharmacy-MBA, currently an independent strategy advisor, has 30 years of experience in operational and strategic management in the consumer and pharmaceutical sectors. Her successful international experience, notably as a \"high-level commercial executive\", demonstrates great adaptability in multicultural environments.</span></b>",
    "la_candidate_a_un_poste_dadministratrice_inde_4": "<b></b><span style=\"font-size: small;\">The candidate for an independent director position started her career in research and development in laboratory and pharmaceutical industry. She then became a strategy consultant at a major international firm where she led projects in several industries (Pharmaceuticals, Agri-food, Distribution, sectors from which she could benefit). Then, in an international leader group in the beverages sector, she spent more than 20 years in diverse operational (profit centres, sales-marketing, innovation) and strategic responsibilities in France and worldwide. In this capacity, she participated in Executive Committees, led major multicultural and functional teams. She knows what it means to carry out on the ground actions within the framework of a strategic vision. From an entrepreneurial family, she has invested in start-ups and supports them. She therefore knows how to adapt to organisations of different sizes. Trilingual French/English/German, member of the IFA</span><b><span style=\"font-size: small;\">.</span></b>",
    "ref_632": "<span style=\"font-size: small;\">Ref: 632</span>",
    "au_cours_des_22_dernieres_annees_cette_candid": "<span style=\"font-size: small;\"><b>Over the last 22 years, this candidate for a director position has been a member of Executive Committees, with expertise in finance, strategy and transformation projects both in France and internationally in the sectors of financial services, infrastructure related to transport, energy, waste and leisure.</b></span>",
    "apres_10_ans_dexperience_en_financements_stru": "After 10 years of experience in structured financing in the utilities and transport sectors, she contributed to defining strategic developments for one of the leading French banking groups (investment evaluations, capital allocation, partnership conclusions) and led major transformation projects as CFO of international groups leading in the fields of asset management, investment banking and private banking. She served as director of several financial sector companies in France and abroad (Italy, UK, USA, Hong Kong), and is currently director of the national association of chief financial officers, the DFCG, of which she chairs the Île-de-France region. She is furthermore a member of the IFA and has initiated the IFA/DFCG working group on the theme \"CFO and Audit Committee\". She has taught financial analysis and management control at Dauphine and HEC. She is a graduate of Sciences Po Paris and Columbia University.",
    "ref_813": "<span style=\"font-size: small;\">Ref: 813</span>",
    "directrice_financiere_et_des_operations_avec_": "<span style=\"font-size: small;\"><b>CFO and Operations Director,</b> <b>with 25 years of experience in international listed industrial groups, in the Energy, Environment, Aluminium, Packaging, Chemicals and B2B Services sectors</b></span>",
    "la_candidate_dispose_d_une_vaste_pratique_du_": "The candidate dispose d´une vaste pratique du «  Risk management « , des grands projets d´investissements, des fusions &amp; acquisitions, and of the transformation des organisations, tant in périodes de croissance que de crise économique globale. Grâce aux différents mandates qu’she has helds, including comme director de subsidiaries, dont l´un de co-Présidente d´un Conseil, she has acquired une experience in-depth of the governance des joint-ventures international in contextes complexes and politiquement sensibles.",
    "diplomee_d_hec_et_du_mba_de_mcgill_university": "Graduate d´HEC (and du MBA de McGill University au Canada), complété d´une formation récente au MIT (Sloan School of Management), she lives in Germany, parle couramment l´English, l´German and l´Spanish, and pourra provide the benefit of le Conseil of his vécu international.",
    "ref_803": "<span style=\"font-size: small;\">Ref: 803 .</span><b><span style=\"font-size: small;\"> </span> </b>",
    "candidate_administratrice_independante_experi": "<b><span style=\"font-size: small;\"> Independent director candidate. International experience. Telecoms, Space, R&amp;D Consulting, IT Services. Excellent command of governance issues.</span></b>",
    "la_candidate_de_formation_juridique_internati": "<span style=\"font-size: small;\">The candidate, by training legal international (UK, France and USA) has held of positions de Legal Director and Board Secretary d’importantes listed companies and non listed ayant of activities largement international in doMaynes des telecoms, du conseil en R&amp;D, des SSII and de l’industrie spatiale. Elle has acquired une extensive experience des restructurings, of partnerships in multiples pays whose Qatar and le Japon, du M&amp;A dans différents pays whose France and les USA, and du white-collar criminal law. Au titre of his/her activités in the capacity of Board Secretary, she served as fortement impliquée in problématiques de governance and est habituée aux pratiques des conseils multinationaux . She served as director de subsidiaries in Italy and in Germany. </span>",
    "ref_504": "<span style=\"font-size: small;\">Ref: 504</span>",
    "au_travers_des_activites_menees_dans_postes_t": "<span style=\"font-size: small;\">Throughs activités menées dans postes tenus in Paris and in Oxford, the candidate has developed des competences de généraliste en gestion, finance and développement commercial in the sector des services within PME European. Au fil des last five years, she has acquired une experience in relations with the shareholders (of the fundraising au reporting trimestriel and organisation/animation des general meetings) as well as in governance intégrant la dimension RSE and l’audit financier, social and environnemental.</span>",
    "apres_avoir_en_angleterre_co_developpe_ex_nih": "<span style=\"font-size: small;\">After having in England co-développé ex-nihilo une company du doMayne of the finance éthique and de l’real estate responsable of which she est aujourd’hui director, the candidate est rentrée in France en 2010 to créer une company similaire. She is aujourd’hui PDG. Son mandate d’director will end en July 2012, lui laissant of availability pour exercer efficacement a position d’independent director, in particular in a company with activités en UK.</span>",
    "formation_master_of_business_administration_u": "<span style=\"font-size: small;\">Formation: Master of Business Administration, Université d’Oxford (SBS) and formation continue auprès de l’Institute of Directors and l’Institut Français des Administrateurs. »</span>",
    "ref_107": "<span style=\"font-size: small;\">Ref: 107</span>",
    "administratrice_independante_20_ans_dexperien": "<span style=\"font-size: small;\"><b>Independent director, 20 years d’experience worldwide des NTIC : Entrepreneur, PDG, Investor. </b> The candidate, after serving as director moreoverieurs companies in the world des NTIC and de l’Internet. Aujourd’hui independent director d’une listed company Eurolist C, she could provide the benefit of à d’autres of his experience diversified (Entrepreneur, PDG, Director, Investor). </span>",
    "apres_avoir_occupe_des_postes_de_direction_ge": "<span style=\"font-size: small;\">After holding of positions de Senior Management for 10 years, she created a start-up Internet en 1999 revendue en 2001. Elle réalise alors assignments in conseil en strategy and prend la direction du développement d’a major firm d’audit and de conseil avant de rejoindre un fonds d’investissement comme « Partner ».</span>",
    "apres_un_master_2_universite_de_paris_2_dassa": "<span style=\"font-size: small;\">Après un Master 2 Université de Paris 2 d’Assas en « Coaching », she creates en 2010 sa company de « Business Coaching » pour aujourd’hui accompagner des companies dans leur développement through the missions de « Coaching » de dirigeants and d’accompagnement operational.</span>",
    "formation_doctorat_de_gestion_universite_de_p": "<span style=\"font-size: small;\">Education: Doctorate in Management, University of Paris 1, MBA, Master 2 Coaching, Assas.</span>",
    "ref_152": "<span style=\"font-size: small;\">Ref: 152</span>",
    "candidate_a_un_poste_dadministratrice_indepen_4": "<span style=\"font-size: small;\"><b>Candidate in a position d’independent director in the doMayne of the santé </b> Docteur en médecine, spécialiste qualified en santé publique, she has held des fonctions très diverses in services de l’état and de 2 régimes d’assurance maladie Elle envisage de prendre sa retraite au 01/07/2013 and pense en tant qu’independent director pouvoir provide the benefit of of his experience extensive un Conseil d’Administration d’une company opérant on marchés of the santé. Pour s’y préparer, elle devenue member l’IFA (Institut French des Directors)and Certified Director after having suivi le cours by training proposé par l’ IFA /Science Po . </span>",
    "ref_365": "<span style=\"font-size: small;\">Ref: 365</span>",
    "femme_ingenieur_supelec_candidate_comme_admin": "<b><span style=\"font-size: small;\">Female Supelec engineer, candidate as independent director</span></b>e",
    "pour_avoir_occupe_dans_des_ssii_pendant_plusi": "<span style=\"font-size: small;\">Pour avoir occupé in SSII pendant plusieurs années of positions de PDG, Chairwoman of the Executive Board, Director de SA and créé une SAS in the doMayne du luxe, the candidate a une experience in-depth of positions operational de dirigeante comportant among other things, IPO, fusions-acquisitions, création d’company, fundraising.</span>",
    "aujourdhui_elle_travaille_dans_le_domaine_des": "Today, she works in the investment funds sector.",
    "ref_612": "<span style=\"font-size: small;\">Ref: 612</span>",
    "candidate_a_un_poste_dadministratrice_comme_m": "<b><span style=\"font-size: small;\">Candidate à un poste d’administratrice, comme membre du Comité Stratégie or d’audit Très grande expérience de la finance à l’international. </span></b>",
    "diplomee_dhec_de_la_london_business_school_et": "<span style=\"font-size: small;\">Graduate d’HEC, of the London Business School and de New York University (International Program), elle commence au sein d’une grande banque American par gérer les relations with grandes companies du secteur privé and public. En 1985, elle rejoint une banque d’affaires international renommée for the opérations de conseil financier and de fusions / acquisitions. Elle a conseillé des Etats, in particular de pays émergents, des grandes companies international and des institutions financières, notably sur: – of investments industrial in pays de l’Est and in pays émergents, – des montage and financements of large projets in the sectors de l’énergie and des infrastructures, – des renégociations de dettes – la gestion and la cession de portefeuilles d’actifs and de prêts of large institutions financières. Dans ce cadre, elle a l’habitude de travailler directement with the COMEX and Conseils d’Administration and with the gouvernements.</span>",
    "elle_est_membre_de_lifa_de_lassociation_hec_d": "<span style=\"font-size: small;\">Elle est membre de l’IFA, de l’association HEC dans ses domaines de compétences, de plusieurs organisations de femmes dirigeantes and de Business Angels. »</span>",
    "ref_512": "<span style=\"font-size: small;\">Ref: 512 </span>",
    "la_candidate_a_un_poste_d_administratrice_ind": "<b><span style=\"font-size: small;\">The candidate in a position d’ Independent director est lawyer en business law and has been responsable legal de groupes international listed. Un séjour moreoverieurs années comme résidente en Corée du Sud (au sein d’a firm d’lawyers Korean puis à la Chambre de Commerce Franco Coréenne) lui has enabled de connaître de l’intérieur la culture nord asiatique. Elle a donné of courses sur ce thème.</span></b>",
    "experience_approfondie_du_domaine_des_ventes_": "<b></b><span style=\"font-size: small;\">Extensive experience in consumer sales including electronic products. As a lawyer, then as legal manager, she is familiar with regulatory issues, compliance, and corporate governance.</span>",
    "ref_635": "<span style=\"font-size: small;\">Ref: 635</span>",
    "candidate_administratrice_independante_hotell_2": "<span style=\"font-size: small;\"><b>Candidate administratrice indépendante : Hôtellerie, Restauration, Tourisme ; France and Europe</b> Expérience pluridisciplinaire acquise au sein d’un groupe hôtelier international coté au CAC 40. Au fil de 30 années, dont 12 ans dans la restauration publique, la candidate a successivement occupé des postes de dirigeante dans des domaines variés : contrôle de gestion, produits, opérations, marketing, audit interne, production, publishing and communication des bureaux de ventes internationales, enfin quant à l’efficacité des coûts marketing &amp; distribution. </span>",
    "aujourdhui_elle_est_consultante_independante__2": "<span style=\"font-size: small;\">Aujourd’hui, she is independent consultant in these doMaynes. Very good knowledge of l’international. Education: Master's in Economics (Paris 2), DEA Théories and Politiques monétaires (Paris 2), Executive Doctorate in Business Administration (Paris Dauphine, 2009). Member de l’IFA and Secretary General de l’Association Européenne de Neuroéconomie.</span>",
    "ref_303_2": "<span style=\"font-size: small;\">Ref: 303</span>",
    "hommes_candidatsle_candidat_x_ensta_actuellem": "<table align=\"center\" border=\"1\" cellpadding=\"0\" cellspacing=\"6\" width=\"100%\"><tbody>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.hommes_candidats\" style=\"height: 58px; text-align: center;\" valign=\"top\"><span style=\"color: #ff0000;\"><b> <span style=\"font-size: 14px;\">Male Candidates</span></b></span></td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_x_ensta_actuellement_expert_indep_2\" valign=\"top\">\n<p align=\"JUSTIFY\" data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_x_ensta_actuellement_expert_indep\"><strong>The candidate, X-Ensta, currently expert independent en mergers and acquisitions, a 35 years d’experience en balance sheet operations, dont vingt années dans l’énergie and les commodities.</strong></p>\n<p align=\"JUSTIFY\" data-i18n=\"page_candidats_mandataires_sociaux.apres_un_debut_de_carriere_dans_le_nucleaire_\">After starting his career in the nuclear, he served as en charge d’distressed businesses au Ministère de l’Industrie and à la Treasury Department. He was then responsable pendant 6 years d’a significant holding pétrolier multinational, puis durant 4 years has been Deputy CEO d’une grande structure de portfolio management, avant de rejoindre one of the world leaders du nuclear to carry out notably des restructuring of investments and d’activités, des balance sheet operations and of reflections strategic</p>\n<p align=\"JUSTIFY\" data-i18n=\"page_candidats_mandataires_sociaux.il_a_ete_administrateur_dun_grand_groupe_mini\">He has served as director d’a major group minier and d’une holding de participations, and jusqu’à recently Chairman of the Supervisory Board d’une company dans laquelle le BPI détient une participation.</p>\n<p align=\"JUSTIFY\" data-i18n=\"page_candidats_mandataires_sociaux.il_est_depuis_plusieurs_annees_expert_industr\">He is for several years expert industrie-énergie au sein d’a firm de mergers and acquisitions.</p>\n<p align=\"JUSTIFY\" data-i18n=\"page_candidats_mandataires_sociaux.ref_920\">Ref: 920</p>\n</td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.administrateur_independant_membre_du_comite_d_2\" valign=\"top\">\n<table border=\"0\" cellpadding=\"1\" cellspacing=\"0\" width=\"437\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.administrateur_independant_membre_du_comite_d_3\" width=\"435\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.administrateur_independant_membre_du_comite_d\"><strong> Independent director, member du Comité d’audit, expert en risk management, digital transformation and cybersecurity</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_senior_manager_dans_un_cabinet_de_\">Aujourd’hui, Senior Manager in a firm de conseil traitant of the risk management, fraude and corruption. Looking back in time, in a context régulé (Solvabilité 2), he served as Director and Chairman du Comité d’audit d’une company de Prévoyance dont he led la cession . Dans une company industrial du CAC40, he has led un shared service center, été internal auditor and chef de projet d’an operation de merger and acquisition. Au sein d’une grande company American, and avant, dans a major group French des telecoms, he served as internal auditor.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.a_loccasion_de_ses_nombreuses_missions_il_a_a\">A l’occasion de his/her numerous assignments, he has acquired :</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.une_profonde_expertise_en_systeme_dinformatio\">– Une profonde expertise en système d’information and digital transformation,</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.une_experience_internationale_tres_etendue_un\">– Une experience international très extensive : about thirty countries, on the 5 continents, with a prédominance pour l’Afrique where he a also travaillé 2 years as coopérant (Kenya) for the compte d’une agence de l’ONU</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.une_connaissance_de_secteurs_dactivite_tres_v\">– Une knowledge of secteurs d’activité très varied, in particular : l’industrie, le BTP, les telecommunications, l’environnement, l’énergie, la Défense, la recherche, les assurances, la gestion d’actifs.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.diplome_de_lessec_et_de_telecom_paris_anglais\">Graduate de l’ESSEC and de Télécom Paris, fluent English, Member de l’IFA d’Audit. Ref 732</p>\n</td></tr></tbody></table>\n<p align=\"left\"> </p>\n</td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.non_executive_director_in_european_companies__2\" valign=\"top\">\n<div align=\"center\"> </div>\n<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.non_executive_director_in_european_companies__3\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.non_executive_director_in_european_companies_\"><b><span style=\"font-size: small;\"> </span></b><strong>Non Executive Director in European companies and family offices with a focus and presence in Asia.</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.this_male_candidate_has_a_successful_track_re\">This mathe candidatee has a successful track record of over twenty-two years advising Fortune 500 companies on strategy, mergers and acquisitions (M&amp;A), corporate finance and business development in ASEAN and India. Knowledge and experience of profit and loss (P&amp;L) and Balance Sheet responsibilities, starting and growing a highly profitable investment banking business and in completing a complex restructuring for a large family owned business. Boards Director experience in listed and unlisted companies as a Non Executive and Executive Director. 52 year old Indian national, INSEAD MBA, Physics background and International outlook having lived in India, Singapore, France, and the U.K.. Presently based in Singapore. Languages: English, Hindi, Gujarati, French basic</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_881\"><span style=\"font-size: small;\">Ref: 881</span></p>\n</td></tr></tbody></table>\n</td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.industries_a_destination_du_btp_securite_fran_2\" valign=\"top\">\n<div align=\"center\"> </div>\n<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.industries_a_destination_du_btp_securite_fran_3\" height=\"93\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.industries_a_destination_du_btp_securite_fran\"><b><span style=\"font-size: small;\"> Industries à destination du BTP /sécurité (France, Pays-Bas Egypte)</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_ingenieur_et_science_po_a_dans_le\"><span style=\"font-size: small;\">The candidate, engineer and Science-Po a in doMaynes and les pays mentionnés above-mentioned une experience de Chairman and d’director</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_871\"><span style=\"font-size: small;\">Ref: 871</span></p>\n</td></tr></tbody></table>\n</td></tr>\n<tr align=\"left\"><td data-i18n=\"page_candidats_mandataires_sociaux.candidat_a_un_poste_dadministrateur_independa_4\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr align=\"left\"><td data-i18n=\"page_candidats_mandataires_sociaux.candidat_a_un_poste_dadministrateur_independa_5\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidat_a_un_poste_dadministrateur_independa\"><strong> Candidate in a position d’independent director Long and extensive experience de DG PME industrial familiale Subsidiaries Europe and Asie, Company Director du service sector</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ingenieur_43_ans_de_carriere_industrielle_don\">Engineer, 43 years of industrial career, dont 13 en production, puis 30 en Senior Management and Présidence d’une PME familiale industrial (CA 40 M€), secteur mécanique and métallurgie.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.creation_et_presidence_de_filiales_en_europe_\">Création and Présidence de subsidiaries in Europe, Chine and Inde. Développement d’alliances and réseaux international. Forte experience commerciale and managériale in Europe, Moyen Orient and Asie.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.23_ans_president_de_conseil_de_surveillance_e\">23 years Chairman de Supervisory Board en tant qu’independent director of two companies du service sector : édition &amp; multimedia (2 M€), restauration &amp; séminaires (5 M€).</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.experience_en_evaluation_acquisition_et_integ\">Experience en évaluation, acquisition and intégration de companies and of issues de governance, transmission, mutation d’shareholdings.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.connaissance_de_lenseignement_superieur_10_an\">Knowledge of l’Higher Education : 10 years Chairman d’un Advisory Board. Anglais and Allemand .</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_544\" style=\"font-size: 12px; font-weight: normal;\"><span style=\"font-size: small;\">Ref: 544</span></p>\n</td></tr></tbody></table></td></tr>\n<tr align=\"center\" style=\"font-weight: normal; font-size: 10pt; font-style: normal;\"><td data-i18n=\"page_candidats_mandataires_sociaux.administrateur_independant_grande_experience__2\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr align=\"left\"><td data-i18n=\"page_candidats_mandataires_sociaux.administrateur_independant_grande_experience__3\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.administrateur_independant_grande_experience_\" style=\"font-size: 12px; font-weight: bold;\"><strong>Independent director, extensive experience en audit</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_ingenieur_commercial_dhec_liege_a\">The candidate, business graduate d’HEC Liège, has held for 25 years in the capacity of Statutory Auditor and d’Chartered Accountant in Belgium and au Grand-Duché de Luxembourg.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.certifie_comme_administrateur_de_societes_ifa\">Certified as Company Director (IFA/SC.PO) and en strategy of the risk management CEFAR/AMRAE. Member des Instituts French and Luxembourg des directors.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.fort_de_son_experience_internationale_au_sein\">Building on son experience international within cabinets d’audit anglo-saxons for companies commerciales, industrial and financières (of medium size), he is devenu entrepreneur by the création and le développement of his/her propres cabinets d’accounting firm, de company domiciliation and d’audit (affilié à a network international, Kreston).</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.son_parcours_professionnel_lui_a_fait_connait\">His/her career path professional lui a fait connaître des secteurs d’activité très varied and in particular le BTP and la wealth management, structures of various sizes différentes, with enjeux and des modèles de business à divers stades de développement. Il has participated à of very nombreuses missions de restructurings both in France qu’au Luxembourg.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.de_par_sa_nationalite_italienne_et_son_parcou\">De par sa nationalité Italian, and his/her career path European, he is thoroughly familiar with in depth les cultures French, Italian and English and has mastered the languages associées.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_il_est_administrateur_de_societes_\">Aujourd’hui, he is company director Luxembourgeoises thus qu’internal auditor within financial structures under Luxembourg regulation.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_532\" style=\"font-size: 12px; font-weight: normal;\"><span style=\"font-size: small;\">Ref: 532</span></p>\n</td></tr></tbody></table></td></tr>\n<tr align=\"center\" style=\"font-weight: normal; font-size: 12px; font-style: normal;\"><td data-i18n=\"page_candidats_mandataires_sociaux.candidat_a_un_poste_dadministrateur_independa_6\" valign=\"top\">\n<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr align=\"left\"><td data-i18n=\"page_candidats_mandataires_sociaux.candidat_a_un_poste_dadministrateur_independa_7\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidat_a_un_poste_dadministrateur_independa_2\" style=\"font-size: 12px; font-weight: bold;\"><b>Candidate in a position d’independent director,</b> long experience de Dirigeant de PME/ETI including à l’international dont Extrême Orient</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.25_ans_de_direction_generale_de_pme_eti_indus\" style=\"font-size: 12px; font-weight: normal;\">– 25 years of Senior Management de PME / ETI industrial de 10/50/120 millions € de CA, multi sites and multi pays – Secteurs industrial : composite materials, aerospace coatings, imprimerie, plastic packaging, wood processing, pièces d’équipements pour l’industrie and la filière oil and gaz. – Types d’shareholdings : groupes listed French and étrangers, groupes familiaux, companies sous LBO. – Experience en développement, gestion, restructuring, insolvency proceedings, reprise sous LBO and external growth. <span style=\"font-size: smaller;\">– A travaillé in Europe, Inde, Iran, Chine, Afrique du Sud. Connaissance du Grand Export pour</span> y avoir implanté des subsidiaries industrial. – Member IFA, APIA – Engineer UTC, Master of Sciences du Cranfield Institute of Technology, MBA du Groupe HEC – Fluent English</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_678\" style=\"font-size: 12px; font-weight: bold;\"><span style=\"font-size: small;\">Ref: 678</span></p>\n</td></tr></tbody></table>\n<p style=\"font-size: 12px; font-weight: bold;\"> </p>\n</td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.candidat_a_un_poste_dadministrateur_independa_8\" valign=\"top\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidat_a_un_poste_dadministrateur_independa_9\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidat_a_un_poste_dadministrateur_independa_3\"><b>Candidate in a position d’independent director, (Comité d’Audit or de Rémunérations). Dans plusieurs secteurs, extensive experience of the Finance and of the Direction Opérationnelles d’Entreprise. </b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.dote_dune_triple_formation_mba_americain_inge\">Doté d’une triple formation (MBA American, Engineer, Economics), the candidate a a position d’independent director, after serving as consultant junior dans deux cabinets renommés, has carried out sa career in subsidiaries françaises of two groupes international majeurs , l’un American, puis l’autre German. Pour the latter, il also travaillé within la Mayson mère in Germany. He has rich experience moreover de 20 years of Finance Department extensive (finances, accounting, taxation, legal and IT) in environments international. Dans cette fonction, he has participated, both in France qu’à l’étranger, à of numerous opérations de merger and acquisition and has served on dans plus of ten supervisory boards or d’administration de subsidiaries of groups mentioned above. Mays, l’originalité de his/her career path tient en ce qu’il a also été CEO  » terrain « , in particular dans of operations successful de turnaround moreoverieurs companies appartenant à différents doMaynes. Les secteurs économiques where a Consehe could benefit from his/her experience englobent notably la chemicals, la pharmaceuticals, l’agri-food, les flavours and fragrances as well as l’real estate. Trilingual French/English/German</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_503\"><span style=\"font-size: small;\">Ref: 503</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.industrie_pharmaceutiquele_candidat_docteur_e\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.industrie_pharmaceutiquele_candidat_docteur_e_2\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.industrie_pharmaceutique\"><span style=\"font-size: small;\"><b> Pharmaceutical Industry</b></span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_docteur_en_pharmacie_aihp_a_une_e\"><span style=\"font-size: small;\">The candidate, Docteur en Pharmaceuticals, AIHP, a une experience des travaux de recherche en hopital and de postes de R&amp;D Management in companies pharmaceutiques including une large-scale with subsidiaries in the USA.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.createur_dune_start_up_de_conseil_en_strategi\"><span style=\"font-size: small;\">Créateur d’a start-up de conseil en strategy R &amp; D pharmaceutique and co-fondateur d’une autre in conception of new antiviral drugs.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_561\"><span style=\"font-size: small;\">Ref: 561</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.administrateur_independant_electronique_aeron\" valign=\"top\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.administrateur_independant_electronique_aeron_2\">\n<div align=\"left\"><span style=\"font-size: small;\"><b>Independent Director, Electronique, Aerospace, Défense and Sécurité. </b> </span></div>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_de_formation_x_et_supaero_ensae_c\"><span style=\"color: #000000; font-size: small;\">The candidate by training X and Sup’Aéro (ENSAé), complemented by Management strategic (IFG-ICG), has held des senior positions within la Senior Management de l’Armement du Ministry of Defence. D’une extensive experience en defence electronics, il is one of the few hauts fonctionnaires Maytrisant le secteur de l’armement French and European in the doMayne des high technologies. Holder of the certificat d’company director (IFA)</span>.</p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_462\"><span style=\"font-size: small;\">Ref: 462</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.equipements_et_appareillages_industriels_ener_2\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.equipements_et_appareillages_industriels_ener_3\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.equipements_et_appareillages_industriels_ener\"><b><span style=\"font-size: small;\"> </span></b><span style=\"font-size: small;\"><b>Equipements and appareillages industrial (Energie, Transport, High Technology)</b></span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_ingenieur_mba_bilingue_francais_a\"><span style=\"font-size: small;\">The candidate Engineer + MBA bilingual French/English a une experience very advanced: – de l’Asie /Pacifique avec 7 years of résidence au Japon and la présidence de companies both in Japan qu’in China, Corée, Taiwan, Thailande,Indes, Australie. – De l’Europe and du Commonwealth avec 6 years of résidence in London where été ajoutés of positions d’directors sur ces zones à ceux dejhas helds in Asia.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_261\"><span style=\"font-size: small;\">Ref: 261</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.aviation_aeronautique_spatial_defense_securit_2\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.aviation_aeronautique_spatial_defense_securit_3\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.aviation_aeronautique_spatial_defense_securit\"><span style=\"font-size: small;\"><b> </b></span><span style=\"font-size: small;\">.</span><b><span style=\"font-size: small;\">Aviation, Aerospace, Spatial, Défense &amp; Sécurite.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_de_formation_economique_commerce_\"><span style=\"font-size: small;\">The candidate by training Economique &amp; International Trade (Londres and Paris) complemented by Management (INSEAD) and Défense (IHEDN) a une extensive experience international through la World Bank (Amériques and Asie) puis l’industrie Aerospace/spatiale/défense/sécurite Francaise, Européenne and Américaine for thequelles he has held des very senior operational positions and « Corporate ». </span><span style=\"font-size: small;\">Il partage his/her residence entre Washington and Paris and est particulièrement actif in the sectors indiqués sur l’Europe, les Amériques and le Moyen Orient.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_513\"><span style=\"font-size: small;\">Ref: 513 </span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.administrateur_de_filiales_anglaises_de_socie_2\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.administrateur_de_filiales_anglaises_de_socie_3\" height=\"158\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.administrateur_de_filiales_anglaises_de_socie\"><b><span style=\"font-size: small;\"> Director de subsidiaries anglaises de companies françaises and réciproquement</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_a_30_ans_dexperience_dans_quelque\"><span style=\"color: #000000; font-size: small;\">The candidate a 30 years d’experience dans quelques-unes des plus grandes companies du Royaume-Uni, de l’Allemagne, des Etats-Unis and des Pays-Bas. Financier by training, habitué aux problématiques des états-major also bien qu’à celles of operations, son expertise concerne des companies also variées that the marine, la chemicals, le sustainable development and l’real estate. D’origine English, Mays long established in France, in Paris and in région rhénane, il would be happy de build bridges between subsidiaries françaises and leurs Maysons-mère britanniques/allemandes or vice versa. </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_203\"><span style=\"color: #000000; font-size: small;\">Ref: 203</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_de_formation_x_et_insead_a_une_la_2\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_de_formation_x_et_insead_a_une_la_3\" height=\"121\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_de_formation_x_et_insead_a_une_la\"><span style=\"font-size: small;\"><b>The candidate by training X and INSEAD a une extensive experience des secteurs infrastructures, aménagement, bâtiment, environnement, sustainable development, ingénierie, services publics, concessions and partenariats publics privés. </b> Dans these sectors, il has held des management positions operational including on chantiers international large-scale (Algérie, Chine). Il été director within Conseils d’Administration and de Surveillance of type très varied and PDG d’une subsidiary d’one of the leaders de l’ingénierie and du conseil. Il vient de recently créer his/her own company de conseil in order to provide the benefit of of his experience des companies de these sectors, in particular through mandates d’independent director </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_508\"><span style=\"color: #000000; font-size: small;\">Ref: 508</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.edition_de_logicielle_candidat_expert_comptab\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.edition_de_logicielle_candidat_expert_comptab_2\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.edition_de_logiciel\"><b><span style=\"font-size: small;\"> Edition de software</span></b></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_expert_comptable_a_une_large_expe\"><span style=\"font-size: small;\">The candidate, Chartered Accountant a une extensive experience de finance department, general secretariat and d’director de </span><span style=\"font-size: small;\">SSII and de companies d’édition de software</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_909\"><span style=\"font-size: small;\">Ref: 909</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.genie_medical_france_et_usaapres_avoir_ete_au\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.genie_medical_france_et_usaapres_avoir_ete_au_2\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.genie_medical_france_et_usa\"><b> <span style=\"font-family: Times New Roman, Times, serif; font-size: small;\">Medical Engineering France and USA</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_avoir_ete_aux_usa_manager_de_projets_ma\"><span style=\"font-size: small;\">After serving as in the USA Manager de projets marketing d’une subsidiary d’une grande company pharmaceutique US, puis for 4 years International Marketing Director d’une company US en Medical Engineering, he founded in France a start-up for the medical assessments. He was the PDG pilotera un développement successful. Société opérant in Europe and in the USA, listed on Euronext. Grand experience of contacts de haut niveau and of transfers de technologie (USA and Europe) with the milieux scientifiques and financiers. Education: Master en Management de l’ ISG</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_104\"><span style=\"font-size: small;\">Ref: 104</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.pharmacie_humaine_otc_et_sante_animalele_cand\" valign=\"top\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.pharmacie_humaine_otc_et_sante_animalele_cand_2\" valign=\"top\">\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.pharmacie_humaine_otc_et_sante_animale\"><b><span style=\"font-family: Times New Roman, Times, serif; font-size: small;\">Human pharmacy (OTC) and Animal health</span></b></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_veterinaire_avec_une_formation_de\"><span style=\"font-size: small;\">The candidate, vétérinaire with a formation de gestionnaire acquise à l’ ESSEC is an experienced executive expérimenté within grands groupes, in particular American, both as opérationel (DG or Business Unit) que fonctionnel (Marketing) within subsidiaries commercialisant des produits for the animal health or huMayne (OTC). Experience d’director du Syndicat de l’Industrie du Médicament vétérinaire. Knowledge of Russian.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_115\"><span style=\"font-size: small;\">Ref: 115</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.equipements_pour_l_energie_le_petrole_et_le_g_2\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.equipements_pour_l_energie_le_petrole_et_le_g_3\" valign=\"middle\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.equipements_pour_l_energie_le_petrole_et_le_g\"><span style=\"font-size: small;\"><b> Equipements pour l’ énergie le oil and le gaz</b></span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_ingenieur_et_mba_hec_isa_a_une_ex\"><span style=\"font-size: small;\">The candidate, engineer and MBA HEC-ISA a une experience d’director in several companies du doMayne above-mentioned.</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.experience_tres_etendue_produits_alimentaires_2\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"97%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.experience_tres_etendue_produits_alimentaires_3\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.experience_tres_etendue_produits_alimentaires\"><b><span style=\"font-size: small;\">Experience très extensive (Produits alimentaires de consumer goods) France and International durant over 15 years</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_a_des_postes_dadministrateur_est_\"><span style=\"font-size: small;\"> The candidate in positions d’director est issu d’une Business School. He served as PDG, Director and Dirigeant Opérationnel de subsidiaries in several pays Européens and in the USA. Il has carried out operations of restructuring complexes. Dans le cadre de his/her responsibilities, il has raised of funds auprès of large investors en venture capital and mené assignments in conseil within the framework d’ opérations de Fusions &amp; Acquisitions (multinationales and start up).</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_845\"><span style=\"font-size: small;\">Ref: 845</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.experience_internationale_tres_etendue_high_t_2\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.experience_internationale_tres_etendue_high_t_3\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.experience_internationale_tres_etendue_high_t\"><b> </b><span style=\"font-size: small;\"><b><span style=\"font-size: small;\">Experience international très extensive (High Tech and IT) </span></b> </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_a_passe_plus_de_30_ans_dans_des_e\"><span style=\"font-size: small;\">The candidate has spent over 30 years in environments international dont over 10 years de vie in the USA. I</span><span style=\"font-size: small;\">l has been PDG, Director or dirigeant operational de subsidiaries of large companies d’IT (généraliste, prestataires de service, progiciels) and Vice Chairman d’a start-up (biométrie). Des liabilitys prises in the doMayne du commerce des objets d’arts and de l’real estate ont enrichi his/her vision de l’company. Aujourd’hui, consultant international, il proposes, en devenant independent director, de provide the benefit of des companies of her competence. F</span><span style=\"font-size: small;\">ormation: Engineer Arts and Métiers and INSEAD</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.presse_et_medias_developpement_internationall\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.presse_et_medias_developpement_internationall_2\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.presse_et_medias_developpement_international\"><b><span style=\"font-size: small;\"> Presse and Médias Développement International</span></b></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_aujourdhui_consultant_internation\"><span style=\"font-size: small;\">The candidate, aujourd’hui consultant international, has started comme Director of the Ch. Com. French in a pays nordique, avant de représenter des industries françaises du textile and de l’habillement in instances international. Then, au sein d’a major group de presse/médias French, he was Subsidiary Director au Portugal, International Director among other things in charge ofs montages de JV, Managing Director d’une subsidiary in France, Deputy Director with postes d’directors. Corporate officer potentiel de companies du doMayne presse/médias with a développement international (speaks several languages: Swedish, Portuguese, English and German). Formation Droit, Oriental Languages ( Russian).</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_101\"><span style=\"font-size: small;\">Ref: 101 </span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.questions_energetiques_et_gestion_des_risques_2\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.questions_energetiques_et_gestion_des_risques_3\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.questions_energetiques_et_gestion_des_risques\"><b><span style=\"font-size: small;\"> Questions énergétiques and risk management associés</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_a_une_longue_experience_des_affai\"><span style=\"font-size: small;\">The candidate a une long experience des affaires énergétiques (civil engineering specialised and équipements lourds/turbomachines…) and du « risk management » associé. Durant ces dernières années, il a assimilé le statut particulier, les aléas inhérents, les modalités de travail des hauts dirigeants and directors de companies and leur implication accrue in gestion de l’énergie and les risques.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_402\"><span style=\"font-size: small;\">Ref: 402</span></p>\n</td></tr></tbody></table></td></tr>\n</tbody></table>",
    "hommes_candidats": "<span style=\"color: #ff0000;\"><b> <span style=\"font-size: 14px;\">Male Candidates</span></b></span>",
    "le_candidat_x_ensta_actuellement_expert_indep_2": "<p align=\"JUSTIFY\" data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_x_ensta_actuellement_expert_indep\"><strong>The candidate, X-Ensta, currently expert independent en mergers and acquisitions, a 35 years d’experience en balance sheet operations, dont vingt années dans l’énergie and les commodities.</strong></p>\n<p align=\"JUSTIFY\" data-i18n=\"page_candidats_mandataires_sociaux.apres_un_debut_de_carriere_dans_le_nucleaire_\">After starting his career in the nuclear, he served as en charge d’distressed businesses au Ministère de l’Industrie and à la Treasury Department. He was then responsable pendant 6 years d’a significant holding pétrolier multinational, puis durant 4 years has been Deputy CEO d’une grande structure de portfolio management, avant de rejoindre one of the world leaders du nuclear to carry out notably des restructuring of investments and d’activités, des balance sheet operations and of reflections strategic</p>\n<p align=\"JUSTIFY\" data-i18n=\"page_candidats_mandataires_sociaux.il_a_ete_administrateur_dun_grand_groupe_mini\">He has served as director d’a major group minier and d’une holding de participations, and jusqu’à recently Chairman of the Supervisory Board d’une company dans laquelle le BPI détient une participation.</p>\n<p align=\"JUSTIFY\" data-i18n=\"page_candidats_mandataires_sociaux.il_est_depuis_plusieurs_annees_expert_industr\">He is for several years expert industrie-énergie au sein d’a firm de mergers and acquisitions.</p>\n<p align=\"JUSTIFY\" data-i18n=\"page_candidats_mandataires_sociaux.ref_920\">Ref: 920</p>",
    "administrateur_independant_membre_du_comite_d_2": "<table border=\"0\" cellpadding=\"1\" cellspacing=\"0\" width=\"437\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.administrateur_independant_membre_du_comite_d_3\" width=\"435\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.administrateur_independant_membre_du_comite_d\"><strong> Independent director, member du Comité d’audit, expert en risk management, digital transformation and cybersecurity</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_senior_manager_dans_un_cabinet_de_\">Aujourd’hui, Senior Manager in a firm de conseil traitant of the risk management, fraude and corruption. Looking back in time, in a context régulé (Solvabilité 2), he served as Director and Chairman du Comité d’audit d’une company de Prévoyance dont he led la cession . Dans une company industrial du CAC40, he has led un shared service center, été internal auditor and chef de projet d’an operation de merger and acquisition. Au sein d’une grande company American, and avant, dans a major group French des telecoms, he served as internal auditor.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.a_loccasion_de_ses_nombreuses_missions_il_a_a\">A l’occasion de his/her numerous assignments, he has acquired :</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.une_profonde_expertise_en_systeme_dinformatio\">– Une profonde expertise en système d’information and digital transformation,</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.une_experience_internationale_tres_etendue_un\">– Une experience international très extensive : about thirty countries, on the 5 continents, with a prédominance pour l’Afrique where he a also travaillé 2 years as coopérant (Kenya) for the compte d’une agence de l’ONU</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.une_connaissance_de_secteurs_dactivite_tres_v\">– Une knowledge of secteurs d’activité très varied, in particular : l’industrie, le BTP, les telecommunications, l’environnement, l’énergie, la Défense, la recherche, les assurances, la gestion d’actifs.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.diplome_de_lessec_et_de_telecom_paris_anglais\">Graduate de l’ESSEC and de Télécom Paris, fluent English, Member de l’IFA d’Audit. Ref 732</p>\n</td></tr></tbody></table>\n<p align=\"left\"> </p>",
    "administrateur_independant_membre_du_comite_d_3": "<p data-i18n=\"page_candidats_mandataires_sociaux.administrateur_independant_membre_du_comite_d\"><strong> Independent director, member du Comité d’audit, expert en risk management, digital transformation and cybersecurity</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_senior_manager_dans_un_cabinet_de_\">Aujourd’hui, Senior Manager in a firm de conseil traitant of the risk management, fraude and corruption. Looking back in time, in a context régulé (Solvabilité 2), he served as Director and Chairman du Comité d’audit d’une company de Prévoyance dont he led la cession . Dans une company industrial du CAC40, he has led un shared service center, été internal auditor and chef de projet d’an operation de merger and acquisition. Au sein d’une grande company American, and avant, dans a major group French des telecoms, he served as internal auditor.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.a_loccasion_de_ses_nombreuses_missions_il_a_a\">A l’occasion de his/her numerous assignments, he has acquired :</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.une_profonde_expertise_en_systeme_dinformatio\">– Une profonde expertise en système d’information and digital transformation,</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.une_experience_internationale_tres_etendue_un\">– Une experience international très extensive : about thirty countries, on the 5 continents, with a prédominance pour l’Afrique where he a also travaillé 2 years as coopérant (Kenya) for the compte d’une agence de l’ONU</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.une_connaissance_de_secteurs_dactivite_tres_v\">– Une knowledge of secteurs d’activité très varied, in particular : l’industrie, le BTP, les telecommunications, l’environnement, l’énergie, la Défense, la recherche, les assurances, la gestion d’actifs.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.diplome_de_lessec_et_de_telecom_paris_anglais\">Graduate de l’ESSEC and de Télécom Paris, fluent English, Member de l’IFA d’Audit. Ref 732</p>",
    "non_executive_director_in_european_companies__2": "<div align=\"center\"> </div> <table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td><b><span style=\"font-size: small;\"> </span></b><strong>Non Executive Director in European companies and family offices with a focus and presence in Asia.</strong></td></tr></tbody></table>",
    "non_executive_director_in_european_companies__3": "<p><b><span style=\"font-size: small;\"> </span></b><strong>Non Executive Director in European companies and family offices with a focus and presence in Asia.</strong></p>",
    "industries_a_destination_du_btp_securite_fran_2": "<div align=\"center\"> </div>\n<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.industries_a_destination_du_btp_securite_fran_3\" height=\"93\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.industries_a_destination_du_btp_securite_fran\"><b><span style=\"font-size: small;\"> Industries à destination du BTP /sécurité (France, Pays-Bas Egypte)</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_ingenieur_et_science_po_a_dans_le\"><span style=\"font-size: small;\">The candidate, engineer and Science-Po a in doMaynes and les pays mentionnés above-mentioned une experience de Chairman and d’director</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_871\"><span style=\"font-size: small;\">Ref: 871</span></p>\n</td></tr></tbody></table>",
    "industries_a_destination_du_btp_securite_fran_3": "<p data-i18n=\"page_candidats_mandataires_sociaux.industries_a_destination_du_btp_securite_fran\"><b><span style=\"font-size: small;\"> Industries à destination du BTP /sécurité (France, Pays-Bas Egypte)</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_ingenieur_et_science_po_a_dans_le\"><span style=\"font-size: small;\">The candidate, engineer and Science-Po a in doMaynes and les pays mentionnés above-mentioned une experience de Chairman and d’director</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_871\"><span style=\"font-size: small;\">Ref: 871</span></p>",
    "candidat_a_un_poste_dadministrateur_independa_4": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr align=\"left\"><td data-i18n=\"page_candidats_mandataires_sociaux.candidat_a_un_poste_dadministrateur_independa_5\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidat_a_un_poste_dadministrateur_independa\"><strong> Candidate in a position d’independent director Long and extensive experience de DG PME industrial familiale Subsidiaries Europe and Asie, Company Director du service sector</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ingenieur_43_ans_de_carriere_industrielle_don\">Engineer, 43 years of industrial career, dont 13 en production, puis 30 en Senior Management and Présidence d’une PME familiale industrial (CA 40 M€), secteur mécanique and métallurgie.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.creation_et_presidence_de_filiales_en_europe_\">Création and Présidence de subsidiaries in Europe, Chine and Inde. Développement d’alliances and réseaux international. Forte experience commerciale and managériale in Europe, Moyen Orient and Asie.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.23_ans_president_de_conseil_de_surveillance_e\">23 years Chairman de Supervisory Board en tant qu’independent director of two companies du service sector : édition &amp; multimedia (2 M€), restauration &amp; séminaires (5 M€).</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.experience_en_evaluation_acquisition_et_integ\">Experience en évaluation, acquisition and intégration de companies and of issues de governance, transmission, mutation d’shareholdings.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.connaissance_de_lenseignement_superieur_10_an\">Knowledge of l’Higher Education : 10 years Chairman d’un Advisory Board. Anglais and Allemand .</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_544\" style=\"font-size: 12px; font-weight: normal;\"><span style=\"font-size: small;\">Ref: 544</span></p>\n</td></tr></tbody></table>",
    "candidat_a_un_poste_dadministrateur_independa_5": "<p data-i18n=\"page_candidats_mandataires_sociaux.candidat_a_un_poste_dadministrateur_independa\"><strong> Candidate in a position d’independent director Long and extensive experience de DG PME industrial familiale Subsidiaries Europe and Asie, Company Director du service sector</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ingenieur_43_ans_de_carriere_industrielle_don\">Engineer, 43 years of industrial career, dont 13 en production, puis 30 en Senior Management and Présidence d’une PME familiale industrial (CA 40 M€), secteur mécanique and métallurgie.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.creation_et_presidence_de_filiales_en_europe_\">Création and Présidence de subsidiaries in Europe, Chine and Inde. Développement d’alliances and réseaux international. Forte experience commerciale and managériale in Europe, Moyen Orient and Asie.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.23_ans_president_de_conseil_de_surveillance_e\">23 years Chairman de Supervisory Board en tant qu’independent director of two companies du service sector : édition &amp; multimedia (2 M€), restauration &amp; séminaires (5 M€).</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.experience_en_evaluation_acquisition_et_integ\">Experience en évaluation, acquisition and intégration de companies and of issues de governance, transmission, mutation d’shareholdings.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.connaissance_de_lenseignement_superieur_10_an\">Knowledge of l’Higher Education : 10 years Chairman d’un Advisory Board. Anglais and Allemand .</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_544\" style=\"font-size: 12px; font-weight: normal;\"><span style=\"font-size: small;\">Ref: 544</span></p>",
    "administrateur_independant_grande_experience__2": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr align=\"left\"><td data-i18n=\"page_candidats_mandataires_sociaux.administrateur_independant_grande_experience__3\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.administrateur_independant_grande_experience_\" style=\"font-size: 12px; font-weight: bold;\"><strong>Independent director, extensive experience en audit</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_ingenieur_commercial_dhec_liege_a\">The candidate, business graduate d’HEC Liège, has held for 25 years in the capacity of Statutory Auditor and d’Chartered Accountant in Belgium and au Grand-Duché de Luxembourg.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.certifie_comme_administrateur_de_societes_ifa\">Certified as Company Director (IFA/SC.PO) and en strategy of the risk management CEFAR/AMRAE. Member des Instituts French and Luxembourg des directors.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.fort_de_son_experience_internationale_au_sein\">Building on son experience international within cabinets d’audit anglo-saxons for companies commerciales, industrial and financières (of medium size), he is devenu entrepreneur by the création and le développement of his/her propres cabinets d’accounting firm, de company domiciliation and d’audit (affilié à a network international, Kreston).</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.son_parcours_professionnel_lui_a_fait_connait\">His/her career path professional lui a fait connaître des secteurs d’activité très varied and in particular le BTP and la wealth management, structures of various sizes différentes, with enjeux and des modèles de business à divers stades de développement. Il has participated à of very nombreuses missions de restructurings both in France qu’au Luxembourg.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.de_par_sa_nationalite_italienne_et_son_parcou\">De par sa nationalité Italian, and his/her career path European, he is thoroughly familiar with in depth les cultures French, Italian and English and has mastered the languages associées.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_il_est_administrateur_de_societes_\">Aujourd’hui, he is company director Luxembourgeoises thus qu’internal auditor within financial structures under Luxembourg regulation.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_532\" style=\"font-size: 12px; font-weight: normal;\"><span style=\"font-size: small;\">Ref: 532</span></p>\n</td></tr></tbody></table>",
    "administrateur_independant_grande_experience__3": "<p data-i18n=\"page_candidats_mandataires_sociaux.administrateur_independant_grande_experience_\" style=\"font-size: 12px; font-weight: bold;\"><strong>Independent director, extensive experience en audit</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_ingenieur_commercial_dhec_liege_a\">The candidate, business graduate d’HEC Liège, has held for 25 years in the capacity of Statutory Auditor and d’Chartered Accountant in Belgium and au Grand-Duché de Luxembourg.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.certifie_comme_administrateur_de_societes_ifa\">Certified as Company Director (IFA/SC.PO) and en strategy of the risk management CEFAR/AMRAE. Member des Instituts French and Luxembourg des directors.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.fort_de_son_experience_internationale_au_sein\">Building on son experience international within cabinets d’audit anglo-saxons for companies commerciales, industrial and financières (of medium size), he is devenu entrepreneur by the création and le développement of his/her propres cabinets d’accounting firm, de company domiciliation and d’audit (affilié à a network international, Kreston).</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.son_parcours_professionnel_lui_a_fait_connait\">His/her career path professional lui a fait connaître des secteurs d’activité très varied and in particular le BTP and la wealth management, structures of various sizes différentes, with enjeux and des modèles de business à divers stades de développement. Il has participated à of very nombreuses missions de restructurings both in France qu’au Luxembourg.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.de_par_sa_nationalite_italienne_et_son_parcou\">De par sa nationalité Italian, and his/her career path European, he is thoroughly familiar with in depth les cultures French, Italian and English and has mastered the languages associées.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_il_est_administrateur_de_societes_\">Aujourd’hui, he is company director Luxembourgeoises thus qu’internal auditor within financial structures under Luxembourg regulation.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_532\" style=\"font-size: 12px; font-weight: normal;\"><span style=\"font-size: small;\">Ref: 532</span></p>",
    "candidat_a_un_poste_dadministrateur_independa_6": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr align=\"left\"><td data-i18n=\"page_candidats_mandataires_sociaux.candidat_a_un_poste_dadministrateur_independa_7\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidat_a_un_poste_dadministrateur_independa_2\" style=\"font-size: 12px; font-weight: bold;\"><b>Candidate in a position d’independent director,</b> long experience de Dirigeant de PME/ETI including à l’international dont Extrême Orient</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.25_ans_de_direction_generale_de_pme_eti_indus\" style=\"font-size: 12px; font-weight: normal;\">– 25 years of Senior Management de PME / ETI industrial de 10/50/120 millions € de CA, multi sites and multi pays – Secteurs industrial : composite materials, aerospace coatings, imprimerie, plastic packaging, wood processing, pièces d’équipements pour l’industrie and la filière oil and gaz. – Types d’shareholdings : groupes listed French and étrangers, groupes familiaux, companies sous LBO. – Experience en développement, gestion, restructuring, insolvency proceedings, reprise sous LBO and external growth. <span style=\"font-size: smaller;\">– A travaillé in Europe, Inde, Iran, Chine, Afrique du Sud. Connaissance du Grand Export pour</span> y avoir implanté des subsidiaries industrial. – Member IFA, APIA – Engineer UTC, Master of Sciences du Cranfield Institute of Technology, MBA du Groupe HEC – Fluent English</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_678\" style=\"font-size: 12px; font-weight: bold;\"><span style=\"font-size: small;\">Ref: 678</span></p>\n</td></tr></tbody></table>\n<p style=\"font-size: 12px; font-weight: bold;\"> </p>",
    "candidat_a_un_poste_dadministrateur_independa_7": "<p data-i18n=\"page_candidats_mandataires_sociaux.candidat_a_un_poste_dadministrateur_independa_2\" style=\"font-size: 12px; font-weight: bold;\"><b>Candidate in a position d’independent director,</b> long experience de Dirigeant de PME/ETI including à l’international dont Extrême Orient</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.25_ans_de_direction_generale_de_pme_eti_indus\" style=\"font-size: 12px; font-weight: normal;\">– 25 years of Senior Management de PME / ETI industrial de 10/50/120 millions € de CA, multi sites and multi pays – Secteurs industrial : composite materials, aerospace coatings, imprimerie, plastic packaging, wood processing, pièces d’équipements pour l’industrie and la filière oil and gaz. – Types d’shareholdings : groupes listed French and étrangers, groupes familiaux, companies sous LBO. – Experience en développement, gestion, restructuring, insolvency proceedings, reprise sous LBO and external growth. <span style=\"font-size: smaller;\">– A travaillé in Europe, Inde, Iran, Chine, Afrique du Sud. Connaissance du Grand Export pour</span> y avoir implanté des subsidiaries industrial. – Member IFA, APIA – Engineer UTC, Master of Sciences du Cranfield Institute of Technology, MBA du Groupe HEC – Fluent English</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_678\" style=\"font-size: 12px; font-weight: bold;\"><span style=\"font-size: small;\">Ref: 678</span></p>",
    "candidat_a_un_poste_dadministrateur_independa_8": "<table border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidat_a_un_poste_dadministrateur_independa_9\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidat_a_un_poste_dadministrateur_independa_3\"><b>Candidate in a position d’independent director, (Comité d’Audit or de Rémunérations). Dans plusieurs secteurs, extensive experience of the Finance and of the Direction Opérationnelles d’Entreprise. </b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.dote_dune_triple_formation_mba_americain_inge\">Doté d’une triple formation (MBA American, Engineer, Economics), the candidate a a position d’independent director, after serving as consultant junior dans deux cabinets renommés, has carried out sa career in subsidiaries françaises of two groupes international majeurs , l’un American, puis l’autre German. Pour the latter, il also travaillé within la Mayson mère in Germany. He has rich experience moreover de 20 years of Finance Department extensive (finances, accounting, taxation, legal and IT) in environments international. Dans cette fonction, he has participated, both in France qu’à l’étranger, à of numerous opérations de merger and acquisition and has served on dans plus of ten supervisory boards or d’administration de subsidiaries of groups mentioned above. Mays, l’originalité de his/her career path tient en ce qu’il a also été CEO  » terrain « , in particular dans of operations successful de turnaround moreoverieurs companies appartenant à différents doMaynes. Les secteurs économiques where a Consehe could benefit from his/her experience englobent notably la chemicals, la pharmaceuticals, l’agri-food, les flavours and fragrances as well as l’real estate. Trilingual French/English/German</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_503\"><span style=\"font-size: small;\">Ref: 503</span></p>\n</td></tr></tbody></table>",
    "candidat_a_un_poste_dadministrateur_independa_9": "<p data-i18n=\"page_candidats_mandataires_sociaux.candidat_a_un_poste_dadministrateur_independa_3\"><b>Candidate in a position d’independent director, (Comité d’Audit or de Rémunérations). Dans plusieurs secteurs, extensive experience of the Finance and of the Direction Opérationnelles d’Entreprise. </b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.dote_dune_triple_formation_mba_americain_inge\">Doté d’une triple formation (MBA American, Engineer, Economics), the candidate a a position d’independent director, after serving as consultant junior dans deux cabinets renommés, has carried out sa career in subsidiaries françaises of two groupes international majeurs , l’un American, puis l’autre German. Pour the latter, il also travaillé within la Mayson mère in Germany. He has rich experience moreover de 20 years of Finance Department extensive (finances, accounting, taxation, legal and IT) in environments international. Dans cette fonction, he has participated, both in France qu’à l’étranger, à of numerous opérations de merger and acquisition and has served on dans plus of ten supervisory boards or d’administration de subsidiaries of groups mentioned above. Mays, l’originalité de his/her career path tient en ce qu’il a also été CEO  » terrain « , in particular dans of operations successful de turnaround moreoverieurs companies appartenant à différents doMaynes. Les secteurs économiques where a Consehe could benefit from his/her experience englobent notably la chemicals, la pharmaceuticals, l’agri-food, les flavours and fragrances as well as l’real estate. Trilingual French/English/German</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_503\"><span style=\"font-size: small;\">Ref: 503</span></p>",
    "industrie_pharmaceutiquele_candidat_docteur_e": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.industrie_pharmaceutiquele_candidat_docteur_e_2\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.industrie_pharmaceutique\"><span style=\"font-size: small;\"><b> Pharmaceutical Industry</b></span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_docteur_en_pharmacie_aihp_a_une_e\"><span style=\"font-size: small;\">The candidate, Docteur en Pharmaceuticals, AIHP, a une experience des travaux de recherche en hopital and de postes de R&amp;D Management in companies pharmaceutiques including une large-scale with subsidiaries in the USA.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.createur_dune_start_up_de_conseil_en_strategi\"><span style=\"font-size: small;\">Créateur d’a start-up de conseil en strategy R &amp; D pharmaceutique and co-fondateur d’une autre in conception of new antiviral drugs.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_561\"><span style=\"font-size: small;\">Ref: 561</span></p>\n</td></tr></tbody></table>",
    "industrie_pharmaceutiquele_candidat_docteur_e_2": "<p data-i18n=\"page_candidats_mandataires_sociaux.industrie_pharmaceutique\"><span style=\"font-size: small;\"><b> Pharmaceutical Industry</b></span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_docteur_en_pharmacie_aihp_a_une_e\"><span style=\"font-size: small;\">The candidate, Docteur en Pharmaceuticals, AIHP, a une experience des travaux de recherche en hopital and de postes de R&amp;D Management in companies pharmaceutiques including une large-scale with subsidiaries in the USA.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.createur_dune_start_up_de_conseil_en_strategi\"><span style=\"font-size: small;\">Créateur d’a start-up de conseil en strategy R &amp; D pharmaceutique and co-fondateur d’une autre in conception of new antiviral drugs.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_561\"><span style=\"font-size: small;\">Ref: 561</span></p>",
    "administrateur_independant_electronique_aeron": "<table border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.administrateur_independant_electronique_aeron_2\">\n<div align=\"left\"><span style=\"font-size: small;\"><b>Independent Director, Electronique, Aerospace, Défense and Sécurité. </b> </span></div>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_de_formation_x_et_supaero_ensae_c\"><span style=\"color: #000000; font-size: small;\">The candidate by training X and Sup’Aéro (ENSAé), complemented by Management strategic (IFG-ICG), has held des senior positions within la Senior Management de l’Armement du Ministry of Defence. D’une extensive experience en defence electronics, il is one of the few hauts fonctionnaires Maytrisant le secteur de l’armement French and European in the doMayne des high technologies. Holder of the certificat d’company director (IFA)</span>.</p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_462\"><span style=\"font-size: small;\">Ref: 462</span></p>\n</td></tr></tbody></table>",
    "administrateur_independant_electronique_aeron_2": "<div align=\"left\"><span style=\"font-size: small;\"><b>Independent Director, Electronique, Aerospace, Défense and Sécurité. </b> </span></div>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_de_formation_x_et_supaero_ensae_c\"><span style=\"color: #000000; font-size: small;\">The candidate by training X and Sup’Aéro (ENSAé), complemented by Management strategic (IFG-ICG), has held des senior positions within la Senior Management de l’Armement du Ministry of Defence. D’une extensive experience en defence electronics, il is one of the few hauts fonctionnaires Maytrisant le secteur de l’armement French and European in the doMayne des high technologies. Holder of the certificat d’company director (IFA)</span>.</p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_462\"><span style=\"font-size: small;\">Ref: 462</span></p>",
    "equipements_et_appareillages_industriels_ener_2": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.equipements_et_appareillages_industriels_ener_3\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.equipements_et_appareillages_industriels_ener\"><b><span style=\"font-size: small;\"> </span></b><span style=\"font-size: small;\"><b>Equipements and appareillages industrial (Energie, Transport, High Technology)</b></span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_ingenieur_mba_bilingue_francais_a\"><span style=\"font-size: small;\">The candidate Engineer + MBA bilingual French/English a une experience very advanced: – de l’Asie /Pacifique avec 7 years of résidence au Japon and la présidence de companies both in Japan qu’in China, Corée, Taiwan, Thailande,Indes, Australie. – De l’Europe and du Commonwealth avec 6 years of résidence in London where été ajoutés of positions d’directors sur ces zones à ceux dejhas helds in Asia.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_261\"><span style=\"font-size: small;\">Ref: 261</span></p>\n</td></tr></tbody></table>",
    "equipements_et_appareillages_industriels_ener_3": "<p data-i18n=\"page_candidats_mandataires_sociaux.equipements_et_appareillages_industriels_ener\"><b><span style=\"font-size: small;\"> </span></b><span style=\"font-size: small;\"><b>Equipements and appareillages industrial (Energie, Transport, High Technology)</b></span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_ingenieur_mba_bilingue_francais_a\"><span style=\"font-size: small;\">The candidate Engineer + MBA bilingual French/English a une experience very advanced: – de l’Asie /Pacifique avec 7 years of résidence au Japon and la présidence de companies both in Japan qu’in China, Corée, Taiwan, Thailande,Indes, Australie. – De l’Europe and du Commonwealth avec 6 years of résidence in London where été ajoutés of positions d’directors sur ces zones à ceux dejhas helds in Asia.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_261\"><span style=\"font-size: small;\">Ref: 261</span></p>",
    "aviation_aeronautique_spatial_defense_securit_2": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.aviation_aeronautique_spatial_defense_securit_3\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.aviation_aeronautique_spatial_defense_securit\"><span style=\"font-size: small;\"><b> </b></span><span style=\"font-size: small;\">.</span><b><span style=\"font-size: small;\">Aviation, Aerospace, Spatial, Défense &amp; Sécurite.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_de_formation_economique_commerce_\"><span style=\"font-size: small;\">The candidate by training Economique &amp; International Trade (Londres and Paris) complemented by Management (INSEAD) and Défense (IHEDN) a une extensive experience international through la World Bank (Amériques and Asie) puis l’industrie Aerospace/spatiale/défense/sécurite Francaise, Européenne and Américaine for thequelles he has held des very senior operational positions and « Corporate ». </span><span style=\"font-size: small;\">Il partage his/her residence entre Washington and Paris and est particulièrement actif in the sectors indiqués sur l’Europe, les Amériques and le Moyen Orient.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_513\"><span style=\"font-size: small;\">Ref: 513 </span></p>\n</td></tr></tbody></table>",
    "aviation_aeronautique_spatial_defense_securit_3": "<p data-i18n=\"page_candidats_mandataires_sociaux.aviation_aeronautique_spatial_defense_securit\"><span style=\"font-size: small;\"><b> </b></span><span style=\"font-size: small;\">.</span><b><span style=\"font-size: small;\">Aviation, Aerospace, Spatial, Défense &amp; Sécurite.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_de_formation_economique_commerce_\"><span style=\"font-size: small;\">The candidate by training Economique &amp; International Trade (Londres and Paris) complemented by Management (INSEAD) and Défense (IHEDN) a une extensive experience international through la World Bank (Amériques and Asie) puis l’industrie Aerospace/spatiale/défense/sécurite Francaise, Européenne and Américaine for thequelles he has held des very senior operational positions and « Corporate ». </span><span style=\"font-size: small;\">Il partage his/her residence entre Washington and Paris and est particulièrement actif in the sectors indiqués sur l’Europe, les Amériques and le Moyen Orient.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_513\"><span style=\"font-size: small;\">Ref: 513 </span></p>",
    "administrateur_de_filiales_anglaises_de_socie_2": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.administrateur_de_filiales_anglaises_de_socie_3\" height=\"158\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.administrateur_de_filiales_anglaises_de_socie\"><b><span style=\"font-size: small;\"> Director de subsidiaries anglaises de companies françaises and réciproquement</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_a_30_ans_dexperience_dans_quelque\"><span style=\"color: #000000; font-size: small;\">The candidate a 30 years d’experience dans quelques-unes des plus grandes companies du Royaume-Uni, de l’Allemagne, des Etats-Unis and des Pays-Bas. Financier by training, habitué aux problématiques des états-major also bien qu’à celles of operations, son expertise concerne des companies also variées that the marine, la chemicals, le sustainable development and l’real estate. D’origine English, Mays long established in France, in Paris and in région rhénane, il would be happy de build bridges between subsidiaries françaises and leurs Maysons-mère britanniques/allemandes or vice versa. </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_203\"><span style=\"color: #000000; font-size: small;\">Ref: 203</span></p>\n</td></tr></tbody></table>",
    "administrateur_de_filiales_anglaises_de_socie_3": "<p data-i18n=\"page_candidats_mandataires_sociaux.administrateur_de_filiales_anglaises_de_socie\"><b><span style=\"font-size: small;\"> Director de subsidiaries anglaises de companies françaises and réciproquement</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_a_30_ans_dexperience_dans_quelque\"><span style=\"color: #000000; font-size: small;\">The candidate a 30 years d’experience dans quelques-unes des plus grandes companies du Royaume-Uni, de l’Allemagne, des Etats-Unis and des Pays-Bas. Financier by training, habitué aux problématiques des états-major also bien qu’à celles of operations, son expertise concerne des companies also variées that the marine, la chemicals, le sustainable development and l’real estate. D’origine English, Mays long established in France, in Paris and in région rhénane, il would be happy de build bridges between subsidiaries françaises and leurs Maysons-mère britanniques/allemandes or vice versa. </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_203\"><span style=\"color: #000000; font-size: small;\">Ref: 203</span></p>",
    "le_candidat_de_formation_x_et_insead_a_une_la_2": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_de_formation_x_et_insead_a_une_la_3\" height=\"121\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_de_formation_x_et_insead_a_une_la\"><span style=\"font-size: small;\"><b>The candidate by training X and INSEAD a une extensive experience des secteurs infrastructures, aménagement, bâtiment, environnement, sustainable development, ingénierie, services publics, concessions and partenariats publics privés. </b> Dans these sectors, il has held des management positions operational including on chantiers international large-scale (Algérie, Chine). Il été director within Conseils d’Administration and de Surveillance of type très varied and PDG d’une subsidiary d’one of the leaders de l’ingénierie and du conseil. Il vient de recently créer his/her own company de conseil in order to provide the benefit of of his experience des companies de these sectors, in particular through mandates d’independent director </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_508\"><span style=\"color: #000000; font-size: small;\">Ref: 508</span></p>\n</td></tr></tbody></table>",
    "le_candidat_de_formation_x_et_insead_a_une_la_3": "<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_de_formation_x_et_insead_a_une_la\"><span style=\"font-size: small;\"><b>The candidate by training X and INSEAD a une extensive experience des secteurs infrastructures, aménagement, bâtiment, environnement, sustainable development, ingénierie, services publics, concessions and partenariats publics privés. </b> Dans these sectors, il has held des management positions operational including on chantiers international large-scale (Algérie, Chine). Il été director within Conseils d’Administration and de Surveillance of type très varied and PDG d’une subsidiary d’one of the leaders de l’ingénierie and du conseil. Il vient de recently créer his/her own company de conseil in order to provide the benefit of of his experience des companies de these sectors, in particular through mandates d’independent director </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_508\"><span style=\"color: #000000; font-size: small;\">Ref: 508</span></p>",
    "edition_de_logicielle_candidat_expert_comptab": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.edition_de_logicielle_candidat_expert_comptab_2\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.edition_de_logiciel\"><b><span style=\"font-size: small;\"> Edition de logiciel</span></b></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_expert_comptable_a_une_large_expe\"><span style=\"font-size: small;\">Le candidat, Expert comptable a une large expérience de direction financière, secrétariat général and d’administrateur de </span><span style=\"font-size: small;\">SSII and de sociétés d’édition de logiciels</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_909\"><span style=\"font-size: small;\">Ref: 909</span></p>\n</td></tr></tbody></table>",
    "edition_de_logicielle_candidat_expert_comptab_2": "<p data-i18n=\"page_candidats_mandataires_sociaux.edition_de_logiciel\"><b><span style=\"font-size: small;\"> Edition de logiciel</span></b></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_expert_comptable_a_une_large_expe\"><span style=\"font-size: small;\">Le candidat, Expert comptable a une large expérience de direction financière, secrétariat général and d’administrateur de </span><span style=\"font-size: small;\">SSII and de sociétés d’édition de logiciels</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_909\"><span style=\"font-size: small;\">Ref: 909</span></p>",
    "genie_medical_france_et_usaapres_avoir_ete_au": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.genie_medical_france_et_usaapres_avoir_ete_au_2\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.genie_medical_france_et_usa\"><b> <span style=\"font-family: Times New Roman, Times, serif; font-size: small;\">Medical Engineering France and USA</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_avoir_ete_aux_usa_manager_de_projets_ma\"><span style=\"font-size: small;\">After serving as in the USA Manager de projets marketing d’une subsidiary d’une grande company pharmaceutique US, puis for 4 years International Marketing Director d’une company US en Medical Engineering, he founded in France a start-up for the medical assessments. He was the PDG pilotera un développement successful. Société opérant in Europe and in the USA, listed on Euronext. Grand experience of contacts de haut niveau and of transfers de technologie (USA and Europe) with the milieux scientifiques and financiers. Education: Master en Management de l’ ISG</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_104\"><span style=\"font-size: small;\">Ref: 104</span></p>\n</td></tr></tbody></table>",
    "genie_medical_france_et_usaapres_avoir_ete_au_2": "<p data-i18n=\"page_candidats_mandataires_sociaux.genie_medical_france_et_usa\"><b> <span style=\"font-family: Times New Roman, Times, serif; font-size: small;\">Medical Engineering France and USA</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_avoir_ete_aux_usa_manager_de_projets_ma\"><span style=\"font-size: small;\">After serving as in the USA Manager de projets marketing d’une subsidiary d’une grande company pharmaceutique US, puis for 4 years International Marketing Director d’une company US en Medical Engineering, he founded in France a start-up for the medical assessments. He was the PDG pilotera un développement successful. Société opérant in Europe and in the USA, listed on Euronext. Grand experience of contacts de haut niveau and of transfers de technologie (USA and Europe) with the milieux scientifiques and financiers. Education: Master en Management de l’ ISG</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_104\"><span style=\"font-size: small;\">Ref: 104</span></p>",
    "pharmacie_humaine_otc_et_sante_animalele_cand": "<table border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.pharmacie_humaine_otc_et_sante_animalele_cand_2\" valign=\"top\">\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.pharmacie_humaine_otc_et_sante_animale\"><b><span style=\"font-family: Times New Roman, Times, serif; font-size: small;\">Human pharmacy (OTC) and Animal health</span></b></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_veterinaire_avec_une_formation_de\"><span style=\"font-size: small;\">The candidate, vétérinaire with a formation de gestionnaire acquise à l’ ESSEC is an experienced executive expérimenté within grands groupes, in particular American, both as opérationel (DG or Business Unit) que fonctionnel (Marketing) within subsidiaries commercialisant des produits for the animal health or huMayne (OTC). Experience d’director du Syndicat de l’Industrie du Médicament vétérinaire. Knowledge of Russian.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_115\"><span style=\"font-size: small;\">Ref: 115</span></p>\n</td></tr></tbody></table>",
    "pharmacie_humaine_otc_et_sante_animalele_cand_2": "<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.pharmacie_humaine_otc_et_sante_animale\"><b><span style=\"font-family: Times New Roman, Times, serif; font-size: small;\">Human pharmacy (OTC) and Animal health</span></b></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_veterinaire_avec_une_formation_de\"><span style=\"font-size: small;\">The candidate, vétérinaire with a formation de gestionnaire acquise à l’ ESSEC is an experienced executive expérimenté within grands groupes, in particular American, both as opérationel (DG or Business Unit) que fonctionnel (Marketing) within subsidiaries commercialisant des produits for the animal health or huMayne (OTC). Experience d’director du Syndicat de l’Industrie du Médicament vétérinaire. Knowledge of Russian.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_115\"><span style=\"font-size: small;\">Ref: 115</span></p>",
    "equipements_pour_l_energie_le_petrole_et_le_g_2": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.equipements_pour_l_energie_le_petrole_et_le_g_3\" valign=\"middle\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.equipements_pour_l_energie_le_petrole_et_le_g\"><span style=\"font-size: small;\"><b> Equipements pour l’ énergie le oil and le gaz</b></span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_ingenieur_et_mba_hec_isa_a_une_ex\"><span style=\"font-size: small;\">The candidate, engineer and MBA HEC-ISA a une experience d’director in several companies du doMayne above-mentioned.</span></p>\n</td></tr></tbody></table>",
    "equipements_pour_l_energie_le_petrole_et_le_g_3": "<p data-i18n=\"page_candidats_mandataires_sociaux.equipements_pour_l_energie_le_petrole_et_le_g\"><span style=\"font-size: small;\"><b> Equipements pour l’ énergie le oil and le gaz</b></span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_ingenieur_et_mba_hec_isa_a_une_ex\"><span style=\"font-size: small;\">The candidate, engineer and MBA HEC-ISA a une experience d’director in several companies du doMayne above-mentioned.</span></p>",
    "experience_tres_etendue_produits_alimentaires_2": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"97%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.experience_tres_etendue_produits_alimentaires_3\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.experience_tres_etendue_produits_alimentaires\"><b><span style=\"font-size: small;\">Experience très extensive (Produits alimentaires de consumer goods) France and International durant over 15 years</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_a_des_postes_dadministrateur_est_\"><span style=\"font-size: small;\"> The candidate in positions d’director est issu d’une Business School. He served as PDG, Director and Dirigeant Opérationnel de subsidiaries in several pays Européens and in the USA. Il has carried out operations of restructuring complexes. Dans le cadre de his/her responsibilities, il has raised of funds auprès of large investors en venture capital and mené assignments in conseil within the framework d’ opérations de Fusions &amp; Acquisitions (multinationales and start up).</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_845\"><span style=\"font-size: small;\">Ref: 845</span></p>\n</td></tr></tbody></table>",
    "experience_tres_etendue_produits_alimentaires_3": "<p data-i18n=\"page_candidats_mandataires_sociaux.experience_tres_etendue_produits_alimentaires\"><b><span style=\"font-size: small;\">Experience très extensive (Produits alimentaires de consumer goods) France and International durant over 15 years</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_a_des_postes_dadministrateur_est_\"><span style=\"font-size: small;\"> The candidate in positions d’director est issu d’une Business School. He served as PDG, Director and Dirigeant Opérationnel de subsidiaries in several pays Européens and in the USA. Il has carried out operations of restructuring complexes. Dans le cadre de his/her responsibilities, il has raised of funds auprès of large investors en venture capital and mené assignments in conseil within the framework d’ opérations de Fusions &amp; Acquisitions (multinationales and start up).</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_845\"><span style=\"font-size: small;\">Ref: 845</span></p>",
    "experience_internationale_tres_etendue_high_t_2": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.experience_internationale_tres_etendue_high_t_3\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.experience_internationale_tres_etendue_high_t\"><b> </b><span style=\"font-size: small;\"><b><span style=\"font-size: small;\">Experience international très extensive (High Tech and IT) </span></b> </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_a_passe_plus_de_30_ans_dans_des_e\"><span style=\"font-size: small;\">The candidate has spent over 30 years in environments international dont over 10 years de vie in the USA. I</span><span style=\"font-size: small;\">l has been PDG, Director or dirigeant operational de subsidiaries of large companies d’IT (généraliste, prestataires de service, progiciels) and Vice Chairman d’a start-up (biométrie). Des liabilitys prises in the doMayne du commerce des objets d’arts and de l’real estate ont enrichi his/her vision de l’company. Aujourd’hui, consultant international, il proposes, en devenant independent director, de provide the benefit of des companies of her competence. F</span><span style=\"font-size: small;\">ormation: Engineer Arts and Métiers and INSEAD</span></p>\n</td></tr></tbody></table>",
    "experience_internationale_tres_etendue_high_t_3": "<p data-i18n=\"page_candidats_mandataires_sociaux.experience_internationale_tres_etendue_high_t\"><b> </b><span style=\"font-size: small;\"><b><span style=\"font-size: small;\">Experience international très extensive (High Tech and IT) </span></b> </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_a_passe_plus_de_30_ans_dans_des_e\"><span style=\"font-size: small;\">The candidate has spent over 30 years in environments international dont over 10 years de vie in the USA. I</span><span style=\"font-size: small;\">l has been PDG, Director or dirigeant operational de subsidiaries of large companies d’IT (généraliste, prestataires de service, progiciels) and Vice Chairman d’a start-up (biométrie). Des liabilitys prises in the doMayne du commerce des objets d’arts and de l’real estate ont enrichi his/her vision de l’company. Aujourd’hui, consultant international, il proposes, en devenant independent director, de provide the benefit of des companies of her competence. F</span><span style=\"font-size: small;\">ormation: Engineer Arts and Métiers and INSEAD</span></p>",
    "presse_et_medias_developpement_internationall": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.presse_et_medias_developpement_internationall_2\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.presse_et_medias_developpement_international\"><b><span style=\"font-size: small;\"> Presse and Médias Développement International</span></b></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_aujourdhui_consultant_internation\"><span style=\"font-size: small;\">The candidate, aujourd’hui consultant international, has started comme Director of the Ch. Com. French in a pays nordique, avant de représenter des industries françaises du textile and de l’habillement in instances international. Then, au sein d’a major group de presse/médias French, he was Subsidiary Director au Portugal, International Director among other things in charge ofs montages de JV, Managing Director d’une subsidiary in France, Deputy Director with postes d’directors. Corporate officer potentiel de companies du doMayne presse/médias with a développement international (speaks several languages: Swedish, Portuguese, English and German). Formation Droit, Oriental Languages ( Russian).</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_101\"><span style=\"font-size: small;\">Ref: 101 </span></p>\n</td></tr></tbody></table>",
    "presse_et_medias_developpement_internationall_2": "<p data-i18n=\"page_candidats_mandataires_sociaux.presse_et_medias_developpement_international\"><b><span style=\"font-size: small;\"> Presse and Médias Développement International</span></b></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_aujourdhui_consultant_internation\"><span style=\"font-size: small;\">The candidate, aujourd’hui consultant international, has started comme Director of the Ch. Com. French in a pays nordique, avant de représenter des industries françaises du textile and de l’habillement in instances international. Then, au sein d’a major group de presse/médias French, he was Subsidiary Director au Portugal, International Director among other things in charge ofs montages de JV, Managing Director d’une subsidiary in France, Deputy Director with postes d’directors. Corporate officer potentiel de companies du doMayne presse/médias with a développement international (speaks several languages: Swedish, Portuguese, English and German). Formation Droit, Oriental Languages ( Russian).</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_101\"><span style=\"font-size: small;\">Ref: 101 </span></p>",
    "questions_energetiques_et_gestion_des_risques_2": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.questions_energetiques_et_gestion_des_risques_3\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.questions_energetiques_et_gestion_des_risques\"><b><span style=\"font-size: small;\"> Questions énergétiques and risk management associés</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_a_une_longue_experience_des_affai\"><span style=\"font-size: small;\">The candidate a une long experience des affaires énergétiques (civil engineering specialised and équipements lourds/turbomachines…) and du « risk management » associé. Durant ces dernières années, il a assimilé le statut particulier, les aléas inhérents, les modalités de travail des hauts dirigeants and directors de companies and leur implication accrue in gestion de l’énergie and les risques.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_402\"><span style=\"font-size: small;\">Ref: 402</span></p>\n</td></tr></tbody></table>",
    "questions_energetiques_et_gestion_des_risques_3": "<p data-i18n=\"page_candidats_mandataires_sociaux.questions_energetiques_et_gestion_des_risques\"><b><span style=\"font-size: small;\"> Questions énergétiques and risk management associés</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.le_candidat_a_une_longue_experience_des_affai\"><span style=\"font-size: small;\">The candidate a une long experience des affaires énergétiques (civil engineering specialised and équipements lourds/turbomachines…) and du « risk management » associé. Durant ces dernières années, il a assimilé le statut particulier, les aléas inhérents, les modalités de travail des hauts dirigeants and directors de companies and leur implication accrue in gestion de l’énergie and les risques.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_402\"><span style=\"font-size: small;\">Ref: 402</span></p>",
    "femmes_candidatescandidate_administratrice_in": "<div align=\"center\"><table align=\"center\" border=\"2\" cellpadding=\"0\" cellspacing=\"6\" width=\"100%\"><tbody>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.femmes_candidates\" style=\"text-align: center; color: #f50c10; font-size: 16px; font-weight: bold;\" valign=\"top\">Female Candidates</td></tr>\n<tr><td align=\"right\" data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_grande_2\" style=\"text-align: left;\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_grande_3\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_grande\" style=\"margin: 0cm; margin-bottom: .0001pt;\"><span style=\"font-family: georgia, palatino, serif;\"><b>Candidate independent director : Extensive experience international</b></span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_ecole_des_mines_et_biotechnologi\" style=\"margin: 0cm; margin-bottom: .0001pt;\"><span style=\"font-family: georgia, palatino, serif;\">The candidate ( Ecole des Mines and Biotechnologie au MIT) has held 3 mandates successifs au Supervisory Board d’une ETI familiale de dimension international: organic growth and externe, défis liés à une croissance rapide (manufacturing, supply chain, RH). Plus de 40 years hors de France: USA + différents pays European, in Germany depuis 2000. Conseil en strategy chez Bain, director operational chez Pasteur-Mérieux. Depuis deux ans, mentorat de start-ups auprès de l’accélérateur MassChallenge.</span></p>\n<p align=\"left\"><span style=\"font-size: small;\"><b> </b></span></p>\n</td></tr>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_hotell_3\">\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_hotell\"><span style=\"font-size: small;\"><b>Candidate independent director : Hôtellerie, Restauration, Tourisme; France and Europe</b> Experience pluridisciplinaire acquise au sein d’un groupe hôtelier international coté au CAC 40. Au fil de 30 years, dont 12 years in restauration publique, the candidate a successivement occupé of positions de dirigeante in doMaynes varied : contrôle de gestion, produits, opérations, marketing, audit interne, production, publishing and communication des bureaux de ventes international, finally quant à l’efficacité des coûts marketing &amp; distribution. </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_elle_est_consultante_independante_\"><span style=\"font-size: small;\">Aujourd’hui, she is independent consultant in these doMaynes. Very good knowledge of l’international. Education: Master's in Economics (Paris2), DEA Théories and Politiques monétaires (Paris 2), Executive Doctorate in Business Administration (Paris Dauphine, 2009). Member de l’IFA and Secretary General de l’Association Européenne de Neuroéconomie.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_303\"><span style=\"font-size: small;\">Ref: 303</span></p>\n</td></tr>\n</tbody></table></td></tr>\n &lt;tr&gt;&lt;td align=\"center\" valign=\"top\" height=\"233\"&gt;&lt;table border=\"0\" width=\"95%\" cellspacing=\"3\" cellpadding=\"0\" align=\"center\"&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;\n&lt;p&gt;&lt;b&gt;&lt;span style=\"font-size: small;\"&gt;Consultante experte en strat&amp;eacute;gie and finance d&amp;rsquo;investissement in the sector de l&amp;rsquo;&amp;eacute;nergie and des services publics in France and &amp;agrave; l&amp;rsquo;international&lt;/span&gt;&lt;/b&gt;&lt;/p&gt;\n&lt;p&gt;&lt;span style=\"font-size: small;\"&gt;The candidate a 15 years d&amp;rsquo;exp&amp;eacute;rience in the doMayne above-mentioned. She is director and member du comit&amp;eacute; d&amp;rsquo;audit d&amp;rsquo;une company fran&amp;ccedil;aise cot&amp;eacute;e op&amp;eacute;rant in the doMayne de l&amp;rsquo;&amp;eacute;nergie. Elle has obtained le Certificat d&amp;rsquo;Director de Soci&amp;eacute;t&amp;eacute;s de l&amp;rsquo;Institut Fran&amp;ccedil;ais des Directors and vise un deuxi&amp;egrave;me mandate. Ayant v&amp;eacute;cu and travaill&amp;eacute; &amp;agrave; Londres, &amp;agrave; New-York, and en Am&amp;eacute;rique du Sud, she has bonne ma&amp;icirc;trise des enjeux &amp;agrave; l&amp;rsquo;international. Elle spoke on probl&amp;eacute;matiques in the sector de l&amp;rsquo;&amp;eacute;nergie during missions de conseil en strat&amp;eacute;gie, d&amp;rsquo;analyses financi&amp;egrave;res, de d&amp;eacute;cisions d&amp;rsquo;allocation de capital and d&amp;rsquo;&amp;eacute;valuation d&amp;rsquo;investissements.&lt;/span&gt;&lt;/p&gt;\n&lt;p&gt;&lt;span style=\"font-size: small;\"&gt;She is dipl&amp;ocirc;m&amp;eacute;e de l&amp;rsquo;ESSEC and has obtained la charte CFA (&amp;lsquo;Chartered Financial Analyst&amp;rsquo;).&lt;/span&gt;&lt;/p&gt;\n&lt;p&gt;&lt;span style=\"font-size: small;\"&gt;Ref: 514&lt;/span&gt;&lt;/p&gt;\n&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/td&gt;&lt;/tr&gt; \n<tr><td align=\"right\" data-i18n=\"page_candidats_mandataires_sociaux.candidate_au_poste_dadministratrice_independa_2\" style=\"text-align: left;\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_au_poste_dadministratrice_independa_3\">\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.candidate_au_poste_dadministratrice_independa\"><span style=\"font-size: small;\"><b> </b></span><span style=\"font-weight: bold;\">Candidate au poste d’independent director .</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.docteur_en_economie_la_candidate_beneficie_du\">Docteur en économie , the candidate bénéficie d’une experience professional moreover de 30 years . Ses competences métiers couvrent le secteur banque / finance , le conseil en organisation and strategy , the new technologies and la transformation digitale .</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.membre_des_comites_de_direction_elle_a_assure\">Member des executive committees she has managed avec succès des liabilitys operational (profit center , développement ) au sein d’one of the largest banques mondiales , d’a firm de conseil de premier plan (big four) and d’une company specialised en système d’information listed on CAC 40 . Compte tenu of projects qu’she has carried out and de his/her various functions she is thoroughly familiar with bien la zone Europe ( UK , Bénelux , Hongrie , Espagne ,Italie) , les Etats Unis , l’Inde and le Maroc .</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.membre_du_cercle_des_administrateurs_de_lasso\">Member du Cercle des directors , de l’association des Alumni d’ATOS, she leads also of actions de bénévolat pour V.E.C.V ( Votre Ecole Chez Vous ) association reconnue d’utilité publique and sous contrat avec l’éducation nationale .</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_324\">Ref: 324</p>\n<p align=\"left\"> </p>\n</td></tr></tbody></table></td></tr>\n<tr><td align=\"right\" data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_5\" style=\"text-align: left;\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_6\">\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen\"><span style=\"font-size: small;\"><b> Candidate in a position d’independent director, with good knowledge of le BTP, les services aux companies, la santé, les fonds d’investissement and la communication. </b></span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.apres_avoir_mene_des_travaux_daudit_chez_erns\"><span style=\"font-size: small;\">After having mené des travaux d’audit chez Ernst &amp; Young, the candidate, over the 13 years suivantes, has acquired successivement une experience de Direction d’une unité operational, de Director financier puis de Secretary General au sein d’une une <b>E</b>ntreprise de <b>T</b>aille <b>I</b>ntermédiaire. Cette company opérant in a dur contexte international a traversé des périodes de fortes crises.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ensuite_apres_avoir_ete_secretaire_general_du\"><span style=\"font-size: small;\">Then, after serving as Secretary General d’a significant Cabinet d’Avocats, she created son propre cabinet de conseil mettant ses competences en gestion and finances au service of the strategy, of the governance and de l’organisation de his/her clients.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_membre_de_lifa_est_diplomee_de_l\"><span style=\"font-size: small;\">The candidate, member de l’IFA, est graduate de l’IEP Paris, Eco-fi, d’un DESS de banque-assurance and titulaire d’un master de gestion effectué à Dauphine. »</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_825\"><span style=\"font-size: small;\">Ref: 825 </span></p>\n</td></tr></tbody></table></td></tr>\n<tr align=\"center\"><td data-i18n=\"page_candidats_mandataires_sociaux.woman_european_company_board_readymba_insead_\" style=\"text-align: left;\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.woman_european_company_board_readymba_insead__2\">\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.woman_european_company_board_ready\"><strong>Woman European Company Board ready </strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.mba_insead_certificate_and_diploma_in_company\">MBA INSEAD, Certificate and Diploma in Company Direction from Institute of Directors (IOD London)</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.en_france_creatrice_de_son_propre_cabinet_de_\"><strong>En France</strong>, founder of her own cabinet de recherche and d’études de marché en IT / Digital, développé jusqu’à 150 personnes sur l’Europe puis revendu à un grand du conseil ; then PDG d’a firm d’étude en Information Technology. <strong>Puis in Europe</strong>, chargée du développement d’a major firm de Conseil en RH and après d’un autre en IT. <strong>Then, longue career in the USA</strong> comme Director Exécutif in various positions for the développement d’a major firm international de conseil en management.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.de_retour_en_europe_membre_du_comite_executif\"><strong>De retour in Europe</strong>, member du Comité Exécutif Europe d’a firm renommé de conseil en leadership and recherche de dirigeants</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.cette_large_experience_internationale_vecue_d\">Cette extensive experience international vécue dans 6 pays lui has enabled de connaître of numerous secteurs B to B, whose digital and also la consumer goods. Son relationnel « Business » (INSEAD, IOD, American Chamber of Commerce Zurich) peut être put at the service d’un Board. A noter : Member for 5 years du Board du CAWC, Connections for Abused Women and their Children à Chicago, Chairwoman of the commission Communication</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_304\">Ref: 304</p>\n</td></tr></tbody></table></td></tr>\n<tr><td align=\"right\" data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_7\" style=\"text-align: left;\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_8\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_2\"><b><span style=\"font-size: small;\"> </span></b><strong>Candidate in a position d’independent director</strong> Elle apporte 30 years d’experience déroulées in an environment International de structures publiques/privées and in doMaynes varied comme la recherche, la production, la strategy, la risk management (huMayns, capitaux and sociétaux), le management de projets and of teams, le « mentoring » de Startups. Ses doMaynes clés d’intervention sont l’industrie pharmaceutique and chimique en collaboration étroite and permanente with a tissu de PME locales and international. Building on toutes ces expériences and expertises, elle a la capacité à intervenir dans of numerous industries connexes or complémentaires (équipementiers, cosmetics, agrochimique…). Son intérêt for a développement économique in a sustainable and equitable way est son fil conducteur parce qu’she believes in l’intelligence collective, la co-construction and la collaboration as the foundation of success d’une company and plus largement de notre company. The candidate a une formation de Docteur Engineer en Chimie, she is certified Director par l’EM Lyon.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_299\">Ref 299</p>\n</td></tr></tbody></table></td></tr>\n<tr><td align=\"right\" data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde_5\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde_6\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde\"><b><span style=\"font-size: small;\"> The candidate in a position d’independent director</span></b> <span style=\"font-size: small;\">est aujourd’hui consultante and enseignante en finances à l’Ecole Nationale des Ponts and Chaussées. Elle has obtained un DECS de Comptabilité and un Executive MBA en Management in New York University. Stern Business School. Bilingue French English avec 26 years d’experience comme CFO and Administratif au sein d’companies international (dont in the USA) dans divers secteurs d’activité, in particular les consumer products and le luxe. Très operational and proche du business, she has expertise en strategy, organisation, management and systèmes d’information. Authorized representative d’une fondation d’company and Member du Board de EPWN, she has experienced de l’intérieur le fonctionnement d’un Conseil d’Administration. Member de l’IFA, de Women Corporate Directors and de EPWN</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_302\"><span style=\"font-size: small;\">Ref: 302</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde_7\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde_8\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde_2\"><b><span style=\"font-size: small;\"> The candidate in a position d’independent director Trés extensive experience international en développement d’affaires, Biotechnologies</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_ecole_des_mines_et_biotechnology\"><span style=\"font-size: small;\">The candidate ( Ecole des Mines and Biotechnology au MIT), réside in Germany depuis l’an 2000, Nombreuses années hors de France: USA + différents pays European. Conseil en strategy chez Bain, Director operational chez Pasteur-Mérieux, notably pour an operation de « spin-off » / vente d’une activité. Depuis 8 years, réussit comme independent consultant for the lancement / développement international de start-up (biotechnologie and santé).</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_603\"><span style=\"font-size: small;\">Ref: 603</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_de_directrice_de_linnova_2\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_de_directrice_de_linnova_3\"><div align=\"left\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_de_directrice_de_linnova\"><strong>Candidate in a position de Director de l’Innovation, Knowledge ofs Conseils d’Adminsitration</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_est_de_formation_initiale_ingeni\">The candidate est by training initiale engineer docteur en industrial engineering (INPG), puis she has obtained un « Executive MBA » and un doctorat en business administration (IAE, PSB). Elle a 15 years d’experience in a groupe papetier international pour piloter de manière transverse le développement operational and strategic de l’innovation (multiples imprégnations international dont l’Allemagne où she has experienced, les USA, l’Espagne). Depuis 9 years, she has developed son activité de conseil en management de l’innovation and in parallel encadre of research académiques on the culture d’innovation : among other things, le management of the créativité collective. Elle a also une good knowledge ofs Conseils d’Administration, car she is certified as director par l’ADAE, of which she est devenue member du Comex and coordinatrice pédagogique of the formation d’directors. Elle dirige furthermore une collection d’ouvrages on the nouvelles tendances de valeur and la performance des « Boards ».</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.langues_etrangeres_anglais_allemand_notions_e\">Langues étrangères : English, German – Notions : Spanish, Italian</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_756\">Ref:756</p>\n</div></td></tr></tbody></table></td></tr>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_9\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_10\">\n<div align=\"left\"><span style=\"font-size: small;\"><b>Candidate in a position d’independent director, she brings over 20 years d’experience à haut niveau in Telecoms à l’international. </b></span></div>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.avec_une_longue_experience_de_direction_gener\"><span style=\"font-size: small;\">Avec une long experience de Senior Management, with opérateurs and with suppliers de Telecoms, the candidate a encadré des international teams and multidisciplinaires (finance, marketing, commercial, développement produit). Member du Executive Committee d’une association mondiale d’opérateurs for more than 10 years, elle acquis une connaissance globale de l’industrie and of his/her acteurs thus qu’une experience de governance.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_une_formation_deconomiste_aux_\"><span style=\"font-size: small;\">The candidate a une formation d’économiste (in the United States and en Suisse) and un MBA d’INSEAD. She is Member du Cercle des Directors d’INSEAD and Women Corporate Directors, Elle possèof the dual nationality French and American.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_108\"><span style=\"font-size: small;\">Ref: 108</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_11\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_12\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_3\"><span style=\"text-align: left; font-weight: bold;\"><strong>Candidate in a position d’independent director. </strong>Experience international varied within grands groupes American and European (Spatial, Médical and Défense), Mays also for PME and startups. </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_un_doctorat_en_mathematiques_appliquees\">Après un doctorat en mathématiques appliquées, pendant une vingtaine d’années, she has managed of large projets (plus de 10 millions d’euros) à l’export (USA, Afrique du Sud, Espagne, Italie, Indonésie, Thaïlande etc…) and des multicultural teams en high technology de l’information and of the communication. Then, in the doMayne l’artificial intelligence, she has worked à définir une nouvelle strategy de développement d’a start-up issue de l’Ecole Normale Supérieure</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ayant_obtenu_des_certificats_pour_evaluation_\">Ayant obtenu of certificates pour évaluation financière and la création de start-up technologique (HEC and Polytechnique), she has joined l’agence de l’innovation industrial puis la grande banque publique d’investissement to provide l’analyse strategic des grands projets sélectionnés (jusqu’à 110 millions d’euros) par ces organismes. Aujourd’hui, en independent, she provides assignments in conseil en strategy. Member du Cercle des Directors .</p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_109\"><span style=\"font-size: small;\">Ref: 109</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_de_formation_ingenieur_insead_a__3\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_de_formation_ingenieur_insead_a__4\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_de_formation_ingenieur_insead_a_\"><b><span style=\"font-size: small;\"> The candidate, by training Engineer + INSEAD, a une long experience de senior management positions and d’director in the sector industrial complétée genuine expertise in risk management of large projets international.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_10_ans_a_des_postes_de_responsabilite_t\"><span style=\"font-size: small;\">Après 10 years à des positions of responsibility technique (études, production, essais, management of large projets), the candidate has held différentes fonctions de Direction concernant des montants pouvant dépasser 500 M€ and comportant un volet international: Strategy, Administration and Finances, Opérations, Contrôle de gestion, Chaîne d’approvisionnement. Cette experience pluridisciplinaire (mécanique, électronique, IT, communications, l’a naturellement conduite vers of positions de Business Unit Director industrial, de Director within Directions Générales and d’Director. The candidate a souvent in parallel exercé des liabilitys transverses en management des risques pluridisciplinaires d’ unités and de projets operational. Cette experience permet aujourd’hui of the considérer comme une experte in this doMayne. Elle donne of courses quant au contrôle des companies ausen angalis de « Management control » dans diverse écoles dont l’ESSEC. The candidate est member de l’IFA and du Cercle des Directors INSEAD / Wharton/….</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_754\"><span style=\"font-size: small;\">ref: 754</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.consultante_franco_suisse_experte_en_gouverna_2\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.consultante_franco_suisse_experte_en_gouverna_3\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.consultante_franco_suisse_experte_en_gouverna\"><b><span style=\"font-size: small;\"> </span></b><strong>Consultante, Franco-Suisse, experte en governance d’family businesses</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_avoir_ete_avocate_au_barreau_de_paris_s\">After serving as Lawyer au Paris Bar, specialised en business law, pendant sept ans, she has led l’family business viticole basée en Gascogne. Son action has been particulièrement orientée on the développement commercial à l’international, and l’ouverture of new marchés. Building on cette experience, for 4 years, she served as Secretary General du Family Business Network France. Elle y a among other things développé un programme pédagogique multidisciplinaire d’ateliers and Lectures for the entrepreneurial families.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_consultante_independante_elle_les_\">Aujourd’hui, independent consultant, elle advises them, in the context d’une l’évolution international accélérée, pour organiser au mieux leur governance and planifier la transmission, in particular within la famille.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.elle_a_suivi_un_cursus_de_droit_des_affaires_\">Elle has followed un cursus de business law and de philosophie du droit, and est holder of the certificat d’aptitude à la profession d’lawyer and d’un master de coaching. Elle vit between the France and l’Italie.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.langues_francais_anglais_italien\">Languages: French – Anglais – Italien</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_832\"><span style=\"font-size: small;\">ref: 832</span></p>\n</td></tr></tbody></table></td></tr>\n &lt;tr&gt;&lt;td align=\"center\" valign=\"top\"&gt;&lt;table border=\"0\" width=\"97%\" cellspacing=\"0\" cellpadding=\"0\" align=\"center\"&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td valign=\"top\"&gt;\n&lt;p&gt;&lt;b&gt;&lt;span style=\"font-size: small;\"&gt; &lt;/span&gt;&lt;/b&gt;&lt;span style=\"font-size: small;\"&gt;&lt;b&gt;Consultante experte en strat&amp;eacute;gie and finance d&amp;rsquo;investissement in the sector de l&amp;rsquo;&amp;eacute;nergie and des services publics in France and &amp;agrave; l&amp;rsquo;international&lt;/b&gt;&lt;/span&gt;&lt;/p&gt;\n&lt;p&gt;&lt;span style=\"font-size: small;\"&gt;The candidate a 15 years d&amp;rsquo;exp&amp;eacute;rience in the doMayne above-mentioned. She is director and member du comit&amp;eacute; d&amp;rsquo;audit d&amp;rsquo;une company fran&amp;ccedil;aise cot&amp;eacute;e op&amp;eacute;rant in the doMayne de l&amp;rsquo;&amp;eacute;nergie. Elle has obtained le Certificat d&amp;rsquo;Director de Soci&amp;eacute;t&amp;eacute;s de l&amp;rsquo;Institut Fran&amp;ccedil;ais des Directors and vise un deuxi&amp;egrave;me mandate. Ayant v&amp;eacute;cu and travaill&amp;eacute; &amp;agrave; Londres, &amp;agrave; New-York, and en Am&amp;eacute;rique du Sud, she has bonne ma&amp;icirc;trise des enjeux &amp;agrave; l&amp;rsquo;international. Elle spoke on probl&amp;eacute;matiques in the sector de l&amp;rsquo;&amp;eacute;nergie during missions de conseil en strat&amp;eacute;gie, d&amp;rsquo;analyses financi&amp;egrave;res, de d&amp;eacute;cisions d&amp;rsquo;allocation de capital and d&amp;rsquo;&amp;eacute;valuation d&amp;rsquo;investissements. &lt;/span&gt;&lt;/p&gt;\n&lt;p&gt;She is dipl&amp;ocirc;m&amp;eacute;e de l&amp;rsquo;ESSEC and has obtained la charte CFA (&amp;lsquo;Chartered Financial Analyst&amp;rsquo;).&lt;/p&gt;\n&lt;p&gt;&lt;span style=\"font-size: small;\"&gt;Ref: 514&lt;/span&gt;&lt;/p&gt;\n&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/td&gt;&lt;/tr&gt; \n<tr style=\"font-size: 12px;\"><td data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_de_nationalite_f_2\">\n<div align=\"center\"><table border=\"0\" cellpadding=\"5\" width=\"510\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_de_nationalite_f_3\" width=\"492\">\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_de_nationalite_f\"><strong>Independent director de nationalité French vivant aujourd’hui in Madrid. Extensive experience operational in the business des telecommunications, puis in a ONG Internationale and aujourd’hui entrepreneur.</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_un_dea_deconomie_a_paris_la_sorbonne_et\">Après un DEA d’économie in Paris La Sorbonne and un MBA à l’Université de San Francisco aux Etats Unis, the candidate a for 7 years travaillé au sein d’un grand opérateur French des telecommunications. She was la première femme à rejoindre la division Internationale, en tant qu’expatriée, in charge of launching of activities commerciales in Spain. Elle y demeurera for thencer les activités d’un autre groupe du même secteur and prendre la liability of their subsidiary in Spain and au Portugal. Elle a then pendant quatre ans été manager for the péninsule ibérique de subsidiaries de companies américaines de telecommunications, listed au Nasdaq (matériels and software).</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ensuite_durant_6_annees_elle_a_ete_responsabl\">Then, durant 6 years, she served as responsible for les pays latins d’une grande ONG international visant la promotion de the presence des femmes en company à des positions of responsibility and conseils d’administration. Elle has developed une expertise in gestion of the diversité.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_elle_a_cree_sa_propre_entreprise_d\">Aujourd’hui, she created his/her own company de consulting pour, within the companies, tel a major group de cosmétiques, développer l’esprit d’équipe, le leadership and faciliter l’évolution des organisations, among other things en utilisant le coaching, la musique and les rythmes. Mentor within l’association international Professional Women Network (PWN) as well as member de l’Association Spanish Women CEO. Languages: French, Anglais, Espagnol.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_723\">Ref 723</p>\n</td></tr></tbody></table></div>\n<p align=\"center\"> </p>\n</td></tr>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_experimentee_jur_2\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"5\" width=\"526\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_experimentee_jur_3\" width=\"512\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_experimentee_jur\"><strong>Independent director expérimentée, legal professional de nationalité Spanish with a extensive experience du business European including via Internet</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_une_formation_de_juriste_en_espagne_et_\">Après une formation of thegal professional in Spain and in Germany, the candidate has held for 5 years in Brussels , Madrid and Barcelone in several cabinets d’lawyers d’affaire l’un Spanish and deux American: Traitement de conflits très varied en amont of actions devant les tribunaux, including vis-à-vis of the European Commission : customs duties, abuse of dominant position, accord commerciaux, fusions acquisitions,… Then, for 6 years, elle fait partie du Cabinet de M. Marcelino Oreja, member of the European Commission , in charge of la Direction du suivi des Entreprises, responsible for the actions concertées between the Commission and les Etats members for the politiques d’amélioration de l’environnement and du développement des companies Puis in Madrid, she served as la conceptrice, and la responsible for l’animation d’un grand projet de plateforme de e-commerce destiné à faciliter les transactions de international trade. Il avait comme objectif de permettre les échanges commerciaux avec d’importantes réductions de coûts in exportations and importations Ce projet a bénéficié de soutiens financiers de l’Union Européenne, de chambres de commerce and of various associations issues de 8 pays European. Un prototype operational was able to être réalisé. Le projet a reçu plusieurs prix and distinctions.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.en_parallele_elle_a_ete_directrice_juridique_\">In parallel, she served as Legal Director and conseillère du Chairman d’un très grand groupe Spanish du doMayne des produits alimentaires and of the construction d’ensembles tels des hôtels. Elle a in particular participé à la création d’un portail internet pour élargir la base des consommateurs. Aujourd’hui, she created son propre cabinet de Conseil tant for the companies que for the organismes publics. Elle peut leur provide the benefit of of her extensive experience European, Mays also in mise en place de relations with the Chine and les pays d’Amérique Latine.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.en_espagne_elle_a_ete_administratrice_de_la_c\">En Espagne, she has served as director of the Confédération des employeurs espagnols, Vice Chairwoman de Women CEO and in a large ville de l’Est des USA, director d’une grande école international as well as d’une ONG visant l’amélioration des conditions de vie des personnes défavorisées. En 2013, she has participated au cours<strong><em> « </em></strong><em>Making corporate boards more effective</em> « à Harward Business School.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_762\">Ref 762</p>\n</td></tr></tbody></table></td></tr>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde_9\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr style=\"font-size: 12px;\"><td data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde_10\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde_3\" style=\"text-align: left; font-size: 10pt;\"><span style=\"font-weight: bold;\">The candidate in a position d’independent director, de nationalité French and American, est based in the USA and in France. Parcours anglo-saxon de 30 years à la croisée de l’real estate and of the finance</span> chez Bank of America, General Motors, EY, …or au service de clients institutionnels comme la World Bank or BlackRock. Elle a eu tour à tour des rôles d’analyste, d’émetteur, d’évaluateur, de prêteur, and d’investor</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.elle_a_mene_plusieurs_operations_de_fusion_ac\" style=\"text-align: left; font-size: 10pt;\">Elle has led plusieurs opérations de merger and acquisition or vente de companies, and siégé in several conseils d’administration de subsidiaries d’a major group.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_consultante_independante_connaissa\">Aujourd’hui , independent consultant, with good knowledge of les Etats-Unis, le Canada, les pays d’Europe de l’Ouest and la Russie, she works à l’international pour accompagner des acteurs institutionnels à bien formuler and exécuter leurs stratégies immobilières. Elle siège au conseil moreoverieurs associations professional immobilières.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.certifications_immobilieres_courantes_avec_ob\"><strong style=\"font-weight: normal;\">Certifications immobilières courantes, avec obligation by training continue: </strong> Aux USA: MAI (Member of the Appraisal Institute), CRE (Counselors of Real Estate) En Europe: FRICS: Fellow of the Royal Institution of the Chartered Surveyors</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.formation_sciences_po_paris_institut_durbanis\"><strong>Formation</strong>: Sciences-Po Paris, Institut d’Urbanisme de Paris, New York University Director certified (IFA)</p>\n<p align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.ref_320\" style=\"font-size: 12px; text-align: left;\">Ref: 320</p>\n</td></tr></tbody></table></td></tr>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.diplomee_de_liae_de_nice_de_paris_i_pantheon__2\" height=\"22\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.diplomee_de_liae_de_nice_de_paris_i_pantheon__3\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.diplomee_de_liae_de_nice_de_paris_i_pantheon_\" style=\"text-align: left; font-size: 10pt;\"><span style=\"font-weight: bold;\">Graduate de l’IAE de Nice, de Paris I Panthéon Sorbonne and d´HEC, avec orientation à l’international, au commercial and marketing, the candidate de nationalité franco-bulgare has spent un tiers of her vie professional à l’étranger, Bulgarie, Maroc, Italie, USA, France</span>, etc.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.elle_a_20_ans_dexperience_de_directions_opera\" style=\"text-align: left; font-size: 10pt;\">Elle a 20 years d’experience de directions operational and strategic, secteurs of the pharmaceutical distribution, des biens d’équipement and des services, in companies italiennes, françaises and japonaises in Europe. Elle has to her/his credit plusieurs delicate turnarounds and has experienced deux situations particulières: introduction à la bourse de NYSE and rachat hostile par a major group japonais.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.elle_a_egalement_acquis_une_bonne_connaissanc\" style=\"text-align: left; font-size: 10pt;\">Elle a also acquis une bonne connaissance du fonctionnement des Conseils, d’une part, as member de Executive Committees (présentations devant les directors), and d’autre part, pour avoir in fact in several circonstances joué le rôle d’un Secrétaire de Conseil (préparations of files for the CA, knowledge ofs stakeholders, rapports de governance).</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.elle_est_actuellement_conseil_independant_en_\" style=\"text-align: left; font-size: 10pt;\">She is currently independent advisor en strategy, accompagnatrice de créateurs d’company or d’activités innovantes of large groupes, specialised in valorisation &amp; développement des marques, member du strategic committee d’a start-up and conseiller en career bénévole (mentoring HEC). Member de l’Institut French des Directors, of the French American Foundation, du Professional’s Women Network and du groupement governance HEC.</p>\n<p align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.ref_617\" style=\"font-size: 12px; text-align: left;\">Ref: 617</p>\n</td></tr></tbody></table></td></tr>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_de_formation_ingenieur_insead_a__5\" height=\"223\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_de_formation_ingenieur_insead_a__6\" height=\"203\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_de_formation_ingenieur_insead_a__2\"><b><span style=\"font-size: small;\"> The candidate, by training Engineer + INSEAD, a une long experience de senior management positions and d’director in the sector industrial complétée genuine expertise in risk management of large projets international.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_10_ans_a_des_postes_de_responsabilite_t_2\"><span style=\"font-size: small;\">Après 10 years à des positions of responsibility technique (études, production, essais, management of large projets), the candidate has held différentes fonctions de Direction concernant des montants pouvant dépasser 500 M€ and comportant un volet international: Strategy, Administration and Finances, Opérations, Contrôle de gestion, Chaîne d’approvisionnement. Cette experience pluridisciplinaire (mécanique, électronique, IT, communications, l’a naturellement conduite vers of positions de Business Unit Director industrial, de Director within Directions Générales and d’Director. The candidate a souvent in parallel exercé des liabilitys transverses en management des risques pluridisciplinaires d’ unités and de projets operational. Cette experience permet aujourd’hui of the considérer comme une experte in this doMayne. Elle donne of courses de « Contrôle des companies » en English « Management control » dans diverses écoles dont l’ESSEC.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_est_membre_de_lifa_et_du_cercle_\">The candidate est member de l’IFA and du Cercle des Directors INSEAD / Wharton/….</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_754_2\"><span style=\"font-size: small;\">Ref: 754</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_grande_societe_e_2\" height=\"426\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_grande_societe_e_3\" height=\"413\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_grande_societe_e\"><b><span style=\"font-size: small;\"> Independent director, Grande Société Européenne</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_domiciliee_depuis_25_ans_a_paris\"><span style=\"font-size: small;\">The candidate based depuis 25 years in Paris possèof the dual nationality French and Spanish. Son experience en management d’opérations hautement strategic pour of large listed companies du Royaume-Uni, of the France, and of the Belgique has been accumulée sur 30 years. D’abord, and in depth, within the secteur des telecommunications, Mays also plus recently for the santé (hôpitaux) and l’industrie alimentaire (Pêche). Elle a his/her credit plusieurs delicate turnarounds comme member du Conseil d’Administration devant superviser le bon déroulement operational, comme member du Comex, and comme consultant. Independent director d’une company Norwegian, she has experienced deux situations very enriching : listing on the stock exchange de Londres and rachat hostile par a major group German.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.dans_un_contexte_franco_espagnol_tendu_elle_a\">Dans un contexte franco Spanish tendu, she served as CEO, puis Chairwoman du Conseil d’Administration of the  » joint-venture  » Spanish of two groupes issus (IBEX35 / CAC40). Son experience international est European and plus particulièrement for the pays du Sud dont she speaks les langues couramment, Mays s’étend à l’Amérique du Sud.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.formation_computing_sciences_engineer_cours_p\">Education: Computing Sciences Engineer, + Cours pour Dirigeants à l’INSEAD. Member du Board International du Global Telecommunications Women Network and in Spain de  » Plataforma de Expertas « . Member du  » Achieving Outstanding Performance  » (AoP) and TMT Group’s de l’INSEAD</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_753\"><span style=\"font-size: small;\">Ref: 753 </span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.actuellement_directeur_grands_comptes_dans_un_2\" height=\"392\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"97%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.actuellement_directeur_grands_comptes_dans_un_3\" height=\"165\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.actuellement_directeur_grands_comptes_dans_un_4\" height=\"232\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.actuellement_directeur_grands_comptes_dans_un\"><b><span style=\"font-size: small;\">Currently Director «  Grands Comptes  » in a company international de telecommunications listed, the candidate recherche, en accord with his/her employeur, a mandatee d’independent director.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.pendant_plus_de_15_ans_la_candidate_a_travail\"><span style=\"font-size: small;\">Pendant over 15 years, the candidate has worked in the Conseil and l’Ingénierie (IT, électronique, process,…), au sein d’un groupe international côté, for the Développement and le Management de Grands Comptes, notably de l’Industrie (automobile, médical, défense,…) and des Telecoms.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_une_expertise_de_business_deve\">The candidate a une expertise de  » Business Developer  » thus qu’une forte ouverture marketing and RH. Within subsidiaries (60 à 800 personnes avec pour certaines des chiffres d’affaires moreover de 500 M€), she served as Director (France and Espagne) , CEO and Chairwoman (SAS). Elle a furthermore exercé des liabilitys transverses and contribué à la transformation d’organisations, tant en période de croissance qu’en période de crise.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.membre_de_leuropean_professionals_women_netwo\"><span style=\"font-size: small;\">Member de l’European Professional’s Women Network, du Cercle Governance and Equilibre, certified par l’Essec for the formation spécifique pour devenir director  » Women Be European Board Ready  » </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_604\"><span style=\"font-size: small;\">Ref: 604</span></p>\n</td></tr></tbody></table></td></tr></tbody></table></td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_pharmacie_mba_actuellement_conse_2\" height=\"177\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"97%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_pharmacie_mba_actuellement_conse_3\" height=\"165\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_pharmacie_mba_actuellement_conse\"><b><span style=\"font-size: small;\"> </span></b><b><span style=\"font-size: small;\">The candidate, Pharmacie-MBA, currently independent advisor en strategy, a 30 years d’experience de directions operational and strategic in the sectors des consumer products and pharmaceutiques. Son experience international successful, among other things comme «  commerciale de haut niveau « , démontre great adaptability dans multicultural environments.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde_4\"><b></b><span style=\"font-size: small;\">The candidate in a position d’independent director has started sa career in recherche and le développement en laboratoire and industrie pharmaceutique. Elle a then été consultante en strategy pour a major firm international où she has led of projects in several industries (Pharmaceuticals, Ind. Agro. Alim., Distribution, secteurs where a Consehe could benefit from his/her experience). Then, in a groupe international leader in the sector des boissons, elle passé over 20 years à diverhis/her responsibilities operational (profit centers, ventes-marketing, innovation) and strategic in France and worldwide. In this capacity, she has participated aux Executive Committees, has led des grandes multicultural teams and fonctionnelles. Elle sait ce que signifie conduire within the framework d’une vision strategic of actions on the terrain. D’une famille d’entrepreneurs, she has invested in start-ups and supports them. Elle sait donc s’adapter à des organisations of different tailles. Trilingual French/English/German, member de l’IFA</span><b><span style=\"font-size: small;\">. </span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_632\"><span style=\"font-size: small;\">Ref: 632</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.au_cours_des_22_dernieres_annees_cette_candid_2\" height=\"230\" valign=\"top\"><div align=\"center\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.au_cours_des_22_dernieres_annees_cette_candid_3\"><div align=\"left\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.au_cours_des_22_dernieres_annees_cette_candid\"><span style=\"font-size: small;\"><b>Over the 22 dernières années, cette candidate in a position d’director has been member de Executive Committees, experte en finance, strategy and projets de transformation both in France and qu’à l’international in the sectors des services financiers, des infrastructures liées aux secteurs du transport, de l’énergie, des déchets, and des loisirs. </b></span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_10_ans_dexperience_en_financements_stru\">Après 10 years d’experience en financements structurés in the sectors des utilities and du transport, elle spoke in définition des évolutions strategic d’one of the first groupes bancaires French (évaluations d’investissement, allocation de capital, conclusions de partenariats) and has led projects in transformation majeurs as CFO de groupes international leaders in doMaynes of the gestion d’actifs, of the banque d’investissement, and of the private banking. She served as director moreoverieurs companies du secteur financier in France and à l’étranger (Italie, UK, USA, Hong-Kong), and est currently director de l’association nationale des directeurs financiers, la DFCG, of which she présiof the région Ile de France. She is furthermore member de l’IFA and has initiated le groupe de réflexion IFA/DFCG on the thématique  » CFO and Comité d’Audit « . Elle a enseigné l’analyse financière and control de gestion à Dauphine and à HEC. She is graduate de Sciences Po Paris and de Columbia University.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_813\"><span style=\"font-size: small;\">Ref: 813</span></p>\n</div></td></tr></tbody></table></div></td></tr>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.directrice_financiere_et_des_operations_avec__2\" height=\"242\" valign=\"top\">\n<div align=\"center\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.directrice_financiere_et_des_operations_avec__3\" height=\"162\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.directrice_financiere_et_des_operations_avec_\"><span style=\"font-size: small;\"><b>CFO and des Opérations,</b> <b>avec 25 years d´experience dans of groups industrial international listed en bourse, des secteurs Énergie, Environnement, Aluminium, Emballage, Chimie and Services B2B</b> </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_dispose_d_une_vaste_pratique_du_\">The candidate dispose d´une vaste pratique du «  Risk management « , des grands projets d´investissements, des fusions &amp; acquisitions, and of the transformation des organisations, tant in périodes de croissance que de crise économique globale. Grâce aux différents mandates qu’she has helds, including comme director de subsidiaries, dont l´un de co-Présidente d´un Conseil, she has acquired une experience in-depth of the governance des joint-ventures international in contextes complexes and politiquement sensibles.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.diplomee_d_hec_et_du_mba_de_mcgill_university\">Graduate d´HEC (and du MBA de McGill University au Canada), complété d´une formation récente au MIT (Sloan School of Management), she lives in Germany, parle couramment l´English, l´German and l´Spanish, and pourra provide the benefit of le Conseil of his vécu international.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_803\"><span style=\"font-size: small;\">Ref: 803 .</span><b><span style=\"font-size: small;\"> </span> </b></p>\n</td></tr></tbody></table></div>\n<p align=\"center\"> </p>\n</td></tr>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_experi_2\" height=\"212\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_experi_3\" height=\"199\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_experi\"><b><span style=\"font-size: small;\"> Candidate independent director. Experience international. Telecoms, Spatial, Conseil en R&amp;D, SSII. Excellente maîtrise des problèmes de governance.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_de_formation_juridique_internati\"><span style=\"font-size: small;\">The candidate, by training legal international (UK, France and USA) has held of positions de Legal Director and Board Secretary d’importantes listed companies and non listed ayant of activities largement international in doMaynes des telecoms, du conseil en R&amp;D, des SSII and de l’industrie spatiale. Elle has acquired une extensive experience des restructurings, of partnerships in multiples pays whose Qatar and le Japon, du M&amp;A dans différents pays whose France and les USA, and du white-collar criminal law. Au titre of his/her activités in the capacity of Board Secretary, she served as fortement impliquée in problématiques de governance and est habituée aux pratiques des conseils multinationaux . She served as director de subsidiaries in Italy and in Germany. </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_504\"><span style=\"font-size: small;\">Ref: 504</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_mba_doxford_univ\" height=\"232\" valign=\"top\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_mba_doxford_univ_2\">\n<div align=\"left\"><span style=\"font-size: small;\"><b> Director Indépendante, MBA d’Oxford University avec over 15 years d’experience managériale and de « Corporate Governance » acquise principalement in Entreprises non listed de Taille Intermédiaire in France, Angleterre and in the USA.</b> </span></div>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.au_travers_des_activites_menees_dans_postes_t\"><span style=\"font-size: small;\">Throughs activités menées dans postes tenus in Paris and in Oxford, the candidate has developed des competences de généraliste en gestion, finance and développement commercial in the sector des services within PME European. Au fil des last five years, she has acquired une experience in relations with the shareholders (of the fundraising au reporting trimestriel and organisation/animation des general meetings) as well as in governance intégrant la dimension RSE and l’audit financier, social and environnemental.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.apres_avoir_en_angleterre_co_developpe_ex_nih\"><span style=\"font-size: small;\">After having in England co-développé ex-nihilo une company du doMayne of the finance éthique and de l’real estate responsable of which she est aujourd’hui director, the candidate est rentrée in France en 2010 to créer une company similaire. She is aujourd’hui PDG. Son mandate d’director will end en July 2012, lui laissant of availability pour exercer efficacement a position d’independent director, in particular in a company with activités en UK.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.formation_master_of_business_administration_u\"><span style=\"font-size: small;\">Education: Master of Business Administration, Université d’Oxford (SBS) and formation continue auprès de l’Institute of Directors and l’Institut French des Directors. »</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_107\"><span style=\"font-size: small;\">Ref: 107</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_20_ans_dexperien_2\" height=\"232\" valign=\"top\">\n<div align=\"center\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_20_ans_dexperien_3\" valign=\"top\">\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_20_ans_dexperien\"><span style=\"font-size: small;\"><b>Independent director, 20 years d’experience worldwide des NTIC : Entrepreneur, PDG, Investor. </b> The candidate, after serving as director moreoverieurs companies in the world des NTIC and de l’Internet. Aujourd’hui independent director d’une listed company Eurolist C, she could provide the benefit of à d’autres of his experience diversified (Entrepreneur, PDG, Director, Investor). </span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.apres_avoir_occupe_des_postes_de_direction_ge\"><span style=\"font-size: small;\">After holding of positions de Senior Management for 10 years, she created a start-up Internet en 1999 revendue en 2001. Elle réalise alors assignments in conseil en strategy and prend la direction du développement d’a major firm d’audit and de conseil avant de rejoindre un fonds d’investissement comme « Partner ».</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.apres_un_master_2_universite_de_paris_2_dassa\"><span style=\"font-size: small;\">Après un Master 2 Université de Paris 2 d’Assas en « Coaching », she creates en 2010 sa company de « Business Coaching » pour aujourd’hui accompagner des companies dans leur développement through the missions de « Coaching » de dirigeants and d’accompagnement operational.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.formation_doctorat_de_gestion_universite_de_p\"><span style=\"font-size: small;\">Education: Doctorat de gestion Université de Paris 1, MBA, Master 2 coaching Assas.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_152\"><span style=\"font-size: small;\">Ref: 152</span></p>\n</td></tr></tbody></table></div>\n<p align=\"center\"> </p>\n</td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_13\" height=\"156\" valign=\"top\"><div align=\"center\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_14\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_4\"><span style=\"font-size: small;\"><b>Candidate in a position d’independent director in the doMayne of the santé </b> Docteur en médecine, spécialiste qualified en santé publique, she has held des fonctions très diverses in services de l’état and de 2 régimes d’assurance maladie Elle envisage de prendre sa retraite au 01/07/2013 and pense en tant qu’independent director pouvoir provide the benefit of of his experience extensive un Conseil d’Administration d’une company opérant on marchés of the santé. Pour s’y préparer, elle devenue member l’IFA (Institut French des Directors)and Certified Director after having suivi le cours by training proposé par l’ IFA /Science Po . </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_365\"><span style=\"font-size: small;\">Ref: 365</span></p>\n</td></tr></tbody></table></div></td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.femme_ingenieur_supelec_candidate_comme_admin_2\" height=\"133\" valign=\"top\"><div align=\"center\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.femme_ingenieur_supelec_candidate_comme_admin_3\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.femme_ingenieur_supelec_candidate_comme_admin\"><b><span style=\"font-size: small;\">Femme engineer Supelec, candidate comme director independent</span></b>e</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.pour_avoir_occupe_dans_des_ssii_pendant_plusi\"><span style=\"font-size: small;\">Pour avoir occupé in SSII pendant plusieurs années of positions de PDG, Chairwoman of the Executive Board, Director de SA and créé une SAS in the doMayne du luxe, the candidate a une experience in-depth of positions operational de dirigeante comportant among other things, IPO, fusions-acquisitions, création d’company, fundraising.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_elle_travaille_dans_le_domaine_des\">Aujourd’hui, elle travaille in the doMayne of funds d’investissement.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_612\"><span style=\"font-size: small;\">Ref: 612</span></p>\n</td></tr></tbody></table></div></td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_comme_m_2\" height=\"302\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_comme_m_3\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_comme_m\"><b><span style=\"font-size: small;\">Candidate in a position d’director, comme member du Comité Strategy or d’audit Très extensive experience of the finance à l’international. </span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.diplomee_dhec_de_la_london_business_school_et\"><span style=\"font-size: small;\">Graduate d’HEC, of the London Business School and de New York University (International Program), elle commence au sein d’une grande banque American par gérer les relations with grandes companies du secteur privé and public. En 1985, elle rejoint une banque d’affaires international renommée for the opérations de conseil financier and de fusions / acquisitions. Elle a conseillé des Etats, in particular de pays émergents, des grandes companies international and des institutions financières, notably sur: – of investments industrial in pays de l’Est and in pays émergents, – des montage and financements of large projets in the sectors de l’énergie and des infrastructures, – des renégociations de dettes – la gestion and la cession de portefeuilles d’actifs and de prêts of large institutions financières. Dans ce cadre, elle a l’habitude de travailler directement with the COMEX and Conseils d’Administration and with the gouvernements.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.elle_est_membre_de_lifa_de_lassociation_hec_d\"><span style=\"font-size: small;\">She is member de l’IFA, de l’association HEC dans ses doMaynes de competences, moreoverieurs organisations de femmes dirigeantes and de Business Angels. »</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_512\"><span style=\"font-size: small;\">Ref: 512 </span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_d_administratrice_ind_2\" height=\"202\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_d_administratrice_ind_3\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_d_administratrice_ind\"><b><span style=\"font-size: small;\">The candidate in a position d’ Independent director est lawyer en business law and has been responsable legal de groupes international listed. Un séjour moreoverieurs années comme résidente en Corée du Sud (au sein d’a firm d’lawyers Korean puis à la Chambre de Commerce Franco Coréenne) lui has enabled de connaître de l’intérieur la culture nord asiatique. Elle a donné of courses sur ce thème.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.experience_approfondie_du_domaine_des_ventes_\"><b></b><span style=\"font-size: small;\">Experience in-depth du doMayne des ventes au grand public dont de produits électroniques. En tant qu’lawyer, puis comme responsable legal, she is familière des conseils d’administration. Bilingue français-anglais. Elle connait furthermore la culture germanique. Education: Diplôme de Juriste Conseil d’Entreprise (DJCE), Certificat d’Aptitude à la Profession d’Avocat</span><b><span style=\"font-size: small;\">.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_635\"><span style=\"font-size: small;\">Ref: 635</span></p>\n</td></tr></tbody></table></td></tr>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_hotell_4\" height=\"233\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_hotell_5\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_hotell_2\"><span style=\"font-size: small;\"><b>Candidate independent director : Hôtellerie, Restauration, Tourisme ; France and Europe</b> Experience pluridisciplinaire acquise au sein d’un groupe hôtelier international coté au CAC 40. Au fil de 30 years, dont 12 years in restauration publique, the candidate a successivement occupé of positions de dirigeante in doMaynes varied : contrôle de gestion, produits, opérations, marketing, audit interne, production, publishing and communication des bureaux de ventes international, finally quant à l’efficacité des coûts marketing &amp; distribution. </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_elle_est_consultante_independante__2\"><span style=\"font-size: small;\">Aujourd’hui, she is independent consultant in these doMaynes. Very good knowledge of l’international. Education: Master's in Economics (Paris 2), DEA Théories and Politiques monétaires (Paris 2), Executive Doctorate in Business Administration (Paris Dauphine, 2009). Member de l’IFA and Secretary General de l’Association Européenne de Neuroéconomie.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_303_2\"><span style=\"font-size: small;\">Ref: 303</span></p>\n</td></tr></tbody></table></td></tr>\n &lt;tr&gt;&lt;td align=\"center\" valign=\"top\" height=\"233\"&gt;&lt;table border=\"0\" width=\"95%\" cellspacing=\"3\" cellpadding=\"0\" align=\"center\"&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;\n&lt;p&gt;&lt;b&gt;&lt;span style=\"font-size: small;\"&gt;Consultante experte en strat&amp;eacute;gie and finance d&amp;rsquo;investissement in the sector de l&amp;rsquo;&amp;eacute;nergie and des services publics in France and &amp;agrave; l&amp;rsquo;international&lt;/span&gt;&lt;/b&gt;&lt;/p&gt;\n&lt;p&gt;&lt;span style=\"font-size: small;\"&gt;The candidate a 15 years d&amp;rsquo;exp&amp;eacute;rience in the doMayne above-mentioned. She is director and member du comit&amp;eacute; d&amp;rsquo;audit d&amp;rsquo;une company fran&amp;ccedil;aise cot&amp;eacute;e op&amp;eacute;rant in the doMayne de l&amp;rsquo;&amp;eacute;nergie. Elle has obtained le Certificat d&amp;rsquo;Director de Soci&amp;eacute;t&amp;eacute;s de l&amp;rsquo;Institut Fran&amp;ccedil;ais des Directors and vise un deuxi&amp;egrave;me mandate. Ayant v&amp;eacute;cu and travaill&amp;eacute; &amp;agrave; Londres, &amp;agrave; New-York, and en Am&amp;eacute;rique du Sud, she has bonne ma&amp;icirc;trise des enjeux &amp;agrave; l&amp;rsquo;international. Elle spoke on probl&amp;eacute;matiques in the sector de l&amp;rsquo;&amp;eacute;nergie during missions de conseil en strat&amp;eacute;gie, d&amp;rsquo;analyses financi&amp;egrave;res, de d&amp;eacute;cisions d&amp;rsquo;allocation de capital and d&amp;rsquo;&amp;eacute;valuation d&amp;rsquo;investissements.&lt;/span&gt;&lt;/p&gt;\n&lt;p&gt;&lt;span style=\"font-size: small;\"&gt;She is dipl&amp;ocirc;m&amp;eacute;e de l&amp;rsquo;ESSEC and has obtained la charte CFA (&amp;lsquo;Chartered Financial Analyst&amp;rsquo;).&lt;/span&gt;&lt;/p&gt;\n&lt;p&gt;&lt;span style=\"font-size: small;\"&gt;Ref: 514&lt;/span&gt;&lt;/p&gt;\n&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/td&gt;&lt;/tr&gt; \n</tbody></table></div>\n<p align=\"center\"> </p>",
    "femmes_candidates": "Female Candidates",
    "candidate_administratrice_independante_grande_2": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_grande_3\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_grande\" style=\"margin: 0cm; margin-bottom: .0001pt;\"><span style=\"font-family: georgia, palatino, serif;\"><b>Candidate independent director : Extensive experience international</b></span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_ecole_des_mines_et_biotechnologi\" style=\"margin: 0cm; margin-bottom: .0001pt;\"><span style=\"font-family: georgia, palatino, serif;\">The candidate ( Ecole des Mines and Biotechnologie au MIT) has held 3 mandates successifs au Supervisory Board d’une ETI familiale de dimension international: organic growth and externe, défis liés à une croissance rapide (manufacturing, supply chain, RH). Plus de 40 years hors de France: USA + différents pays European, in Germany depuis 2000. Conseil en strategy chez Bain, director operational chez Pasteur-Mérieux. Depuis deux ans, mentorat de start-ups auprès de l’accélérateur MassChallenge.</span></p>\n<p align=\"left\"><span style=\"font-size: small;\"><b> </b></span></p>\n</td></tr>\n<tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_hotell_3\">\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_hotell\"><span style=\"font-size: small;\"><b>Candidate independent director : Hôtellerie, Restauration, Tourisme; France and Europe</b> Experience pluridisciplinaire acquise au sein d’un groupe hôtelier international coté au CAC 40. Au fil de 30 years, dont 12 years in restauration publique, the candidate a successivement occupé of positions de dirigeante in doMaynes varied : contrôle de gestion, produits, opérations, marketing, audit interne, production, publishing and communication des bureaux de ventes international, finally quant à l’efficacité des coûts marketing &amp; distribution. </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_elle_est_consultante_independante_\"><span style=\"font-size: small;\">Aujourd’hui, she is independent consultant in these doMaynes. Very good knowledge of l’international. Education: Master's in Economics (Paris2), DEA Théories and Politiques monétaires (Paris 2), Executive Doctorate in Business Administration (Paris Dauphine, 2009). Member de l’IFA and Secretary General de l’Association Européenne de Neuroéconomie.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_303\"><span style=\"font-size: small;\">Ref: 303</span></p>\n</td></tr>\n</tbody></table>",
    "candidate_administratrice_independante_grande_3": "<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_grande\" style=\"margin: 0cm; margin-bottom: .0001pt;\"><span style=\"font-family: georgia, palatino, serif;\"><b>Candidate independent director : Extensive experience international</b></span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_ecole_des_mines_et_biotechnologi\" style=\"margin: 0cm; margin-bottom: .0001pt;\"><span style=\"font-family: georgia, palatino, serif;\">The candidate ( Ecole des Mines and Biotechnologie au MIT) has held 3 mandates successifs au Supervisory Board d’une ETI familiale de dimension international: organic growth and externe, défis liés à une croissance rapide (manufacturing, supply chain, RH). Plus de 40 years hors de France: USA + différents pays European, in Germany depuis 2000. Conseil en strategy chez Bain, director operational chez Pasteur-Mérieux. Depuis deux ans, mentorat de start-ups auprès de l’accélérateur MassChallenge.</span></p>\n<p align=\"left\"><span style=\"font-size: small;\"><b> </b></span></p>",
    "candidate_administratrice_independante_hotell_3": "<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_hotell\"><span style=\"font-size: small;\"><b>Candidate independent director : Hôtellerie, Restauration, Tourisme; France and Europe</b> Experience pluridisciplinaire acquise au sein d’un groupe hôtelier international coté au CAC 40. Au fil de 30 years, dont 12 years in restauration publique, the candidate a successivement occupé of positions de dirigeante in doMaynes varied : contrôle de gestion, produits, opérations, marketing, audit interne, production, publishing and communication des bureaux de ventes international, finally quant à l’efficacité des coûts marketing &amp; distribution. </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_elle_est_consultante_independante_\"><span style=\"font-size: small;\">Aujourd’hui, she is independent consultant in these doMaynes. Very good knowledge of l’international. Education: Master's in Economics (Paris2), DEA Théories and Politiques monétaires (Paris 2), Executive Doctorate in Business Administration (Paris Dauphine, 2009). Member de l’IFA and Secretary General de l’Association Européenne de Neuroéconomie.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_303\"><span style=\"font-size: small;\">Ref: 303</span></p>",
    "candidate_au_poste_dadministratrice_independa_2": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_au_poste_dadministratrice_independa_3\">\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.candidate_au_poste_dadministratrice_independa\"><span style=\"font-size: small;\"><b> </b></span><span style=\"font-weight: bold;\">Candidate au poste d’independent director .</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.docteur_en_economie_la_candidate_beneficie_du\">Docteur en économie , the candidate bénéficie d’une experience professional moreover de 30 years . Ses competences métiers couvrent le secteur banque / finance , le conseil en organisation and strategy , the new technologies and la transformation digitale .</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.membre_des_comites_de_direction_elle_a_assure\">Member des executive committees she has managed avec succès des liabilitys operational (profit center , développement ) au sein d’one of the largest banques mondiales , d’a firm de conseil de premier plan (big four) and d’une company specialised en système d’information listed on CAC 40 . Compte tenu of projects qu’she has carried out and de his/her various functions she is thoroughly familiar with bien la zone Europe ( UK , Bénelux , Hongrie , Espagne ,Italie) , les Etats Unis , l’Inde and le Maroc .</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.membre_du_cercle_des_administrateurs_de_lasso\">Member du Cercle des directors , de l’association des Alumni d’ATOS, she leads also of actions de bénévolat pour V.E.C.V ( Votre Ecole Chez Vous ) association reconnue d’utilité publique and sous contrat avec l’éducation nationale .</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_324\">Ref: 324</p>\n<p align=\"left\"> </p>\n</td></tr></tbody></table>",
    "candidate_au_poste_dadministratrice_independa_3": "<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.candidate_au_poste_dadministratrice_independa\"><span style=\"font-size: small;\"><b> </b></span><span style=\"font-weight: bold;\">Candidate au poste d’independent director .</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.docteur_en_economie_la_candidate_beneficie_du\">Docteur en économie , the candidate bénéficie d’une experience professional moreover de 30 years . Ses competences métiers couvrent le secteur banque / finance , le conseil en organisation and strategy , the new technologies and la transformation digitale .</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.membre_des_comites_de_direction_elle_a_assure\">Member des executive committees she has managed avec succès des liabilitys operational (profit center , développement ) au sein d’one of the largest banques mondiales , d’a firm de conseil de premier plan (big four) and d’une company specialised en système d’information listed on CAC 40 . Compte tenu of projects qu’she has carried out and de his/her various functions she is thoroughly familiar with bien la zone Europe ( UK , Bénelux , Hongrie , Espagne ,Italie) , les Etats Unis , l’Inde and le Maroc .</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.membre_du_cercle_des_administrateurs_de_lasso\">Member du Cercle des directors , de l’association des Alumni d’ATOS, she leads also of actions de bénévolat pour V.E.C.V ( Votre Ecole Chez Vous ) association reconnue d’utilité publique and sous contrat avec l’éducation nationale .</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_324\">Ref: 324</p>\n<p align=\"left\"> </p>",
    "candidate_a_un_poste_dadministratrice_indepen_5": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_6\">\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen\"><span style=\"font-size: small;\"><b> Candidate in a position d’independent director, with good knowledge of le BTP, les services aux companies, la santé, les fonds d’investissement and la communication. </b></span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.apres_avoir_mene_des_travaux_daudit_chez_erns\"><span style=\"font-size: small;\">After having mené des travaux d’audit chez Ernst &amp; Young, the candidate, over the 13 years suivantes, has acquired successivement une experience de Direction d’une unité operational, de Director financier puis de Secretary General au sein d’une une <b>E</b>ntreprise de <b>T</b>aille <b>I</b>ntermédiaire. Cette company opérant in a dur contexte international a traversé des périodes de fortes crises.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ensuite_apres_avoir_ete_secretaire_general_du\"><span style=\"font-size: small;\">Then, after serving as Secretary General d’a significant Cabinet d’Avocats, she created son propre cabinet de conseil mettant ses competences en gestion and finances au service of the strategy, of the governance and de l’organisation de his/her clients.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_membre_de_lifa_est_diplomee_de_l\"><span style=\"font-size: small;\">The candidate, member de l’IFA, est graduate de l’IEP Paris, Eco-fi, d’un DESS de banque-assurance and titulaire d’un master de gestion effectué à Dauphine. »</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_825\"><span style=\"font-size: small;\">Ref: 825 </span></p>\n</td></tr></tbody></table>",
    "candidate_a_un_poste_dadministratrice_indepen_6": "<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen\"><span style=\"font-size: small;\"><b> Candidate in a position d’independent director, with good knowledge of le BTP, les services aux companies, la santé, les fonds d’investissement and la communication. </b></span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.apres_avoir_mene_des_travaux_daudit_chez_erns\"><span style=\"font-size: small;\">After having mené des travaux d’audit chez Ernst &amp; Young, the candidate, over the 13 years suivantes, has acquired successivement une experience de Direction d’une unité operational, de Director financier puis de Secretary General au sein d’une une <b>E</b>ntreprise de <b>T</b>aille <b>I</b>ntermédiaire. Cette company opérant in a dur contexte international a traversé des périodes de fortes crises.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ensuite_apres_avoir_ete_secretaire_general_du\"><span style=\"font-size: small;\">Then, after serving as Secretary General d’a significant Cabinet d’Avocats, she created son propre cabinet de conseil mettant ses competences en gestion and finances au service of the strategy, of the governance and de l’organisation de his/her clients.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_membre_de_lifa_est_diplomee_de_l\"><span style=\"font-size: small;\">The candidate, member de l’IFA, est graduate de l’IEP Paris, Eco-fi, d’un DESS de banque-assurance and titulaire d’un master de gestion effectué à Dauphine. »</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_825\"><span style=\"font-size: small;\">Ref: 825 </span></p>",
    "woman_european_company_board_readymba_insead_": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.woman_european_company_board_readymba_insead__2\">\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.woman_european_company_board_ready\"><strong>Woman European Company Board ready </strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.mba_insead_certificate_and_diploma_in_company\">MBA INSEAD, Certificate and Diploma in Company Direction from Institute of Directors (IOD London)</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.en_france_creatrice_de_son_propre_cabinet_de_\"><strong>En France</strong>, founder of her own cabinet de recherche and d’études de marché en IT / Digital, développé jusqu’à 150 personnes sur l’Europe puis revendu à un grand du conseil ; then PDG d’a firm d’étude en Information Technology. <strong>Puis in Europe</strong>, chargée du développement d’a major firm de Conseil en RH and après d’un autre en IT. <strong>Then, longue career in the USA</strong> comme Director Exécutif in various positions for the développement d’a major firm international de conseil en management.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.de_retour_en_europe_membre_du_comite_executif\"><strong>De retour in Europe</strong>, member du Comité Exécutif Europe d’a firm renommé de conseil en leadership and recherche de dirigeants</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.cette_large_experience_internationale_vecue_d\">Cette extensive experience international vécue dans 6 pays lui has enabled de connaître of numerous secteurs B to B, whose digital and also la consumer goods. Son relationnel « Business » (INSEAD, IOD, American Chamber of Commerce Zurich) peut être put at the service d’un Board. A noter : Member for 5 years du Board du CAWC, Connections for Abused Women and their Children à Chicago, Chairwoman of the commission Communication</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_304\">Ref: 304</p>\n</td></tr></tbody></table>",
    "woman_european_company_board_readymba_insead__2": "<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.woman_european_company_board_ready\"><strong>Woman European Company Board ready </strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.mba_insead_certificate_and_diploma_in_company\">MBA INSEAD, Certificate and Diploma in Company Direction from Institute of Directors (IOD London)</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.en_france_creatrice_de_son_propre_cabinet_de_\"><strong>En France</strong>, founder of her own cabinet de recherche and d’études de marché en IT / Digital, développé jusqu’à 150 personnes sur l’Europe puis revendu à un grand du conseil ; then PDG d’a firm d’étude en Information Technology. <strong>Puis in Europe</strong>, chargée du développement d’a major firm de Conseil en RH and après d’un autre en IT. <strong>Then, longue career in the USA</strong> comme Director Exécutif in various positions for the développement d’a major firm international de conseil en management.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.de_retour_en_europe_membre_du_comite_executif\"><strong>De retour in Europe</strong>, member du Comité Exécutif Europe d’a firm renommé de conseil en leadership and recherche de dirigeants</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.cette_large_experience_internationale_vecue_d\">Cette extensive experience international vécue dans 6 pays lui has enabled de connaître of numerous secteurs B to B, whose digital and also la consumer goods. Son relationnel « Business » (INSEAD, IOD, American Chamber of Commerce Zurich) peut être put at the service d’un Board. A noter : Member for 5 years du Board du CAWC, Connections for Abused Women and their Children à Chicago, Chairwoman of the commission Communication</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_304\">Ref: 304</p>",
    "candidate_a_un_poste_dadministratrice_indepen_7": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_8\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_2\"><b><span style=\"font-size: small;\"> </span></b><strong>Candidate in a position d’independent director</strong> Elle apporte 30 years d’experience déroulées in an environment International de structures publiques/privées and in doMaynes varied comme la recherche, la production, la strategy, la risk management (huMayns, capitaux and sociétaux), le management de projets and of teams, le « mentoring » de Startups. Ses doMaynes clés d’intervention sont l’industrie pharmaceutique and chimique en collaboration étroite and permanente with a tissu de PME locales and international. Building on toutes ces expériences and expertises, elle a la capacité à intervenir dans of numerous industries connexes or complémentaires (équipementiers, cosmetics, agrochimique…). Son intérêt for a développement économique in a sustainable and equitable way est son fil conducteur parce qu’she believes in l’intelligence collective, la co-construction and la collaboration as the foundation of success d’une company and plus largement de notre company. The candidate a une formation de Docteur Engineer en Chimie, she is certified Director par l’EM Lyon.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_299\">Ref 299</p>\n</td></tr></tbody></table>",
    "candidate_a_un_poste_dadministratrice_indepen_8": "<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_2\"><b><span style=\"font-size: small;\"> </span></b><strong>Candidate in a position d’independent director</strong> Elle apporte 30 years d’experience déroulées in an environment International de structures publiques/privées and in doMaynes varied comme la recherche, la production, la strategy, la risk management (huMayns, capitaux and sociétaux), le management de projets and of teams, le « mentoring » de Startups. Ses doMaynes clés d’intervention sont l’industrie pharmaceutique and chimique en collaboration étroite and permanente with a tissu de PME locales and international. Building on toutes ces expériences and expertises, elle a la capacité à intervenir dans of numerous industries connexes or complémentaires (équipementiers, cosmetics, agrochimique…). Son intérêt for a développement économique in a sustainable and equitable way est son fil conducteur parce qu’she believes in l’intelligence collective, la co-construction and la collaboration as the foundation of success d’une company and plus largement de notre company. The candidate a une formation de Docteur Engineer en Chimie, she is certified Director par l’EM Lyon.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_299\">Ref 299</p>",
    "la_candidate_a_un_poste_dadministratrice_inde_5": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde_6\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde\"><b><span style=\"font-size: small;\"> The candidate in a position d’independent director</span></b> <span style=\"font-size: small;\">est aujourd’hui consultante and enseignante en finances à l’Ecole Nationale des Ponts and Chaussées. Elle has obtained un DECS de Comptabilité and un Executive MBA en Management in New York University. Stern Business School. Bilingue French English avec 26 years d’experience comme CFO and Administratif au sein d’companies international (dont in the USA) dans divers secteurs d’activité, in particular les consumer products and le luxe. Très operational and proche du business, she has expertise en strategy, organisation, management and systèmes d’information. Authorized representative d’une fondation d’company and Member du Board de EPWN, she has experienced de l’intérieur le fonctionnement d’un Conseil d’Administration. Member de l’IFA, de Women Corporate Directors and de EPWN</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_302\"><span style=\"font-size: small;\">Ref: 302</span></p>\n</td></tr></tbody></table>",
    "la_candidate_a_un_poste_dadministratrice_inde_6": "<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde\"><b><span style=\"font-size: small;\"> The candidate in a position d’independent director</span></b> <span style=\"font-size: small;\">est aujourd’hui consultante and enseignante en finances à l’Ecole Nationale des Ponts and Chaussées. Elle has obtained un DECS de Comptabilité and un Executive MBA en Management in New York University. Stern Business School. Bilingue French English avec 26 years d’experience comme CFO and Administratif au sein d’companies international (dont in the USA) dans divers secteurs d’activité, in particular les consumer products and le luxe. Très operational and proche du business, she has expertise en strategy, organisation, management and systèmes d’information. Authorized representative d’une fondation d’company and Member du Board de EPWN, she has experienced de l’intérieur le fonctionnement d’un Conseil d’Administration. Member de l’IFA, de Women Corporate Directors and de EPWN</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_302\"><span style=\"font-size: small;\">Ref: 302</span></p>",
    "la_candidate_a_un_poste_dadministratrice_inde_7": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde_8\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde_2\"><b><span style=\"font-size: small;\"> The candidate in a position d’independent director Trés extensive experience international en développement d’affaires, Biotechnologies</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_ecole_des_mines_et_biotechnology\"><span style=\"font-size: small;\">The candidate ( Ecole des Mines and Biotechnology au MIT), réside in Germany depuis l’an 2000, Nombreuses années hors de France: USA + différents pays European. Conseil en strategy chez Bain, Director operational chez Pasteur-Mérieux, notably pour an operation de « spin-off » / vente d’une activité. Depuis 8 years, réussit comme independent consultant for the lancement / développement international de start-up (biotechnologie and santé).</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_603\"><span style=\"font-size: small;\">Ref: 603</span></p>\n</td></tr></tbody></table>",
    "la_candidate_a_un_poste_dadministratrice_inde_8": "<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde_2\"><b><span style=\"font-size: small;\"> The candidate in a position d’independent director Trés extensive experience international en développement d’affaires, Biotechnologies</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_ecole_des_mines_et_biotechnology\"><span style=\"font-size: small;\">The candidate ( Ecole des Mines and Biotechnology au MIT), réside in Germany depuis l’an 2000, Nombreuses années hors de France: USA + différents pays European. Conseil en strategy chez Bain, Director operational chez Pasteur-Mérieux, notably pour an operation de « spin-off » / vente d’une activité. Depuis 8 years, réussit comme independent consultant for the lancement / développement international de start-up (biotechnologie and santé).</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_603\"><span style=\"font-size: small;\">Ref: 603</span></p>",
    "candidate_a_un_poste_de_directrice_de_linnova_2": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_de_directrice_de_linnova_3\"><div align=\"left\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_de_directrice_de_linnova\"><strong>Candidate in a position de Director de l’Innovation, Knowledge ofs Conseils d’Adminsitration</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_est_de_formation_initiale_ingeni\">The candidate est by training initiale engineer docteur en industrial engineering (INPG), puis she has obtained un « Executive MBA » and un doctorat en business administration (IAE, PSB). Elle a 15 years d’experience in a groupe papetier international pour piloter de manière transverse le développement operational and strategic de l’innovation (multiples imprégnations international dont l’Allemagne où she has experienced, les USA, l’Espagne). Depuis 9 years, she has developed son activité de conseil en management de l’innovation and in parallel encadre of research académiques on the culture d’innovation : among other things, le management of the créativité collective. Elle a also une good knowledge ofs Conseils d’Administration, car she is certified as director par l’ADAE, of which she est devenue member du Comex and coordinatrice pédagogique of the formation d’directors. Elle dirige furthermore une collection d’ouvrages on the nouvelles tendances de valeur and la performance des « Boards ».</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.langues_etrangeres_anglais_allemand_notions_e\">Langues étrangères : English, German – Notions : Spanish, Italian</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_756\">Ref:756</p>\n</div></td></tr></tbody></table>",
    "candidate_a_un_poste_de_directrice_de_linnova_3": "<div align=\"left\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_de_directrice_de_linnova\"><strong>Candidate in a position de Director de l’Innovation, Knowledge ofs Conseils d’Adminsitration</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_est_de_formation_initiale_ingeni\">The candidate est by training initiale engineer docteur en industrial engineering (INPG), puis she has obtained un « Executive MBA » and un doctorat en business administration (IAE, PSB). Elle a 15 years d’experience in a groupe papetier international pour piloter de manière transverse le développement operational and strategic de l’innovation (multiples imprégnations international dont l’Allemagne où she has experienced, les USA, l’Espagne). Depuis 9 years, she has developed son activité de conseil en management de l’innovation and in parallel encadre of research académiques on the culture d’innovation : among other things, le management of the créativité collective. Elle a also une good knowledge ofs Conseils d’Administration, car she is certified as director par l’ADAE, of which she est devenue member du Comex and coordinatrice pédagogique of the formation d’directors. Elle dirige furthermore une collection d’ouvrages on the nouvelles tendances de valeur and la performance des « Boards ».</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.langues_etrangeres_anglais_allemand_notions_e\">Langues étrangères : English, German – Notions : Spanish, Italian</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_756\">Ref:756</p>\n</div>",
    "candidate_a_un_poste_dadministratrice_indepen_9": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_10\">\n<div align=\"left\"><span style=\"font-size: small;\"><b>Candidate in a position d’independent director, she brings over 20 years d’experience à haut niveau in Telecoms à l’international. </b></span></div>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.avec_une_longue_experience_de_direction_gener\"><span style=\"font-size: small;\">Avec une long experience de Senior Management, with opérateurs and with suppliers de Telecoms, the candidate a encadré des international teams and multidisciplinaires (finance, marketing, commercial, développement produit). Member du Executive Committee d’une association mondiale d’opérateurs for more than 10 years, elle acquis une connaissance globale de l’industrie and of his/her acteurs thus qu’une experience de governance.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_une_formation_deconomiste_aux_\"><span style=\"font-size: small;\">The candidate a une formation d’économiste (in the United States and en Suisse) and un MBA d’INSEAD. She is Member du Cercle des Directors d’INSEAD and Women Corporate Directors, Elle possèof the dual nationality French and American.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_108\"><span style=\"font-size: small;\">Ref: 108</span></p>\n</td></tr></tbody></table>",
    "candidate_a_un_poste_dadministratrice_indepen_10": "<div align=\"left\"><span style=\"font-size: small;\"><b>Candidate in a position d’independent director, she brings over 20 years d’experience à haut niveau in Telecoms à l’international. </b></span></div>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.avec_une_longue_experience_de_direction_gener\"><span style=\"font-size: small;\">Avec une long experience de Senior Management, with opérateurs and with suppliers de Telecoms, the candidate a encadré des international teams and multidisciplinaires (finance, marketing, commercial, développement produit). Member du Executive Committee d’une association mondiale d’opérateurs for more than 10 years, elle acquis une connaissance globale de l’industrie and of his/her acteurs thus qu’une experience de governance.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_une_formation_deconomiste_aux_\"><span style=\"font-size: small;\">The candidate a une formation d’économiste (in the United States and en Suisse) and un MBA d’INSEAD. She is Member du Cercle des Directors d’INSEAD and Women Corporate Directors, Elle possèof the dual nationality French and American.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_108\"><span style=\"font-size: small;\">Ref: 108</span></p>",
    "candidate_a_un_poste_dadministratrice_indepen_11": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_12\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_3\"><span style=\"text-align: left; font-weight: bold;\"><strong>Candidate in a position d’independent director. </strong>Experience international varied within grands groupes American and European (Spatial, Médical and Défense), Mays also for PME and startups. </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_un_doctorat_en_mathematiques_appliquees\">Après un doctorat en mathématiques appliquées, pendant une vingtaine d’années, she has managed of large projets (plus de 10 millions d’euros) à l’export (USA, Afrique du Sud, Espagne, Italie, Indonésie, Thaïlande etc…) and des multicultural teams en high technology de l’information and of the communication. Then, in the doMayne l’artificial intelligence, she has worked à définir une nouvelle strategy de développement d’a start-up issue de l’Ecole Normale Supérieure</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ayant_obtenu_des_certificats_pour_evaluation_\">Ayant obtenu of certificates pour évaluation financière and la création de start-up technologique (HEC and Polytechnique), she has joined l’agence de l’innovation industrial puis la grande banque publique d’investissement to provide l’analyse strategic des grands projets sélectionnés (jusqu’à 110 millions d’euros) par ces organismes. Aujourd’hui, en independent, she provides assignments in conseil en strategy. Member du Cercle des Directors .</p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_109\"><span style=\"font-size: small;\">Ref: 109</span></p>\n</td></tr></tbody></table>",
    "candidate_a_un_poste_dadministratrice_indepen_12": "<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_3\"><span style=\"text-align: left; font-weight: bold;\"><strong>Candidate in a position d’independent director. </strong>Experience international varied within grands groupes American and European (Spatial, Médical and Défense), Mays also for PME and startups. </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_un_doctorat_en_mathematiques_appliquees\">Après un doctorat en mathématiques appliquées, pendant une vingtaine d’années, she has managed of large projets (plus de 10 millions d’euros) à l’export (USA, Afrique du Sud, Espagne, Italie, Indonésie, Thaïlande etc…) and des multicultural teams en high technology de l’information and of the communication. Then, in the doMayne l’artificial intelligence, she has worked à définir une nouvelle strategy de développement d’a start-up issue de l’Ecole Normale Supérieure</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ayant_obtenu_des_certificats_pour_evaluation_\">Ayant obtenu of certificates pour évaluation financière and la création de start-up technologique (HEC and Polytechnique), she has joined l’agence de l’innovation industrial puis la grande banque publique d’investissement to provide l’analyse strategic des grands projets sélectionnés (jusqu’à 110 millions d’euros) par ces organismes. Aujourd’hui, en independent, she provides assignments in conseil en strategy. Member du Cercle des Directors .</p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_109\"><span style=\"font-size: small;\">Ref: 109</span></p>",
    "la_candidate_de_formation_ingenieur_insead_a__3": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_de_formation_ingenieur_insead_a__4\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_de_formation_ingenieur_insead_a_\"><b><span style=\"font-size: small;\"> The candidate, by training Engineer + INSEAD, a une long experience de senior management positions and d’director in the sector industrial complétée genuine expertise in risk management of large projets international.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_10_ans_a_des_postes_de_responsabilite_t\"><span style=\"font-size: small;\">Après 10 years à des positions of responsibility technique (études, production, essais, management of large projets), the candidate has held différentes fonctions de Direction concernant des montants pouvant dépasser 500 M€ and comportant un volet international: Strategy, Administration and Finances, Opérations, Contrôle de gestion, Chaîne d’approvisionnement. Cette experience pluridisciplinaire (mécanique, électronique, IT, communications, l’a naturellement conduite vers of positions de Business Unit Director industrial, de Director within Directions Générales and d’Director. The candidate a souvent in parallel exercé des liabilitys transverses en management des risques pluridisciplinaires d’ unités and de projets operational. Cette experience permet aujourd’hui of the considérer comme une experte in this doMayne. Elle donne of courses quant au contrôle des companies ausen angalis de « Management control » dans diverse écoles dont l’ESSEC. The candidate est member de l’IFA and du Cercle des Directors INSEAD / Wharton/….</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_754\"><span style=\"font-size: small;\">ref: 754</span></p>\n</td></tr></tbody></table>",
    "la_candidate_de_formation_ingenieur_insead_a__4": "<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_de_formation_ingenieur_insead_a_\"><b><span style=\"font-size: small;\"> The candidate, by training Engineer + INSEAD, a une long experience de senior management positions and d’director in the sector industrial complétée genuine expertise in risk management of large projets international.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_10_ans_a_des_postes_de_responsabilite_t\"><span style=\"font-size: small;\">Après 10 years à des positions of responsibility technique (études, production, essais, management of large projets), the candidate has held différentes fonctions de Direction concernant des montants pouvant dépasser 500 M€ and comportant un volet international: Strategy, Administration and Finances, Opérations, Contrôle de gestion, Chaîne d’approvisionnement. Cette experience pluridisciplinaire (mécanique, électronique, IT, communications, l’a naturellement conduite vers of positions de Business Unit Director industrial, de Director within Directions Générales and d’Director. The candidate a souvent in parallel exercé des liabilitys transverses en management des risques pluridisciplinaires d’ unités and de projets operational. Cette experience permet aujourd’hui of the considérer comme une experte in this doMayne. Elle donne of courses quant au contrôle des companies ausen angalis de « Management control » dans diverse écoles dont l’ESSEC. The candidate est member de l’IFA and du Cercle des Directors INSEAD / Wharton/….</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_754\"><span style=\"font-size: small;\">ref: 754</span></p>",
    "consultante_franco_suisse_experte_en_gouverna_2": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.consultante_franco_suisse_experte_en_gouverna_3\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.consultante_franco_suisse_experte_en_gouverna\"><b><span style=\"font-size: small;\"> </span></b><strong>Consultante, Franco-Suisse, experte en governance d’family businesses</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_avoir_ete_avocate_au_barreau_de_paris_s\">After serving as Lawyer au Paris Bar, specialised en business law, pendant sept ans, she has led l’family business viticole basée en Gascogne. Son action has been particulièrement orientée on the développement commercial à l’international, and l’ouverture of new marchés. Building on cette experience, for 4 years, she served as Secretary General du Family Business Network France. Elle y a among other things développé un programme pédagogique multidisciplinaire d’ateliers and Lectures for the entrepreneurial families.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_consultante_independante_elle_les_\">Aujourd’hui, independent consultant, elle advises them, in the context d’une l’évolution international accélérée, pour organiser au mieux leur governance and planifier la transmission, in particular within la famille.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.elle_a_suivi_un_cursus_de_droit_des_affaires_\">Elle has followed un cursus de business law and de philosophie du droit, and est holder of the certificat d’aptitude à la profession d’lawyer and d’un master de coaching. Elle vit between the France and l’Italie.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.langues_francais_anglais_italien\">Languages: French – Anglais – Italien</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_832\"><span style=\"font-size: small;\">ref: 832</span></p>\n</td></tr></tbody></table>",
    "consultante_franco_suisse_experte_en_gouverna_3": "<p data-i18n=\"page_candidats_mandataires_sociaux.consultante_franco_suisse_experte_en_gouverna\"><b><span style=\"font-size: small;\"> </span></b><strong>Consultante, Franco-Suisse, experte en governance d’family businesses</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_avoir_ete_avocate_au_barreau_de_paris_s\">After serving as Lawyer au Paris Bar, specialised en business law, pendant sept ans, she has led l’family business viticole basée en Gascogne. Son action has been particulièrement orientée on the développement commercial à l’international, and l’ouverture of new marchés. Building on cette experience, for 4 years, she served as Secretary General du Family Business Network France. Elle y a among other things développé un programme pédagogique multidisciplinaire d’ateliers and Lectures for the entrepreneurial families.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_consultante_independante_elle_les_\">Aujourd’hui, independent consultant, elle advises them, in the context d’une l’évolution international accélérée, pour organiser au mieux leur governance and planifier la transmission, in particular within la famille.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.elle_a_suivi_un_cursus_de_droit_des_affaires_\">Elle has followed un cursus de business law and de philosophie du droit, and est holder of the certificat d’aptitude à la profession d’lawyer and d’un master de coaching. Elle vit between the France and l’Italie.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.langues_francais_anglais_italien\">Languages: French – Anglais – Italien</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_832\"><span style=\"font-size: small;\">ref: 832</span></p>",
    "administratrice_independante_de_nationalite_f_2": "<div align=\"center\"><table border=\"0\" cellpadding=\"5\" width=\"510\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_de_nationalite_f_3\" width=\"492\">\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_de_nationalite_f\"><strong>Independent director de nationalité French vivant aujourd’hui in Madrid. Extensive experience operational in the business des telecommunications, puis in a ONG Internationale and aujourd’hui entrepreneur.</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_un_dea_deconomie_a_paris_la_sorbonne_et\">Après un DEA d’économie in Paris La Sorbonne and un MBA à l’Université de San Francisco aux Etats Unis, the candidate a for 7 years travaillé au sein d’un grand opérateur French des telecommunications. She was la première femme à rejoindre la division Internationale, en tant qu’expatriée, in charge of launching of activities commerciales in Spain. Elle y demeurera for thencer les activités d’un autre groupe du même secteur and prendre la liability of their subsidiary in Spain and au Portugal. Elle a then pendant quatre ans été manager for the péninsule ibérique de subsidiaries de companies américaines de telecommunications, listed au Nasdaq (matériels and software).</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ensuite_durant_6_annees_elle_a_ete_responsabl\">Then, durant 6 years, she served as responsible for les pays latins d’une grande ONG international visant la promotion de the presence des femmes en company à des positions of responsibility and conseils d’administration. Elle has developed une expertise in gestion of the diversité.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_elle_a_cree_sa_propre_entreprise_d\">Aujourd’hui, she created his/her own company de consulting pour, within the companies, tel a major group de cosmétiques, développer l’esprit d’équipe, le leadership and faciliter l’évolution des organisations, among other things en utilisant le coaching, la musique and les rythmes. Mentor within l’association international Professional Women Network (PWN) as well as member de l’Association Spanish Women CEO. Languages: French, Anglais, Espagnol.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_723\">Ref 723</p>\n</td></tr></tbody></table></div>\n<p align=\"center\"> </p>",
    "administratrice_independante_de_nationalite_f_3": "<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_de_nationalite_f\"><strong>Independent director de nationalité French vivant aujourd’hui in Madrid. Extensive experience operational in the business des telecommunications, puis in a ONG Internationale and aujourd’hui entrepreneur.</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_un_dea_deconomie_a_paris_la_sorbonne_et\">Après un DEA d’économie in Paris La Sorbonne and un MBA à l’Université de San Francisco aux Etats Unis, the candidate a for 7 years travaillé au sein d’un grand opérateur French des telecommunications. She was la première femme à rejoindre la division Internationale, en tant qu’expatriée, in charge of launching of activities commerciales in Spain. Elle y demeurera for thencer les activités d’un autre groupe du même secteur and prendre la liability of their subsidiary in Spain and au Portugal. Elle a then pendant quatre ans été manager for the péninsule ibérique de subsidiaries de companies américaines de telecommunications, listed au Nasdaq (matériels and software).</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ensuite_durant_6_annees_elle_a_ete_responsabl\">Then, durant 6 years, she served as responsible for les pays latins d’une grande ONG international visant la promotion de the presence des femmes en company à des positions of responsibility and conseils d’administration. Elle has developed une expertise in gestion of the diversité.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_elle_a_cree_sa_propre_entreprise_d\">Aujourd’hui, she created his/her own company de consulting pour, within the companies, tel a major group de cosmétiques, développer l’esprit d’équipe, le leadership and faciliter l’évolution des organisations, among other things en utilisant le coaching, la musique and les rythmes. Mentor within l’association international Professional Women Network (PWN) as well as member de l’Association Spanish Women CEO. Languages: French, Anglais, Espagnol.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_723\">Ref 723</p>",
    "administratrice_independante_experimentee_jur_2": "<table align=\"center\" border=\"0\" cellpadding=\"5\" width=\"526\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_experimentee_jur_3\" width=\"512\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_experimentee_jur\"><strong>Independent director expérimentée, legal professional de nationalité Spanish with a extensive experience du business European including via Internet</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_une_formation_de_juriste_en_espagne_et_\">Après une formation of thegal professional in Spain and in Germany, the candidate has held for 5 years in Brussels , Madrid and Barcelone in several cabinets d’lawyers d’affaire l’un Spanish and deux American: Traitement de conflits très varied en amont of actions devant les tribunaux, including vis-à-vis of the European Commission : customs duties, abuse of dominant position, accord commerciaux, fusions acquisitions,… Then, for 6 years, elle fait partie du Cabinet de M. Marcelino Oreja, member of the European Commission , in charge of la Direction du suivi des Entreprises, responsible for the actions concertées between the Commission and les Etats members for the politiques d’amélioration de l’environnement and du développement des companies Puis in Madrid, she served as la conceptrice, and la responsible for l’animation d’un grand projet de plateforme de e-commerce destiné à faciliter les transactions de international trade. Il avait comme objectif de permettre les échanges commerciaux avec d’importantes réductions de coûts in exportations and importations Ce projet a bénéficié de soutiens financiers de l’Union Européenne, de chambres de commerce and of various associations issues de 8 pays European. Un prototype operational was able to être réalisé. Le projet a reçu plusieurs prix and distinctions.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.en_parallele_elle_a_ete_directrice_juridique_\">In parallel, she served as Legal Director and conseillère du Chairman d’un très grand groupe Spanish du doMayne des produits alimentaires and of the construction d’ensembles tels des hôtels. Elle a in particular participé à la création d’un portail internet pour élargir la base des consommateurs. Aujourd’hui, she created son propre cabinet de Conseil tant for the companies que for the organismes publics. Elle peut leur provide the benefit of of her extensive experience European, Mays also in mise en place de relations with the Chine and les pays d’Amérique Latine.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.en_espagne_elle_a_ete_administratrice_de_la_c\">En Espagne, she has served as director of the Confédération des employeurs espagnols, Vice Chairwoman de Women CEO and in a large ville de l’Est des USA, director d’une grande école international as well as d’une ONG visant l’amélioration des conditions de vie des personnes défavorisées. En 2013, she has participated au cours<strong><em> « </em></strong><em>Making corporate boards more effective</em> « à Harward Business School.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_762\">Ref 762</p>\n</td></tr></tbody></table>",
    "administratrice_independante_experimentee_jur_3": "<p data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_experimentee_jur\"><strong>Independent director expérimentée, legal professional de nationalité Spanish with a extensive experience du business European including via Internet</strong></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_une_formation_de_juriste_en_espagne_et_\">Après une formation of thegal professional in Spain and in Germany, the candidate has held for 5 years in Brussels , Madrid and Barcelone in several cabinets d’lawyers d’affaire l’un Spanish and deux American: Traitement de conflits très varied en amont of actions devant les tribunaux, including vis-à-vis of the European Commission : customs duties, abuse of dominant position, accord commerciaux, fusions acquisitions,… Then, for 6 years, elle fait partie du Cabinet de M. Marcelino Oreja, member of the European Commission , in charge of la Direction du suivi des Entreprises, responsible for the actions concertées between the Commission and les Etats members for the politiques d’amélioration de l’environnement and du développement des companies Puis in Madrid, she served as la conceptrice, and la responsible for l’animation d’un grand projet de plateforme de e-commerce destiné à faciliter les transactions de international trade. Il avait comme objectif de permettre les échanges commerciaux avec d’importantes réductions de coûts in exportations and importations Ce projet a bénéficié de soutiens financiers de l’Union Européenne, de chambres de commerce and of various associations issues de 8 pays European. Un prototype operational was able to être réalisé. Le projet a reçu plusieurs prix and distinctions.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.en_parallele_elle_a_ete_directrice_juridique_\">In parallel, she served as Legal Director and conseillère du Chairman d’un très grand groupe Spanish du doMayne des produits alimentaires and of the construction d’ensembles tels des hôtels. Elle a in particular participé à la création d’un portail internet pour élargir la base des consommateurs. Aujourd’hui, she created son propre cabinet de Conseil tant for the companies que for the organismes publics. Elle peut leur provide the benefit of of her extensive experience European, Mays also in mise en place de relations with the Chine and les pays d’Amérique Latine.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.en_espagne_elle_a_ete_administratrice_de_la_c\">En Espagne, she has served as director of the Confédération des employeurs espagnols, Vice Chairwoman de Women CEO and in a large ville de l’Est des USA, director d’une grande école international as well as d’une ONG visant l’amélioration des conditions de vie des personnes défavorisées. En 2013, she has participated au cours<strong><em> « </em></strong><em>Making corporate boards more effective</em> « à Harward Business School.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_762\">Ref 762</p>",
    "la_candidate_a_un_poste_dadministratrice_inde_9": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr style=\"font-size: 12px;\"><td data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde_10\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde_3\" style=\"text-align: left; font-size: 10pt;\"><span style=\"font-weight: bold;\">The candidate in a position d’independent director, de nationalité French and American, est based in the USA and in France. Parcours anglo-saxon de 30 years à la croisée de l’real estate and of the finance</span> chez Bank of America, General Motors, EY, …or au service de clients institutionnels comme la World Bank or BlackRock. Elle a eu tour à tour des rôles d’analyste, d’émetteur, d’évaluateur, de prêteur, and d’investor</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.elle_a_mene_plusieurs_operations_de_fusion_ac\" style=\"text-align: left; font-size: 10pt;\">Elle has led plusieurs opérations de merger and acquisition or vente de companies, and siégé in several conseils d’administration de subsidiaries d’a major group.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_consultante_independante_connaissa\">Aujourd’hui , independent consultant, with good knowledge of les Etats-Unis, le Canada, les pays d’Europe de l’Ouest and la Russie, she works à l’international pour accompagner des acteurs institutionnels à bien formuler and exécuter leurs stratégies immobilières. Elle siège au conseil moreoverieurs associations professional immobilières.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.certifications_immobilieres_courantes_avec_ob\"><strong style=\"font-weight: normal;\">Certifications immobilières courantes, avec obligation by training continue: </strong> Aux USA: MAI (Member of the Appraisal Institute), CRE (Counselors of Real Estate) En Europe: FRICS: Fellow of the Royal Institution of the Chartered Surveyors</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.formation_sciences_po_paris_institut_durbanis\"><strong>Formation</strong>: Sciences-Po Paris, Institut d’Urbanisme de Paris, New York University Director certified (IFA)</p>\n<p align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.ref_320\" style=\"font-size: 12px; text-align: left;\">Ref: 320</p>\n</td></tr></tbody></table>",
    "la_candidate_a_un_poste_dadministratrice_inde_10": "<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde_3\" style=\"text-align: left; font-size: 10pt;\"><span style=\"font-weight: bold;\">The candidate in a position d’independent director, de nationalité French and American, est based in the USA and in France. Parcours anglo-saxon de 30 years à la croisée de l’real estate and of the finance</span> chez Bank of America, General Motors, EY, …or au service de clients institutionnels comme la World Bank or BlackRock. Elle a eu tour à tour des rôles d’analyste, d’émetteur, d’évaluateur, de prêteur, and d’investor</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.elle_a_mene_plusieurs_operations_de_fusion_ac\" style=\"text-align: left; font-size: 10pt;\">Elle has led plusieurs opérations de merger and acquisition or vente de companies, and siégé in several conseils d’administration de subsidiaries d’a major group.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_consultante_independante_connaissa\">Aujourd’hui , independent consultant, with good knowledge of les Etats-Unis, le Canada, les pays d’Europe de l’Ouest and la Russie, she works à l’international pour accompagner des acteurs institutionnels à bien formuler and exécuter leurs stratégies immobilières. Elle siège au conseil moreoverieurs associations professional immobilières.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.certifications_immobilieres_courantes_avec_ob\"><strong style=\"font-weight: normal;\">Certifications immobilières courantes, avec obligation by training continue: </strong> Aux USA: MAI (Member of the Appraisal Institute), CRE (Counselors of Real Estate) En Europe: FRICS: Fellow of the Royal Institution of the Chartered Surveyors</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.formation_sciences_po_paris_institut_durbanis\"><strong>Formation</strong>: Sciences-Po Paris, Institut d’Urbanisme de Paris, New York University Director certified (IFA)</p>\n<p align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.ref_320\" style=\"font-size: 12px; text-align: left;\">Ref: 320</p>",
    "diplomee_de_liae_de_nice_de_paris_i_pantheon__2": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.diplomee_de_liae_de_nice_de_paris_i_pantheon__3\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.diplomee_de_liae_de_nice_de_paris_i_pantheon_\" style=\"text-align: left; font-size: 10pt;\"><span style=\"font-weight: bold;\">Graduate de l’IAE de Nice, de Paris I Panthéon Sorbonne and d´HEC, avec orientation à l’international, au commercial and marketing, the candidate de nationalité franco-bulgare has spent un tiers of her vie professional à l’étranger, Bulgarie, Maroc, Italie, USA, France</span>, etc.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.elle_a_20_ans_dexperience_de_directions_opera\" style=\"text-align: left; font-size: 10pt;\">Elle a 20 years d’experience de directions operational and strategic, secteurs of the pharmaceutical distribution, des biens d’équipement and des services, in companies italiennes, françaises and japonaises in Europe. Elle has to her/his credit plusieurs delicate turnarounds and has experienced deux situations particulières: introduction à la bourse de NYSE and rachat hostile par a major group japonais.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.elle_a_egalement_acquis_une_bonne_connaissanc\" style=\"text-align: left; font-size: 10pt;\">Elle a also acquis une bonne connaissance du fonctionnement des Conseils, d’une part, as member de Executive Committees (présentations devant les directors), and d’autre part, pour avoir in fact in several circonstances joué le rôle d’un Secrétaire de Conseil (préparations of files for the CA, knowledge ofs stakeholders, rapports de governance).</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.elle_est_actuellement_conseil_independant_en_\" style=\"text-align: left; font-size: 10pt;\">She is currently independent advisor en strategy, accompagnatrice de créateurs d’company or d’activités innovantes of large groupes, specialised in valorisation &amp; développement des marques, member du strategic committee d’a start-up and conseiller en career bénévole (mentoring HEC). Member de l’Institut French des Directors, of the French American Foundation, du Professional’s Women Network and du groupement governance HEC.</p>\n<p align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.ref_617\" style=\"font-size: 12px; text-align: left;\">Ref: 617</p>\n</td></tr></tbody></table>",
    "diplomee_de_liae_de_nice_de_paris_i_pantheon__3": "<p data-i18n=\"page_candidats_mandataires_sociaux.diplomee_de_liae_de_nice_de_paris_i_pantheon_\" style=\"text-align: left; font-size: 10pt;\"><span style=\"font-weight: bold;\">Graduate de l’IAE de Nice, de Paris I Panthéon Sorbonne and d´HEC, avec orientation à l’international, au commercial and marketing, the candidate de nationalité franco-bulgare has spent un tiers of her vie professional à l’étranger, Bulgarie, Maroc, Italie, USA, France</span>, etc.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.elle_a_20_ans_dexperience_de_directions_opera\" style=\"text-align: left; font-size: 10pt;\">Elle a 20 years d’experience de directions operational and strategic, secteurs of the pharmaceutical distribution, des biens d’équipement and des services, in companies italiennes, françaises and japonaises in Europe. Elle has to her/his credit plusieurs delicate turnarounds and has experienced deux situations particulières: introduction à la bourse de NYSE and rachat hostile par a major group japonais.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.elle_a_egalement_acquis_une_bonne_connaissanc\" style=\"text-align: left; font-size: 10pt;\">Elle a also acquis une bonne connaissance du fonctionnement des Conseils, d’une part, as member de Executive Committees (présentations devant les directors), and d’autre part, pour avoir in fact in several circonstances joué le rôle d’un Secrétaire de Conseil (préparations of files for the CA, knowledge ofs stakeholders, rapports de governance).</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.elle_est_actuellement_conseil_independant_en_\" style=\"text-align: left; font-size: 10pt;\">She is currently independent advisor en strategy, accompagnatrice de créateurs d’company or d’activités innovantes of large groupes, specialised in valorisation &amp; développement des marques, member du strategic committee d’a start-up and conseiller en career bénévole (mentoring HEC). Member de l’Institut French des Directors, of the French American Foundation, du Professional’s Women Network and du groupement governance HEC.</p>\n<p align=\"center\" data-i18n=\"page_candidats_mandataires_sociaux.ref_617\" style=\"font-size: 12px; text-align: left;\">Ref: 617</p>",
    "la_candidate_de_formation_ingenieur_insead_a__5": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_de_formation_ingenieur_insead_a__6\" height=\"203\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_de_formation_ingenieur_insead_a__2\"><b><span style=\"font-size: small;\"> The candidate, by training Engineer + INSEAD, a une long experience de senior management positions and d’director in the sector industrial complétée genuine expertise in risk management of large projets international.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_10_ans_a_des_postes_de_responsabilite_t_2\"><span style=\"font-size: small;\">Après 10 years à des positions of responsibility technique (études, production, essais, management of large projets), the candidate has held différentes fonctions de Direction concernant des montants pouvant dépasser 500 M€ and comportant un volet international: Strategy, Administration and Finances, Opérations, Contrôle de gestion, Chaîne d’approvisionnement. Cette experience pluridisciplinaire (mécanique, électronique, IT, communications, l’a naturellement conduite vers of positions de Business Unit Director industrial, de Director within Directions Générales and d’Director. The candidate a souvent in parallel exercé des liabilitys transverses en management des risques pluridisciplinaires d’ unités and de projets operational. Cette experience permet aujourd’hui of the considérer comme une experte in this doMayne. Elle donne of courses de « Contrôle des companies » en English « Management control » dans diverses écoles dont l’ESSEC.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_est_membre_de_lifa_et_du_cercle_\">The candidate est member de l’IFA and du Cercle des Directors INSEAD / Wharton/….</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_754_2\"><span style=\"font-size: small;\">Ref: 754</span></p>\n</td></tr></tbody></table>",
    "la_candidate_de_formation_ingenieur_insead_a__6": "<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_de_formation_ingenieur_insead_a__2\"><b><span style=\"font-size: small;\"> The candidate, by training Engineer + INSEAD, a une long experience de senior management positions and d’director in the sector industrial complétée genuine expertise in risk management of large projets international.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_10_ans_a_des_postes_de_responsabilite_t_2\"><span style=\"font-size: small;\">Après 10 years à des positions of responsibility technique (études, production, essais, management of large projets), the candidate has held différentes fonctions de Direction concernant des montants pouvant dépasser 500 M€ and comportant un volet international: Strategy, Administration and Finances, Opérations, Contrôle de gestion, Chaîne d’approvisionnement. Cette experience pluridisciplinaire (mécanique, électronique, IT, communications, l’a naturellement conduite vers of positions de Business Unit Director industrial, de Director within Directions Générales and d’Director. The candidate a souvent in parallel exercé des liabilitys transverses en management des risques pluridisciplinaires d’ unités and de projets operational. Cette experience permet aujourd’hui of the considérer comme une experte in this doMayne. Elle donne of courses de « Contrôle des companies » en English « Management control » dans diverses écoles dont l’ESSEC.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_est_membre_de_lifa_et_du_cercle_\">The candidate est member de l’IFA and du Cercle des Directors INSEAD / Wharton/….</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_754_2\"><span style=\"font-size: small;\">Ref: 754</span></p>",
    "administratrice_independante_grande_societe_e_2": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_grande_societe_e_3\" height=\"413\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_grande_societe_e\"><b><span style=\"font-size: small;\"> Independent director, Grande Société Européenne</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_domiciliee_depuis_25_ans_a_paris\"><span style=\"font-size: small;\">The candidate based depuis 25 years in Paris possèof the dual nationality French and Spanish. Son experience en management d’opérations hautement strategic pour of large listed companies du Royaume-Uni, of the France, and of the Belgique has been accumulée sur 30 years. D’abord, and in depth, within the secteur des telecommunications, Mays also plus recently for the santé (hôpitaux) and l’industrie alimentaire (Pêche). Elle a his/her credit plusieurs delicate turnarounds comme member du Conseil d’Administration devant superviser le bon déroulement operational, comme member du Comex, and comme consultant. Independent director d’une company Norwegian, she has experienced deux situations very enriching : listing on the stock exchange de Londres and rachat hostile par a major group German.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.dans_un_contexte_franco_espagnol_tendu_elle_a\">Dans un contexte franco Spanish tendu, she served as CEO, puis Chairwoman du Conseil d’Administration of the  » joint-venture  » Spanish of two groupes issus (IBEX35 / CAC40). Son experience international est European and plus particulièrement for the pays du Sud dont she speaks les langues couramment, Mays s’étend à l’Amérique du Sud.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.formation_computing_sciences_engineer_cours_p\">Education: Computing Sciences Engineer, + Cours pour Dirigeants à l’INSEAD. Member du Board International du Global Telecommunications Women Network and in Spain de  » Plataforma de Expertas « . Member du  » Achieving Outstanding Performance  » (AoP) and TMT Group’s de l’INSEAD</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_753\"><span style=\"font-size: small;\">Ref: 753 </span></p>\n</td></tr></tbody></table>",
    "administratrice_independante_grande_societe_e_3": "<p data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_grande_societe_e\"><b><span style=\"font-size: small;\"> Independent director, Grande Société Européenne</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_domiciliee_depuis_25_ans_a_paris\"><span style=\"font-size: small;\">The candidate based depuis 25 years in Paris possèof the dual nationality French and Spanish. Son experience en management d’opérations hautement strategic pour of large listed companies du Royaume-Uni, of the France, and of the Belgique has been accumulée sur 30 years. D’abord, and in depth, within the secteur des telecommunications, Mays also plus recently for the santé (hôpitaux) and l’industrie alimentaire (Pêche). Elle a his/her credit plusieurs delicate turnarounds comme member du Conseil d’Administration devant superviser le bon déroulement operational, comme member du Comex, and comme consultant. Independent director d’une company Norwegian, she has experienced deux situations very enriching : listing on the stock exchange de Londres and rachat hostile par a major group German.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.dans_un_contexte_franco_espagnol_tendu_elle_a\">Dans un contexte franco Spanish tendu, she served as CEO, puis Chairwoman du Conseil d’Administration of the  » joint-venture  » Spanish of two groupes issus (IBEX35 / CAC40). Son experience international est European and plus particulièrement for the pays du Sud dont she speaks les langues couramment, Mays s’étend à l’Amérique du Sud.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.formation_computing_sciences_engineer_cours_p\">Education: Computing Sciences Engineer, + Cours pour Dirigeants à l’INSEAD. Member du Board International du Global Telecommunications Women Network and in Spain de  » Plataforma de Expertas « . Member du  » Achieving Outstanding Performance  » (AoP) and TMT Group’s de l’INSEAD</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_753\"><span style=\"font-size: small;\">Ref: 753 </span></p>",
    "actuellement_directeur_grands_comptes_dans_un_2": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"97%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.actuellement_directeur_grands_comptes_dans_un_3\" height=\"165\" valign=\"top\"><table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.actuellement_directeur_grands_comptes_dans_un_4\" height=\"232\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.actuellement_directeur_grands_comptes_dans_un\"><b><span style=\"font-size: small;\">Currently Director «  Grands Comptes  » in a company international de telecommunications listed, the candidate recherche, en accord with his/her employeur, a mandatee d’independent director.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.pendant_plus_de_15_ans_la_candidate_a_travail\"><span style=\"font-size: small;\">Pendant over 15 years, the candidate has worked in the Conseil and l’Ingénierie (IT, électronique, process,…), au sein d’un groupe international côté, for the Développement and le Management de Grands Comptes, notably de l’Industrie (automobile, médical, défense,…) and des Telecoms.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_une_expertise_de_business_deve\">The candidate a une expertise de  » Business Developer  » thus qu’une forte ouverture marketing and RH. Within subsidiaries (60 à 800 personnes avec pour certaines des chiffres d’affaires moreover de 500 M€), she served as Director (France and Espagne) , CEO and Chairwoman (SAS). Elle a furthermore exercé des liabilitys transverses and contribué à la transformation d’organisations, tant en période de croissance qu’en période de crise.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.membre_de_leuropean_professionals_women_netwo\"><span style=\"font-size: small;\">Member de l’European Professional’s Women Network, du Cercle Governance and Equilibre, certified par l’Essec for the formation spécifique pour devenir director  » Women Be European Board Ready  » </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_604\"><span style=\"font-size: small;\">Ref: 604</span></p>\n</td></tr></tbody></table></td></tr></tbody></table>",
    "actuellement_directeur_grands_comptes_dans_un_3": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.actuellement_directeur_grands_comptes_dans_un_4\" height=\"232\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.actuellement_directeur_grands_comptes_dans_un\"><b><span style=\"font-size: small;\">Currently Director «  Grands Comptes  » in a company international de telecommunications listed, the candidate recherche, en accord with his/her employeur, a mandatee d’independent director.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.pendant_plus_de_15_ans_la_candidate_a_travail\"><span style=\"font-size: small;\">Pendant over 15 years, the candidate has worked in the Conseil and l’Ingénierie (IT, électronique, process,…), au sein d’un groupe international côté, for the Développement and le Management de Grands Comptes, notably de l’Industrie (automobile, médical, défense,…) and des Telecoms.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_une_expertise_de_business_deve\">The candidate a une expertise de  » Business Developer  » thus qu’une forte ouverture marketing and RH. Within subsidiaries (60 à 800 personnes avec pour certaines des chiffres d’affaires moreover de 500 M€), she served as Director (France and Espagne) , CEO and Chairwoman (SAS). Elle a furthermore exercé des liabilitys transverses and contribué à la transformation d’organisations, tant en période de croissance qu’en période de crise.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.membre_de_leuropean_professionals_women_netwo\"><span style=\"font-size: small;\">Member de l’European Professional’s Women Network, du Cercle Governance and Equilibre, certified par l’Essec for the formation spécifique pour devenir director  » Women Be European Board Ready  » </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_604\"><span style=\"font-size: small;\">Ref: 604</span></p>\n</td></tr></tbody></table>",
    "actuellement_directeur_grands_comptes_dans_un_4": "<p data-i18n=\"page_candidats_mandataires_sociaux.actuellement_directeur_grands_comptes_dans_un\"><b><span style=\"font-size: small;\">Currently Director «  Grands Comptes  » in a company international de telecommunications listed, the candidate recherche, en accord with his/her employeur, a mandatee d’independent director.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.pendant_plus_de_15_ans_la_candidate_a_travail\"><span style=\"font-size: small;\">Pendant over 15 years, the candidate has worked in the Conseil and l’Ingénierie (IT, électronique, process,…), au sein d’un groupe international côté, for the Développement and le Management de Grands Comptes, notably de l’Industrie (automobile, médical, défense,…) and des Telecoms.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_une_expertise_de_business_deve\">The candidate a une expertise de  » Business Developer  » thus qu’une forte ouverture marketing and RH. Within subsidiaries (60 à 800 personnes avec pour certaines des chiffres d’affaires moreover de 500 M€), she served as Director (France and Espagne) , CEO and Chairwoman (SAS). Elle a furthermore exercé des liabilitys transverses and contribué à la transformation d’organisations, tant en période de croissance qu’en période de crise.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.membre_de_leuropean_professionals_women_netwo\"><span style=\"font-size: small;\">Member de l’European Professional’s Women Network, du Cercle Governance and Equilibre, certified par l’Essec for the formation spécifique pour devenir director  » Women Be European Board Ready  » </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_604\"><span style=\"font-size: small;\">Ref: 604</span></p>",
    "la_candidate_pharmacie_mba_actuellement_conse_2": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"97%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_pharmacie_mba_actuellement_conse_3\" height=\"165\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_pharmacie_mba_actuellement_conse\"><b><span style=\"font-size: small;\"> </span></b><b><span style=\"font-size: small;\">The candidate, Pharmacie-MBA, currently independent advisor en strategy, a 30 years d’experience de directions operational and strategic in the sectors des consumer products and pharmaceutiques. Son experience international successful, among other things comme «  commerciale de haut niveau « , démontre great adaptability dans multicultural environments.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde_4\"><b></b><span style=\"font-size: small;\">The candidate in a position d’independent director has started sa career in recherche and le développement en laboratoire and industrie pharmaceutique. Elle a then été consultante en strategy pour a major firm international où she has led of projects in several industries (Pharmaceuticals, Ind. Agro. Alim., Distribution, secteurs where a Consehe could benefit from his/her experience). Then, in a groupe international leader in the sector des boissons, elle passé over 20 years à diverhis/her responsibilities operational (profit centers, ventes-marketing, innovation) and strategic in France and worldwide. In this capacity, she has participated aux Executive Committees, has led des grandes multicultural teams and fonctionnelles. Elle sait ce que signifie conduire within the framework d’une vision strategic of actions on the terrain. D’une famille d’entrepreneurs, she has invested in start-ups and supports them. Elle sait donc s’adapter à des organisations of different tailles. Trilingual French/English/German, member de l’IFA</span><b><span style=\"font-size: small;\">. </span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_632\"><span style=\"font-size: small;\">Ref: 632</span></p>\n</td></tr></tbody></table>",
    "la_candidate_pharmacie_mba_actuellement_conse_3": "<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_pharmacie_mba_actuellement_conse\"><b><span style=\"font-size: small;\"> </span></b><b><span style=\"font-size: small;\">The candidate, Pharmacie-MBA, currently independent advisor en strategy, a 30 years d’experience de directions operational and strategic in the sectors des consumer products and pharmaceutiques. Son experience international successful, among other things comme «  commerciale de haut niveau « , démontre great adaptability dans multicultural environments.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_dadministratrice_inde_4\"><b></b><span style=\"font-size: small;\">The candidate in a position d’independent director has started sa career in recherche and le développement en laboratoire and industrie pharmaceutique. Elle a then été consultante en strategy pour a major firm international où she has led of projects in several industries (Pharmaceuticals, Ind. Agro. Alim., Distribution, secteurs where a Consehe could benefit from his/her experience). Then, in a groupe international leader in the sector des boissons, elle passé over 20 years à diverhis/her responsibilities operational (profit centers, ventes-marketing, innovation) and strategic in France and worldwide. In this capacity, she has participated aux Executive Committees, has led des grandes multicultural teams and fonctionnelles. Elle sait ce que signifie conduire within the framework d’une vision strategic of actions on the terrain. D’une famille d’entrepreneurs, she has invested in start-ups and supports them. Elle sait donc s’adapter à des organisations of different tailles. Trilingual French/English/German, member de l’IFA</span><b><span style=\"font-size: small;\">. </span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_632\"><span style=\"font-size: small;\">Ref: 632</span></p>",
    "au_cours_des_22_dernieres_annees_cette_candid_2": "<div align=\"center\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.au_cours_des_22_dernieres_annees_cette_candid_3\"><div align=\"left\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.au_cours_des_22_dernieres_annees_cette_candid\"><span style=\"font-size: small;\"><b>Over the 22 dernières années, cette candidate in a position d’director has been member de Executive Committees, experte en finance, strategy and projets de transformation both in France and qu’à l’international in the sectors des services financiers, des infrastructures liées aux secteurs du transport, de l’énergie, des déchets, and des loisirs. </b></span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_10_ans_dexperience_en_financements_stru\">Après 10 years d’experience en financements structurés in the sectors des utilities and du transport, elle spoke in définition des évolutions strategic d’one of the first groupes bancaires French (évaluations d’investissement, allocation de capital, conclusions de partenariats) and has led projects in transformation majeurs as CFO de groupes international leaders in doMaynes of the gestion d’actifs, of the banque d’investissement, and of the private banking. She served as director moreoverieurs companies du secteur financier in France and à l’étranger (Italie, UK, USA, Hong-Kong), and est currently director de l’association nationale des directeurs financiers, la DFCG, of which she présiof the région Ile de France. She is furthermore member de l’IFA and has initiated le groupe de réflexion IFA/DFCG on the thématique  » CFO and Comité d’Audit « . Elle a enseigné l’analyse financière and control de gestion à Dauphine and à HEC. She is graduate de Sciences Po Paris and de Columbia University.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_813\"><span style=\"font-size: small;\">Ref: 813</span></p>\n</div></td></tr></tbody></table></div>",
    "au_cours_des_22_dernieres_annees_cette_candid_3": "<div align=\"left\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.au_cours_des_22_dernieres_annees_cette_candid\"><span style=\"font-size: small;\"><b>Over the 22 dernières années, cette candidate in a position d’director has been member de Executive Committees, experte en finance, strategy and projets de transformation both in France and qu’à l’international in the sectors des services financiers, des infrastructures liées aux secteurs du transport, de l’énergie, des déchets, and des loisirs. </b></span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.apres_10_ans_dexperience_en_financements_stru\">Après 10 years d’experience en financements structurés in the sectors des utilities and du transport, elle spoke in définition des évolutions strategic d’one of the first groupes bancaires French (évaluations d’investissement, allocation de capital, conclusions de partenariats) and has led projects in transformation majeurs as CFO de groupes international leaders in doMaynes of the gestion d’actifs, of the banque d’investissement, and of the private banking. She served as director moreoverieurs companies du secteur financier in France and à l’étranger (Italie, UK, USA, Hong-Kong), and est currently director de l’association nationale des directeurs financiers, la DFCG, of which she présiof the région Ile de France. She is furthermore member de l’IFA and has initiated le groupe de réflexion IFA/DFCG on the thématique  » CFO and Comité d’Audit « . Elle a enseigné l’analyse financière and control de gestion à Dauphine and à HEC. She is graduate de Sciences Po Paris and de Columbia University.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_813\"><span style=\"font-size: small;\">Ref: 813</span></p>\n</div>",
    "directrice_financiere_et_des_operations_avec__2": "<div align=\"center\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.directrice_financiere_et_des_operations_avec__3\" height=\"162\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.directrice_financiere_et_des_operations_avec_\"><span style=\"font-size: small;\"><b>CFO and des Opérations,</b> <b>avec 25 years d´experience dans of groups industrial international listed en bourse, des secteurs Énergie, Environnement, Aluminium, Emballage, Chimie and Services B2B</b> </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_dispose_d_une_vaste_pratique_du_\">The candidate dispose d´une vaste pratique du «  Risk management « , des grands projets d´investissements, des fusions &amp; acquisitions, and of the transformation des organisations, tant in périodes de croissance que de crise économique globale. Grâce aux différents mandates qu’she has helds, including comme director de subsidiaries, dont l´un de co-Présidente d´un Conseil, she has acquired une experience in-depth of the governance des joint-ventures international in contextes complexes and politiquement sensibles.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.diplomee_d_hec_et_du_mba_de_mcgill_university\">Graduate d´HEC (and du MBA de McGill University au Canada), complété d´une formation récente au MIT (Sloan School of Management), she lives in Germany, parle couramment l´English, l´German and l´Spanish, and pourra provide the benefit of le Conseil of his vécu international.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_803\"><span style=\"font-size: small;\">Ref: 803 .</span><b><span style=\"font-size: small;\"> </span> </b></p>\n</td></tr></tbody></table></div>\n<p align=\"center\"> </p>",
    "directrice_financiere_et_des_operations_avec__3": "<p data-i18n=\"page_candidats_mandataires_sociaux.directrice_financiere_et_des_operations_avec_\"><span style=\"font-size: small;\"><b>CFO and des Opérations,</b> <b>avec 25 years d´experience dans of groups industrial international listed en bourse, des secteurs Énergie, Environnement, Aluminium, Emballage, Chimie and Services B2B</b> </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_dispose_d_une_vaste_pratique_du_\">The candidate dispose d´une vaste pratique du «  Risk management « , des grands projets d´investissements, des fusions &amp; acquisitions, and of the transformation des organisations, tant in périodes de croissance que de crise économique globale. Grâce aux différents mandates qu’she has helds, including comme director de subsidiaries, dont l´un de co-Présidente d´un Conseil, she has acquired une experience in-depth of the governance des joint-ventures international in contextes complexes and politiquement sensibles.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.diplomee_d_hec_et_du_mba_de_mcgill_university\">Graduate d´HEC (and du MBA de McGill University au Canada), complété d´une formation récente au MIT (Sloan School of Management), she lives in Germany, parle couramment l´English, l´German and l´Spanish, and pourra provide the benefit of le Conseil of his vécu international.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_803\"><span style=\"font-size: small;\">Ref: 803 .</span><b><span style=\"font-size: small;\"> </span> </b></p>",
    "candidate_administratrice_independante_experi_2": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_experi_3\" height=\"199\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_experi\"><b><span style=\"font-size: small;\"> Candidate independent director. Experience international. Telecoms, Spatial, Conseil en R&amp;D, SSII. Excellente maîtrise des problèmes de governance.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_de_formation_juridique_internati\"><span style=\"font-size: small;\">The candidate, by training legal international (UK, France and USA) has held of positions de Legal Director and Board Secretary d’importantes listed companies and non listed ayant of activities largement international in doMaynes des telecoms, du conseil en R&amp;D, des SSII and de l’industrie spatiale. Elle has acquired une extensive experience des restructurings, of partnerships in multiples pays whose Qatar and le Japon, du M&amp;A dans différents pays whose France and les USA, and du white-collar criminal law. Au titre of his/her activités in the capacity of Board Secretary, she served as fortement impliquée in problématiques de governance and est habituée aux pratiques des conseils multinationaux . She served as director de subsidiaries in Italy and in Germany. </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_504\"><span style=\"font-size: small;\">Ref: 504</span></p>\n</td></tr></tbody></table>",
    "candidate_administratrice_independante_experi_3": "<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_experi\"><b><span style=\"font-size: small;\"> Candidate independent director. Experience international. Telecoms, Spatial, Conseil en R&amp;D, SSII. Excellente maîtrise des problèmes de governance.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_de_formation_juridique_internati\"><span style=\"font-size: small;\">The candidate, by training legal international (UK, France and USA) has held of positions de Legal Director and Board Secretary d’importantes listed companies and non listed ayant of activities largement international in doMaynes des telecoms, du conseil en R&amp;D, des SSII and de l’industrie spatiale. Elle has acquired une extensive experience des restructurings, of partnerships in multiples pays whose Qatar and le Japon, du M&amp;A dans différents pays whose France and les USA, and du white-collar criminal law. Au titre of his/her activités in the capacity of Board Secretary, she served as fortement impliquée in problématiques de governance and est habituée aux pratiques des conseils multinationaux . She served as director de subsidiaries in Italy and in Germany. </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_504\"><span style=\"font-size: small;\">Ref: 504</span></p>",
    "administratrice_independante_mba_doxford_univ": "<table border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_mba_doxford_univ_2\">\n<div align=\"left\"><span style=\"font-size: small;\"><b> Director Indépendante, MBA d’Oxford University avec over 15 years d’experience managériale and de « Corporate Governance » acquise principalement in Entreprises non listed de Taille Intermédiaire in France, Angleterre and in the USA.</b> </span></div>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.au_travers_des_activites_menees_dans_postes_t\"><span style=\"font-size: small;\">Throughs activités menées dans postes tenus in Paris and in Oxford, the candidate has developed des competences de généraliste en gestion, finance and développement commercial in the sector des services within PME European. Au fil des last five years, she has acquired une experience in relations with the shareholders (of the fundraising au reporting trimestriel and organisation/animation des general meetings) as well as in governance intégrant la dimension RSE and l’audit financier, social and environnemental.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.apres_avoir_en_angleterre_co_developpe_ex_nih\"><span style=\"font-size: small;\">After having in England co-développé ex-nihilo une company du doMayne of the finance éthique and de l’real estate responsable of which she est aujourd’hui director, the candidate est rentrée in France en 2010 to créer une company similaire. She is aujourd’hui PDG. Son mandate d’director will end en July 2012, lui laissant of availability pour exercer efficacement a position d’independent director, in particular in a company with activités en UK.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.formation_master_of_business_administration_u\"><span style=\"font-size: small;\">Education: Master of Business Administration, Université d’Oxford (SBS) and formation continue auprès de l’Institute of Directors and l’Institut French des Directors. »</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_107\"><span style=\"font-size: small;\">Ref: 107</span></p>\n</td></tr></tbody></table>",
    "administratrice_independante_mba_doxford_univ_2": "<div align=\"left\"><span style=\"font-size: small;\"><b> Director Indépendante, MBA d’Oxford University avec over 15 years d’experience managériale and de « Corporate Governance » acquise principalement in Entreprises non listed de Taille Intermédiaire in France, Angleterre and in the USA.</b> </span></div>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.au_travers_des_activites_menees_dans_postes_t\"><span style=\"font-size: small;\">Throughs activités menées dans postes tenus in Paris and in Oxford, the candidate has developed des competences de généraliste en gestion, finance and développement commercial in the sector des services within PME European. Au fil des last five years, she has acquired une experience in relations with the shareholders (of the fundraising au reporting trimestriel and organisation/animation des general meetings) as well as in governance intégrant la dimension RSE and l’audit financier, social and environnemental.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.apres_avoir_en_angleterre_co_developpe_ex_nih\"><span style=\"font-size: small;\">After having in England co-développé ex-nihilo une company du doMayne of the finance éthique and de l’real estate responsable of which she est aujourd’hui director, the candidate est rentrée in France en 2010 to créer une company similaire. She is aujourd’hui PDG. Son mandate d’director will end en July 2012, lui laissant of availability pour exercer efficacement a position d’independent director, in particular in a company with activités en UK.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.formation_master_of_business_administration_u\"><span style=\"font-size: small;\">Education: Master of Business Administration, Université d’Oxford (SBS) and formation continue auprès de l’Institute of Directors and l’Institut French des Directors. »</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_107\"><span style=\"font-size: small;\">Ref: 107</span></p>",
    "administratrice_independante_20_ans_dexperien_2": "<div align=\"center\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_20_ans_dexperien_3\" valign=\"top\">\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_20_ans_dexperien\"><span style=\"font-size: small;\"><b>Independent director, 20 years d’experience worldwide des NTIC : Entrepreneur, PDG, Investor. </b> The candidate, after serving as director moreoverieurs companies in the world des NTIC and de l’Internet. Aujourd’hui independent director d’une listed company Eurolist C, she could provide the benefit of à d’autres of his experience diversified (Entrepreneur, PDG, Director, Investor). </span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.apres_avoir_occupe_des_postes_de_direction_ge\"><span style=\"font-size: small;\">After holding of positions de Senior Management for 10 years, she created a start-up Internet en 1999 revendue en 2001. Elle réalise alors assignments in conseil en strategy and prend la direction du développement d’a major firm d’audit and de conseil avant de rejoindre un fonds d’investissement comme « Partner ».</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.apres_un_master_2_universite_de_paris_2_dassa\"><span style=\"font-size: small;\">Après un Master 2 Université de Paris 2 d’Assas en « Coaching », she creates en 2010 sa company de « Business Coaching » pour aujourd’hui accompagner des companies dans leur développement through the missions de « Coaching » de dirigeants and d’accompagnement operational.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.formation_doctorat_de_gestion_universite_de_p\"><span style=\"font-size: small;\">Education: Doctorat de gestion Université de Paris 1, MBA, Master 2 coaching Assas.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_152\"><span style=\"font-size: small;\">Ref: 152</span></p>\n</td></tr></tbody></table></div>\n<p align=\"center\"> </p>",
    "administratrice_independante_20_ans_dexperien_3": "<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.administratrice_independante_20_ans_dexperien\"><span style=\"font-size: small;\"><b>Independent director, 20 years d’experience worldwide des NTIC : Entrepreneur, PDG, Investor. </b> The candidate, after serving as director moreoverieurs companies in the world des NTIC and de l’Internet. Aujourd’hui independent director d’une listed company Eurolist C, she could provide the benefit of à d’autres of his experience diversified (Entrepreneur, PDG, Director, Investor). </span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.apres_avoir_occupe_des_postes_de_direction_ge\"><span style=\"font-size: small;\">After holding of positions de Senior Management for 10 years, she created a start-up Internet en 1999 revendue en 2001. Elle réalise alors assignments in conseil en strategy and prend la direction du développement d’a major firm d’audit and de conseil avant de rejoindre un fonds d’investissement comme « Partner ».</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.apres_un_master_2_universite_de_paris_2_dassa\"><span style=\"font-size: small;\">Après un Master 2 Université de Paris 2 d’Assas en « Coaching », she creates en 2010 sa company de « Business Coaching » pour aujourd’hui accompagner des companies dans leur développement through the missions de « Coaching » de dirigeants and d’accompagnement operational.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.formation_doctorat_de_gestion_universite_de_p\"><span style=\"font-size: small;\">Education: Doctorat de gestion Université de Paris 1, MBA, Master 2 coaching Assas.</span></p>\n<p align=\"left\" data-i18n=\"page_candidats_mandataires_sociaux.ref_152\"><span style=\"font-size: small;\">Ref: 152</span></p>",
    "candidate_a_un_poste_dadministratrice_indepen_13": "<div align=\"center\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_14\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_4\"><span style=\"font-size: small;\"><b>Candidate in a position d’independent director in the doMayne of the santé </b> Docteur en médecine, spécialiste qualified en santé publique, she has held des fonctions très diverses in services de l’état and de 2 régimes d’assurance maladie Elle envisage de prendre sa retraite au 01/07/2013 and pense en tant qu’independent director pouvoir provide the benefit of of his experience extensive un Conseil d’Administration d’une company opérant on marchés of the santé. Pour s’y préparer, elle devenue member l’IFA (Institut French des Directors)and Certified Director after having suivi le cours by training proposé par l’ IFA /Science Po . </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_365\"><span style=\"font-size: small;\">Ref: 365</span></p>\n</td></tr></tbody></table></div>",
    "candidate_a_un_poste_dadministratrice_indepen_14": "<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_indepen_4\"><span style=\"font-size: small;\"><b>Candidate in a position d’independent director in the doMayne of the santé </b> Docteur en médecine, spécialiste qualified en santé publique, she has held des fonctions très diverses in services de l’état and de 2 régimes d’assurance maladie Elle envisage de prendre sa retraite au 01/07/2013 and pense en tant qu’independent director pouvoir provide the benefit of of his experience extensive un Conseil d’Administration d’une company opérant on marchés of the santé. Pour s’y préparer, elle devenue member l’IFA (Institut French des Directors)and Certified Director after having suivi le cours by training proposé par l’ IFA /Science Po . </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_365\"><span style=\"font-size: small;\">Ref: 365</span></p>",
    "femme_ingenieur_supelec_candidate_comme_admin_2": "<div align=\"center\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.femme_ingenieur_supelec_candidate_comme_admin_3\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.femme_ingenieur_supelec_candidate_comme_admin\"><b><span style=\"font-size: small;\">Femme engineer Supelec, candidate comme director independent</span></b>e</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.pour_avoir_occupe_dans_des_ssii_pendant_plusi\"><span style=\"font-size: small;\">Pour avoir occupé in SSII pendant plusieurs années of positions de PDG, Chairwoman of the Executive Board, Director de SA and créé une SAS in the doMayne du luxe, the candidate a une experience in-depth of positions operational de dirigeante comportant among other things, IPO, fusions-acquisitions, création d’company, fundraising.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_elle_travaille_dans_le_domaine_des\">Aujourd’hui, elle travaille in the doMayne of funds d’investissement.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_612\"><span style=\"font-size: small;\">Ref: 612</span></p>\n</td></tr></tbody></table></div>",
    "femme_ingenieur_supelec_candidate_comme_admin_3": "<p data-i18n=\"page_candidats_mandataires_sociaux.femme_ingenieur_supelec_candidate_comme_admin\"><b><span style=\"font-size: small;\">Femme engineer Supelec, candidate comme director independent</span></b>e</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.pour_avoir_occupe_dans_des_ssii_pendant_plusi\"><span style=\"font-size: small;\">Pour avoir occupé in SSII pendant plusieurs années of positions de PDG, Chairwoman of the Executive Board, Director de SA and créé une SAS in the doMayne du luxe, the candidate a une experience in-depth of positions operational de dirigeante comportant among other things, IPO, fusions-acquisitions, création d’company, fundraising.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_elle_travaille_dans_le_domaine_des\">Aujourd’hui, elle travaille in the doMayne of funds d’investissement.</p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_612\"><span style=\"font-size: small;\">Ref: 612</span></p>",
    "candidate_a_un_poste_dadministratrice_comme_m_2": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_comme_m_3\" valign=\"top\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_comme_m\"><b><span style=\"font-size: small;\">Candidate in a position d’director, comme member du Comité Strategy or d’audit Très extensive experience of the finance à l’international. </span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.diplomee_dhec_de_la_london_business_school_et\"><span style=\"font-size: small;\">Graduate d’HEC, of the London Business School and de New York University (International Program), elle commence au sein d’une grande banque American par gérer les relations with grandes companies du secteur privé and public. En 1985, elle rejoint une banque d’affaires international renommée for the opérations de conseil financier and de fusions / acquisitions. Elle a conseillé des Etats, in particular de pays émergents, des grandes companies international and des institutions financières, notably sur: – of investments industrial in pays de l’Est and in pays émergents, – des montage and financements of large projets in the sectors de l’énergie and des infrastructures, – des renégociations de dettes – la gestion and la cession de portefeuilles d’actifs and de prêts of large institutions financières. Dans ce cadre, elle a l’habitude de travailler directement with the COMEX and Conseils d’Administration and with the gouvernements.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.elle_est_membre_de_lifa_de_lassociation_hec_d\"><span style=\"font-size: small;\">She is member de l’IFA, de l’association HEC dans ses doMaynes de competences, moreoverieurs organisations de femmes dirigeantes and de Business Angels. »</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_512\"><span style=\"font-size: small;\">Ref: 512 </span></p>\n</td></tr></tbody></table>",
    "candidate_a_un_poste_dadministratrice_comme_m_3": "<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_a_un_poste_dadministratrice_comme_m\"><b><span style=\"font-size: small;\">Candidate in a position d’director, comme member du Comité Strategy or d’audit Très extensive experience of the finance à l’international. </span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.diplomee_dhec_de_la_london_business_school_et\"><span style=\"font-size: small;\">Graduate d’HEC, of the London Business School and de New York University (International Program), elle commence au sein d’une grande banque American par gérer les relations with grandes companies du secteur privé and public. En 1985, elle rejoint une banque d’affaires international renommée for the opérations de conseil financier and de fusions / acquisitions. Elle a conseillé des Etats, in particular de pays émergents, des grandes companies international and des institutions financières, notably sur: – of investments industrial in pays de l’Est and in pays émergents, – des montage and financements of large projets in the sectors de l’énergie and des infrastructures, – des renégociations de dettes – la gestion and la cession de portefeuilles d’actifs and de prêts of large institutions financières. Dans ce cadre, elle a l’habitude de travailler directement with the COMEX and Conseils d’Administration and with the gouvernements.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.elle_est_membre_de_lifa_de_lassociation_hec_d\"><span style=\"font-size: small;\">She is member de l’IFA, de l’association HEC dans ses doMaynes de competences, moreoverieurs organisations de femmes dirigeantes and de Business Angels. »</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_512\"><span style=\"font-size: small;\">Ref: 512 </span></p>",
    "la_candidate_a_un_poste_d_administratrice_ind_2": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_d_administratrice_ind_3\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_d_administratrice_ind\"><b><span style=\"font-size: small;\">The candidate in a position d’ Independent director est lawyer en business law and has been responsable legal de groupes international listed. Un séjour moreoverieurs années comme résidente en Corée du Sud (au sein d’a firm d’lawyers Korean puis à la Chambre de Commerce Franco Coréenne) lui has enabled de connaître de l’intérieur la culture nord asiatique. Elle a donné of courses sur ce thème.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.experience_approfondie_du_domaine_des_ventes_\"><b></b><span style=\"font-size: small;\">Experience in-depth du doMayne des ventes au grand public dont de produits électroniques. En tant qu’lawyer, puis comme responsable legal, she is familière des conseils d’administration. Bilingue français-anglais. Elle connait furthermore la culture germanique. Education: Diplôme de Juriste Conseil d’Entreprise (DJCE), Certificat d’Aptitude à la Profession d’Avocat</span><b><span style=\"font-size: small;\">.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_635\"><span style=\"font-size: small;\">Ref: 635</span></p>\n</td></tr></tbody></table>",
    "la_candidate_a_un_poste_d_administratrice_ind_3": "<p data-i18n=\"page_candidats_mandataires_sociaux.la_candidate_a_un_poste_d_administratrice_ind\"><b><span style=\"font-size: small;\">The candidate in a position d’ Independent director est lawyer en business law and has been responsable legal de groupes international listed. Un séjour moreoverieurs années comme résidente en Corée du Sud (au sein d’a firm d’lawyers Korean puis à la Chambre de Commerce Franco Coréenne) lui has enabled de connaître de l’intérieur la culture nord asiatique. Elle a donné of courses sur ce thème.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.experience_approfondie_du_domaine_des_ventes_\"><b></b><span style=\"font-size: small;\">Experience in-depth du doMayne des ventes au grand public dont de produits électroniques. En tant qu’lawyer, puis comme responsable legal, she is familière des conseils d’administration. Bilingue français-anglais. Elle connait furthermore la culture germanique. Education: Diplôme de Juriste Conseil d’Entreprise (DJCE), Certificat d’Aptitude à la Profession d’Avocat</span><b><span style=\"font-size: small;\">.</span></b></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_635\"><span style=\"font-size: small;\">Ref: 635</span></p>",
    "candidate_administratrice_independante_hotell_4": "<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"3\" width=\"95%\"><tbody><tr><td data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_hotell_5\">\n<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_hotell_2\"><span style=\"font-size: small;\"><b>Candidate independent director : Hôtellerie, Restauration, Tourisme ; France and Europe</b> Experience pluridisciplinaire acquise au sein d’un groupe hôtelier international coté au CAC 40. Au fil de 30 years, dont 12 years in restauration publique, the candidate a successivement occupé of positions de dirigeante in doMaynes varied : contrôle de gestion, produits, opérations, marketing, audit interne, production, publishing and communication des bureaux de ventes international, finally quant à l’efficacité des coûts marketing &amp; distribution. </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_elle_est_consultante_independante__2\"><span style=\"font-size: small;\">Aujourd’hui, she is independent consultant in these doMaynes. Very good knowledge of l’international. Education: Master's in Economics (Paris 2), DEA Théories and Politiques monétaires (Paris 2), Executive Doctorate in Business Administration (Paris Dauphine, 2009). Member de l’IFA and Secretary General de l’Association Européenne de Neuroéconomie.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_303_2\"><span style=\"font-size: small;\">Ref: 303</span></p>\n</td></tr></tbody></table>",
    "candidate_administratrice_independante_hotell_5": "<p data-i18n=\"page_candidats_mandataires_sociaux.candidate_administratrice_independante_hotell_2\"><span style=\"font-size: small;\"><b>Candidate independent director : Hôtellerie, Restauration, Tourisme ; France and Europe</b> Experience pluridisciplinaire acquise au sein d’un groupe hôtelier international coté au CAC 40. Au fil de 30 years, dont 12 years in restauration publique, the candidate a successivement occupé of positions de dirigeante in doMaynes varied : contrôle de gestion, produits, opérations, marketing, audit interne, production, publishing and communication des bureaux de ventes international, finally quant à l’efficacité des coûts marketing &amp; distribution. </span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.aujourdhui_elle_est_consultante_independante__2\"><span style=\"font-size: small;\">Aujourd’hui, she is independent consultant in these doMaynes. Very good knowledge of l’international. Education: Master's in Economics (Paris 2), DEA Théories and Politiques monétaires (Paris 2), Executive Doctorate in Business Administration (Paris Dauphine, 2009). Member de l’IFA and Secretary General de l’Association Européenne de Neuroéconomie.</span></p>\n<p data-i18n=\"page_candidats_mandataires_sociaux.ref_303_2\"><span style=\"font-size: small;\">Ref: 303</span></p>"
  },
