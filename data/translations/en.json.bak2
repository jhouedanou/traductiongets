  "history": {
    "meta": {
      "title": "History - G-ET-S"
    },
    "title": "History",
    "intro": "The press release below describes the takeover by Guy Le Péchon of G & S, a consulting firm founded in 2003 by members of the ADAE association.",
    "press": {
      "title": "Press Release — 4 May 2009",
      "subtitle": "Gouvernance et Structures offers Boards of Directors integrated services",
      "p1": "Gouvernance & Structures, a research and consulting firm founded in 2003, has just been taken over by one of its founding partners, Consultancy International Services.",
      "p2": "Now led by its managing partner, Guy Le Péchon (X-INSEAD, IFA member), the “Governance Advisors” of the G & S network can carry out a wide range of assignments: diagnostics and benchmarking of Board functioning or composition to increase added value, search for corporate officers including independent directors, ad-hoc use of new technologies, and corporate governance surveys and studies.",
      "p3": "Recently, G&S conducted an in-depth study on the presence of women as corporate officers in 550 French companies listed on Euronext, and previously an original survey on the theme of “governance, performance and modernity”, in collaboration with ADAE and Acadys, on a sample including mid-sized companies and subsidiaries of foreign groups."
    },
    "pioneer": {
      "title": "G & S — Pioneer in Observing Board Gender Diversity",
      "p1": "G & S was the first to present detailed statistics on gender diversity in the boards of Euronext Paris-listed companies, during an INSEAD alumni meeting in July 2009, in the lead-up to the Copé-Zimmerman law.",
      "p2": "The G & S study on “The Place of Women Directors in French Listed Companies” presented below was updated using annual reports as of end 2009.",
      "event": "The breakfast meeting organised in early July 2009 by the Club Mixité and the Cercle des Administrateurs INSEAD ALUMNI ASSOCIATION FRANCE on the theme “The place of women directors in French listed companies” brought together over sixty participants.",
      "cta_program": "Click here to download the event programme",
      "cta_slides": "Click here to view the opening slides of the presentation.",
      "cta_extracts": "To receive extracts of the study, please send an email to info@g-et-s.com with your full name, contact details and position"
    }
  },
  "advisors": {
    "title": "The “GOVERNANCE-ADVISORS”™ Network of G & S",
    "touveron": {
      "name": "Alain Touveron",
      "education": "Engineer CPE Lyon, MBA INSEAD Fontainebleau",
      "bio": "After serving as R&D team leader, in Industrial Property and Licensing, and then as Profit Centre Manager at Progil-Groupe RP, Sandoz Basel and Safic Alcan – Groupe Chargeurs Réunis, he spent over 20 years running his own Executive Search firm and co-founded the World Search Group, a federation of European Executive Search firms."
    },
    "pechon": {
      "name": "Guy Le Péchon",
      "role": "(X, MIT, INSEAD), Managing Partner of G & S — Research, Diagnostics, Surveys, IT",
      "bio": "Former Head of IT & Telecommunications Coordination at Rhône-Poulenc. For over a decade, while consulting on Information Systems, he has been working to improve corporate governance. He is an active member of the French Institute of Directors (IFA) and a founding member of the Cercle des Administrateurs. He has been an operational partner in several start-ups."
    },
    "deferron": {
      "name": "Diane de Ferron",
      "role": "Consultant, French-Swiss, expert in family business governance",
      "bio": "A former business law attorney at the Paris Bar, she managed the family wine estate in Gascony for 5 years, developing its international business. She then served for 4 years as Secretary General of the Family Business Network France. Today, she advises family businesses on corporate and family governance, including succession matters."
    },
    "pouyat": {
      "name": "Olivier Pouyat",
      "role": "(Dauphine) Managing Partner of Eloya — HR Consulting",
      "bio": "Trained in management, personal development and recruitment, he heads the Eloya firm, specialised in executive search and coaching of executives and management teams. He has been working on HR projects for seven years, developing expertise across multiple sectors: IT, Services, Banking, Industry, Retail and Construction."
    },
    "linkedin": "LinkedIn"
  },
  "missions": {
    "title": "Assignments",
    "link": {
      "diagnostic": "Board of Directors or Supervisory Board Assessment",
      "search": "Search for Corporate Officers",
      "surveys": "Surveys, Studies and Benchmarking",
      "digital": "Directors and the Ubiquity of Digital"
    },
    "intro": "The references below for corporate officer searches conducted by G & S illustrate the diversity of needs and the adaptability that Gouvernance & Structures brings to each particular case.",
    "case1": {
      "title": "Major French home furnishing distribution company",
      "subtitle": "Evaluation of the potential appointment of a director with logistics expertise.",
      "text": "The study showed that the best solution was to engage an experienced logistics consultant for an 18-month in-depth mission to improve operations. G&S facilitated this recruitment; the CEO considered the final results after two years to be remarkable."
    },
    "case2": {
      "title": "Preliminary study for creating a Board of Directors or Strategic Advisory Board",
      "text": "This study with the leaders of a successful IT services start-up (SAS) helped them understand the advantages and disadvantages of different governance structures and approaches. Given the context and findings, the decision was deferred."
    },
    "case3": {
      "title": "Search and co-optation of a director for INFOGRAMMES",
      "text": "This search for a person with financial expertise was carried out under delicate circumstances, as the entire governance structure of the company was being overhauled to better address the difficulties the company was facing."
    },
    "case4": {
      "title": "Appointment of a director in a major family-owned company: building materials",
      "text": "Six children and their parents share responsibility across the Management Board and Supervisory Board. They chose to bring in an outside director to professionalise the board, benefit from an external perspective on the business, and improve risk analysis."
    },
    "case5": {
      "title": "In the real estate development sector: search for a Secretary General",
      "text": "This successful search demonstrates that G & S’s expertise is not limited to board director appointments."
    },
    "case6": {
      "title": "In the building services sector: search for a CEO and corporate officer, intended to take over the company within 3 years.",
      "text": "An original approach proposed by G & S for business transfers and acquisitions."
    },
    "case7": {
      "title": "Appointment of a director at Proméo",
      "cta": "Click here to read the director’s testimonial"
    },
    "case8": {
      "title": "Appointment of a director for a company about to be listed on Alternext",
      "text": "The independent director thus co-opted is a financial expert. His appointment broadens the previously somewhat family-dominated Board composition. He will support this thriving company in its presentations to financial analysts (road shows)."
    }
  },
  "diag": {
    "title": "Board of Directors or Supervisory Board Assessment / Diagnostic",
    "breadcrumb": "Home >> Assignments >> Board Assessment / Diagnostic",
    "q1": "Is my Board of Directors’ composition aligned with my company’s strategy?",
    "q2": "How does my Board of Directors’ functioning compare to best practices?",
    "q3": "How can we validate the current situation for third parties? How can we improve it?",
    "intro1": "These are sensitive questions you would like answered. But you don’t have time to explore them in depth, and you sense that existing directors may resist if the subject is raised without preparation.",
    "intro2": "Certain third parties (e.g. potential investors) are signalling that they would like information about board functioning before committing further.",
    "proposal": "G & S offers a systematic and rational method for establishing a diagnostic and improvement recommendations.",
    "scope": "G & S works primarily with all types of companies: listed, near-IPO, subsidiaries of foreign companies, financing institutions with directors on other boards, etc. G & S adapts the composition of the team to each particular case and provides a quote with performance commitments.",
    "steps": {
      "title": "The 5 Steps Recommended by G & S",
      "s1": {
        "title": "1 — Fully understand the general context",
        "text": "This involves interviews with you and other persons you designate, in order to fully understand the general context of your company and its Board of Directors."
      },
      "s2": {
        "title": "2 — From the best practices lists, select those most relevant to your context"
      },
      "s3": {
        "title": "3 — G & S then works on your behalf",
        "text": "by studying documentation and interviewing board members to assess how the board functions relative to best practices and peer companies (see G&S survey)."
      },
      "s4": {
        "title": "4 — G & S presents its conclusions and recommendations and delivers a report after validation with you",
        "text": "Certain elements of such a report can serve to establish, for requesting third parties, the observed situation."
      },
      "s5": {
        "title": "5 — G & S supports the implementation",
        "text": "in particular to help drive all stakeholders to improve the situation."
      }
    }
  },
  "search_dir": {
    "title": "Search for Corporate Officers",
    "breadcrumb": "Home >> Assignments >> Search for Corporate Officers",
    "section_title": "Concerns Related to Co-opting a Director",
    "intro": "If you are considering co-opting a new director, corporate officer and/or executive, most likely an external event has prompted you to reflect on your company’s governance.",
    "context": "Often the resignation or retirement of one of your corporate officers, a change in the capital structure, the arrival of a powerful competitor in one of your markets, the desire to grow your business internationally… has given you the idea of co-opting a new director or one of your executives to improve your company’s governance.",
    "value1": "G & S, often involved in this type of reflection, can advise you effectively during this preliminary phase on possible directions.",
    "value2": "In the case of an LLC (SARL), the search is generally not for a director but for a member of the ad hoc committee you may use to support your strategic thinking.",
    "traditional": "The traditional approach for this type of appointment usually involves discussing it with other directors, friends and contacts, to identify the person to co-opt or recruit.",
    "traditional_limits": "This approach ensures confidentiality and requires few resources, but in no way guarantees that the selected candidate is among the best available to improve your company’s governance, and may prove unfortunate in the medium term.",
    "proposal": "G & S offers a method that broadens the search for potential director candidates.",
    "scope": "G & S works primarily with mid-sized listed and unlisted companies, companies approaching IPO, subsidiaries of foreign companies, and financing institutions with directors on other boards. Such companies tend to have fewer resources than large CAC 40 listed companies.",
    "steps": {
      "title": "The 5 Steps Recommended by G & S",
      "s1": {
        "title": "1 — Fully understand the context",
        "text": "This involves interviews with you and other persons you designate, in order to fully understand the general context of your company and its Board of Directors."
      },
      "s2": {
        "title": "2 — Define with you the profile characteristics of the director to be found"
      },
      "s3": {
        "title": "3 — G & S then works on your behalf to select several potential candidates",
        "text": "G & S’s strength is its network of contacts."
      },
      "s4": {
        "title": "4 — You select the candidate of your choice",
        "text": "through well-prepared, focused and efficient interviews. G & S supports you in finalising the terms."
      },
      "s5": {
        "title": "5 — G & S ensures the assignment’s success over the medium term"
      }
    }
  },
  "surveys": {
    "title": "Surveys and Studies",
    "breadcrumb": "Home >> Assignments >> Surveys and Studies",
    "intro": "G & S, on its own behalf or for third-party organisations, conducts in-depth studies and surveys on corporate governance. These surveys serve as the basis for specific benchmarking studies requested by clients.",
    "cta_contact": "If you wish to conduct a survey on a specific topic, please do not hesitate to email G & S: info@g-et-s.com",
    "examples_title": "Two Examples",
    "ex1": {
      "title": "Study of the Place of Women as Corporate Officers in 400 French Companies Listed on Euronext",
      "video_link": "Watch the 3-minute video",
      "full_pres_link": "A complete narrated presentation",
      "text": "Based on 2016 annual reports, a detailed systematic analysis of women in Boards of Directors, Supervisory Boards and Executive Boards enabled G & S, across numerous parameters such as Euronext compartments A, B or C and business type, to assess the place of women in these companies relative to the overall average (men + women).",
      "database": "Thanks to this study, G & S has a database of nearly 1,000 women directors with their key characteristics (age, nationality, independence…).",
      "cta": "If you are interested in this topic, please email G & S: info@g-et-s.com"
    },
    "ex2": {
      "title": "In-depth survey on board functioning in a sample of small to mid-sized companies",
      "text": "Together with ADAE and the firm ACADYS, G & S conducted a detailed questionnaire-based survey of CEOs, Directors and Board Secretaries.",
      "results": {
        "title": "Results",
        "synthesis": "Summary in 5 slides: free download",
        "details": "For more detailed results: 25 and 95 slides",
        "cta": "Email G & S: info@g-et-s.com"
      }
    }
  },
  "training": {
    "title": "Board Member Training",
    "breadcrumb": "Home >> Board Member Training",
    "section1": "LEADERSHIP BODIES TRAINING",
    "original": {
      "title": "Original training programmes offered by G & S",
      "text": "Building on workshops previously offered, such as the behaviour of men and women in Boards (click here to see an example) or the use of personal computers — today it would be the use of social media (click here to see an example), G & S can organise tailored workshops."
    },
    "institutional": {
      "title": "Institutional Training"
    },
    "legislation": {
      "title": "Learn about French legislation on “Women on Boards”",
      "lang_fr": "Detailed French-language summary of French laws on women in Boards",
      "lang_en": "Details in English of the French laws on Women On Boards"
    },
    "law_2014": "The French Law of August 2014 extends the January 2011 Law for unlisted public limited companies (Sociétés Anonymes) from 500 to 250 employees (and €50 million in turnover or total assets), requiring by 2020 that 40% of Board members be women for boards with more than 8 members, and that the difference between the number of men and women be no greater than two for boards with 8 members or fewer.",
    "eu": {
      "title": "The European Commission published a press release on the presence of women on company Boards.",
      "text": "The Commission’s proposed Directive sets a target of 40% women among total non-executive directors by 2020 for listed companies (companies with fewer than 250 employees and turnover below €50 million are excluded) and by 2018 for public enterprises."
    }
  },
  "ifa": {
    "title": "IFA Digital Working Group Reports",
    "intro": "Under the leadership of IFA President Daniel Lebègue, I actively participated in two successive working groups that produced two forward-looking reports:",
    "report1": {
      "title": "What Information Does a Director Need?",
      "text1": "The key task was to properly catalogue, describe and classify the information useful to a director, indicating authors and confidentiality levels throughout the creation/validation process (e.g. the Annual Report).",
      "text2": "This report was the subject of a specific G & S study with a pilot online application offering a catalogue of around one hundred documents identified for directors.",
      "cta_pdf": "Download the PDF report",
      "cta_catalog": "Documents for directors"
    },
    "report2": {
      "title": "The Board of Directors and the Digital Transformation of Companies",
      "text": "The working group’s starting point was to address the risks involved, but it became apparent during the work that it was important to highlight the positive opportunities for the company of this digital transformation.",
      "cta": "Click here to download the document"
    }
  },
