  "page_formations_administrateurs": {
    "insead": "<b><span style=\"color: #0000a0;\">INSEAD</span></b>",
    "international_directors_program": "<a href=\"https://www.insead.edu/executive-education/corporate-governance/aspiring-directors-programme?_ref=finder\"><span style=\"color: #000000;\">International Directors Program</span></a>",
    "executive_educationvision_tres_internationale": "<span style=\"color: #0000ff;\">Executive Education<br/>Highly international vision</span>",
