    "adaeass_des_administrateurs_et_dirigeants_den": "<a align=\"center\" href=\"https://www.club-adae.fr/%F0%9F%9A%80-devenez-un-administrateur-qualifie-independant-avec-ladae/\" target=\"_blank\"><span style=\"color: #000000;\"><b><span style=\"color: #0000cc;\">ADAE </span><span style=\"color: #0000cc;\">Ass. des Administrateurs and Dirigeants d'Entreprises </span></b></span></a>",
