  "page_assises_parite": {
    "forum_de_la_mixite_21_decembre_2012": "<i class=\"fas fa-calendar text-primary me-2\"></i>Gender Diversity Forum - 21 December 2012",
    "webinaire_8_mars_2023": "<i class=\"fas fa-video text-primary me-2\"></i>Webinar - 8 March 2023",
    "presentation_de_letude": "<i class=\"fas fa-chart-line text-primary me-2\"></i>Presentation of the study",
    "au_forum_de_la_mixite_du_21_decembre_2012_guy": "At the Gender Diversity Forum on 21 December 2012, Guy Le Péchon was one of the speakers in the <strong>Leyders Associates</strong> workshop on the theme:",
    "il_a_evoque_les_profils_des_administratrices_": "Il a évoqué les profils des directors within nombreuses listed companies sur Euronext and suggéré surtout penser à convaincre les Chairmen d'élargir de façon professional les cooptations des members de leurs Conseils.",
    "reprenant_mis_a_jour_des_elements_de_son_inte": "Reprenant mis à jour des éléments de son intervention enregistrée - Gender Parity Conference 2012 and 2023 - le 8 mars 2023 dans un Webinaire organisé par le <strong>Centre des Professions financières</strong>, fin juin 2023, Guy Le Péchon a été interviewé par <strong>Lucille Desjonquères</strong> au cours de la séance d'inauguration à <strong>Bercy des Assises de la Parité</strong>.",
    "il_a_pu_donner_un_apercu_de_la_situation_de_l": "Il a pu donner un aperçu de la situation de la féminisation des Instances de Gouvernance (Conseils d'Administration or de Surveillance, COMEX and CODIR) des sociétés du CAC 40 à fin juin 2023.",
    "copie_de_lune_des_planches_majeures_projetees": "<strong>Copy of one of the major slides presented</strong>",
    "g_s_enverra_copie_de_la_presentation_de_letud": "G &amp; S enverra copie de la présentation de l'étude and du rapport détaillé à fin juin 2023 aux personnes le demandant indiquant leurs coordonnées à <a href=\"mailto:contact@g-et-s.com\" style=\"color: #1e73be; text-decoration: underline;\">contact@g-et-s.com</a>",
    "se_positionner_pour_etre_administrable_femini": "\"Positioning yourself to be board-ready. Feminising your board.\"",
    "obtenir_le_rapport_complet": "<i class=\"fas fa-envelope text-info me-2\"></i>Obtain the full report",
    "assises_de_la_parite_2012_et_2023": "Gender Parity Conference 2012 and 2023"
