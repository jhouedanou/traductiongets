  "page_glossaire_prestations": {
    "tant_un_conseil_dadministration_que_des_manag": "Both a board of directors and executive managers may need to use consulting services.",
    "dans_le_cadre_dune_enquete_menee_par_une_equi": "Dans le cadre d'une enquête menée par une équipe de l'association de <a href=\"https://www.xmp-consult.org/agenda/webinar-intelligence-collective-10196\" style=\"color: #1e73be;\" target=\"_blank\">XMP Consult</a>, Association de consultants independent issus de top universities auprès de tels dirigeants, and de la publication des résultats de cette enquête dans leur <a href=\"https://www.xmp-consult.org/global/gene/link.php?doc_id=150&amp;fg=1\" style=\"color: #1e73be;\" target=\"_blank\">lettre annuelle de February 2025</a>, dans laquelle G &amp; S a commis deux articles, he served as jugé utile d'y faire figurer un glossaire des services de conseil pour faciliter le choix entre ce type de prestation.",
    "le_resultat_est_larticle_redige_par_g_s_voir_": "The result is the article written by G &amp; S. voir Page 8 <a href=\"https://www.xmp-consult.org/global/gene/link.php?doc_id=150&amp;fg=1\" style=\"color: #1e73be;\" target=\"_blank\">de la lettre</a>.",
    "larticle_propose_une_classification_des_diffe": "L'article propose une classification des différents types de services de Conseil and pour chacune d'elle un résumé expliquant leur contenu.",
    "quand_un_dirigeant_est_face_a_un_probleme_et_": "Quand un dirigeant est face à un problème and se pose la question quelle de services de conseil faire appel pour m'aider à résoudre ce problème, balayer rapidement ce glossaire devrait lui apporter un éclairage interesting.",
    "images_generees_par_intelligence_artificielle": "Images generated by Artificial Intelligence",
    "pour_plus_dinformations_sur_ce_sujet_nhesitez": "For more information sur ce sujet, n'hésitez pas à nous contacter :",
    "email_contact_g_et_s_com": "<i class=\"fas fa-at text-primary me-2\"></i>\n<strong>Email:</strong> contact@g-et-s.com",
    "nous_contacter": "<i class=\"fas fa-envelope text-primary me-2\"></i>Contact Us",
    "glossaire_des_prestations_de_conseil": "<i class=\"fas fa-book text-primary me-3\"></i>\n                    Consulting Services Glossary"
  },
  "page_historique": {
    "gouvernance_et_structures_propose_aux_conseil": "Governance and Structures propose aux Boards of Directors des services intégrées",
    "communique_de_presse_du_4_mai_2009": "Press Release of 4 May 2009",
    "g_s_pionnier_pour_observation_de_la_feminisat": "<i class=\"fas fa-award\" style=\"margin-right: 10px;\"></i>G &amp; S pionnier pour observation de la feminisation des Boards of Directors",
    "le_communique_de_presse_ci_dessous_indique_la": "Le communiqué de presse ci-dessous indique la reprise par Guy Le Péchon de G &amp; S, cabinet de conseil créé en 2003 par des membres de l'association ADAE",
    "gouvernance_structures_societe_detudes_et_de_": "Governance &amp; Structures, company d'études and de conseil créée en 2003, vient d'être reprise par l'un de ses associés fondateurs, Consultancy International Services.",
    "desormais_anime_par_son_associe_gerant_guy_le": "DésorMays animé par son associé/gérant, Guy Le Péchon, X-INSEAD, member de l'IFA, les « Gouvernance-Advisors » du réseau G &amp; S peuvent mener des missions très diverses : assessment and « benchmarking » sur le fonctionnement or la composition des Boards of Directors en vue d'en augmenter la added value, recherche de corporate officers dont des directors in particular independent, utilisation ad-hoc des nouvelles technologies, enquêtes and études sur la « corporate governance».",
    "ainsi_dernierement_g_s_a_mene_une_etude_appro": "Thus dernièrement G&amp;S a mené une étude in-depth sur la place des femmes corporate officers within 550 companies françaises listed sur Euronext and antérieurement une enquête originale à l'époque sur le thème de - governance, performance and modernité-, enquête en collaboration avec l'ADAE and la company Acadys auprès d'un échantillon comprenant des companies moyennes and subsidiaries de groupes étrangers.",
    "site_internet_http_www_g_et_s_com": "<strong>Website :</strong> <a href=\"http://www.g-et-s.com\" style=\"color: #1e73be;\">http://www.g-et-s.com</a>",
    "contacts_info_g_et_s_com": "<strong>Contacts:</strong> <a href=\"mailto:info@g-et-s.com\" style=\"color: #1e73be;\">info@g-et-s.com</a>",
    "courrier_guy_le_pechon_g_s_2_allee_des_troene": "<strong>Courrier :</strong> Guy Le Péchon, G &amp; S, 2 allée des troènes, 92330 SCEAUX, France",
    "tel_06_16_31_07_15": "<strong>Phone:</strong> 06 16 31 07 15",
    "g_s_a_ete_le_premier_a_presenter_des_statisti": "G &amp; S a été le premier à présenter des statistiques détaillées sur la board gender diversity des listed companies sur Euronext Paris, lors d'une réunion des anciens de l'INSEAD en July 2009 pendant le temps de préparation de la loi Copé Zimmerman.",
    "letude_g_s_sur_la_place_des_femmes_administra": "L'étude G &amp; S sur <b><span style=\"color: #0000ff;\">« La place des women directors dans les listed companies françaises »</span></b> <span style=\"color: #000000;\">présentée ci-dessous a été mise à jour à partir des annual reports à fin 2009.</span>",
    "le_petit_dejeuner_organise_debut_juillet_2009": "<span style=\"color: #0033cc;\">The breakfast event organised in early July 2009</span>",
    "par": "<span style=\"color: #0033cc;\"><br/>by</span>",
    "le_club_mixite_et_le_cercle_des_administrateu": "<span style=\"color: #0033cc;\"><br/>le Club Mixité, and le Cercle des Administrateurs<br/>INSEAD ALUMNI ASSOCIATION FRANCE<br/>sur le thème :</span>",
    "la_place_des_femmes_administrateurs_dans_les_": "<br/><b><span style=\"color: #000066;\">\"The place of women directors in French listed companies\"</span></b>",
    "a_rassemble_plus_dune_soixantaine_de_particip": "<br/>brought together more than sixty participants",
    "voir_les_photos_dans_la_colonne_de_gauche": "See photos in the left column",
    "le_theme_a_ete_introduit_par_guy_le_pechon_as": "The theme was introduced by Guy Le Péchon, Associate/Managing Partner of",
    "gouvernance_structures_par_une_presentation_d": "<br/>Governance &amp; Structures par une présentation des résultats principaux de l'étude in-depth qu'il a menée dans plus de 500 French listed companies sur les marchés A, B and C d'Euronext",
    "pour_teledecharger_le_programme_de_cet_evenem": "<span style=\"color: #ff0000;\">Pour télédécharger le programme de cet évènement</span> <a href=\"./../wp-content/uploads/2020/01/invifad.pdf\">cliquer ici</a><br/><span style=\"color: #ff0000;\">Pour parcourir les premiers transparents de la présentation</span> <a href=\"./../wp-content/uploads/2020/01/debpres.pdf\">cliquer ici.</a><br/><span style=\"color: #ff0000;\">Pour obtenir des extraits de l'étude, envoyer un courriel à</span> <a href=\"mailto:info@g-et-s.com\">info@g-et-s.com</a> en précisant bien vos noms, prénoms, coordonnées and fonctions",
    "historique": "History",
    "le_petit_dejeuner_organise_debut_juillet_2009_2": "<div align=\"center\">\n<p align=\"center\" data-i18n=\"page_historique.le_petit_dejeuner_organise_debut_juillet_2009\"><span style=\"color: #0033cc;\">Le Petit déjeuner organisé début July 2009</span></p>\n<p align=\"center\" data-i18n=\"page_historique.par\"><span style=\"color: #0033cc;\"><br/>par</span></p>\n<p align=\"center\" data-i18n=\"page_historique.le_club_mixite_et_le_cercle_des_administrateu\"><span style=\"color: #0033cc;\"><br/>le Club Gender diversity, and le Cercle des Directors<br/>INSEAD ALUMNI ASSOCIATION FRANCE<br/>sur le thème :</span></p>\n<p align=\"center\" data-i18n=\"page_historique.la_place_des_femmes_administrateurs_dans_les_\"><br/><b><span style=\"color: #000066;\">« La place des women directors dans les listed companies françaises »</span></b></p>\n<p align=\"center\" data-i18n=\"page_historique.a_rassemble_plus_dune_soixantaine_de_particip\"><br/>a rassemblé plus d'une soixantaine de participant(es)</p>\n<p align=\"center\" data-i18n=\"page_historique.voir_les_photos_dans_la_colonne_de_gauche\">See photos in the left column</p>\n<p align=\"center\" data-i18n=\"page_historique.le_theme_a_ete_introduit_par_guy_le_pechon_as\">Le thème a été introduit par Guy Le Péchon, Associé/Gérant de</p>\n<p align=\"center\" data-i18n=\"page_historique.gouvernance_structures_par_une_presentation_d\"><br/>Governance &amp; Structures par une présentation des résultats principaux de l'étude in-depth qu'il a menée dans plus de 500 French listed companies sur les marchés A, B and C d'Euronext</p>\n<p align=\"center\" data-i18n=\"page_historique.pour_teledecharger_le_programme_de_cet_evenem\"><span style=\"color: #ff0000;\">Pour télédécharger le programme de cet évènement</span> <a href=\"./../wp-content/uploads/2020/01/invifad.pdf\">click here</a><br/><span style=\"color: #ff0000;\">Pour parcourir les premiers transparents de la présentation</span> <a href=\"./../wp-content/uploads/2020/01/debpres.pdf\">click here.</a><br/><span style=\"color: #ff0000;\">Pour obtenir des extraits de l'étude, send an eMayl to</span> <a href=\"mailto:info@g-et-s.com\">info@g-et-s.com</a> en précisant bien vos noms, prénoms, coordonnées and fonctions</p>\n</div>"
  },
